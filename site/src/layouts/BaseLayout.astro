---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'BusiKM — elektroniczna kilometrówka dla pojazdów 2,5–3,5 t. GPS tracking, raporty MF 2026, eksport do systemów FK.',
  ogImage = '/og-image.png',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://busikm.pl';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const fullTitle = title.includes('BusiKM') ? title : `${title} | BusiKM`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Core -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="BusiKM" />
    <meta property="og:locale" content="pl_PL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Additional SEO -->
    <meta name="author" content="BusiKM" />
    <meta name="theme-color" content="#005CE8" />
    <meta name="application-name" content="BusiKM" />
    <meta name="apple-mobile-web-app-title" content="BusiKM" />
    <meta name="format-detection" content="telephone=no" />

    <!-- AI / LLM / Search Bot hints -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "BusiKM",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, iOS, Android",
      "description": "Elektroniczna kilometrówka dla pojazdów 2,5–3,5 t. Automatyczna ewidencja przebiegu z GPS, raporty MF, eksport do systemów FK.",
      "url": siteUrl,
      "image": ogImageUrl,
      "author": {
        "@type": "Organization",
        "name": "BusiKM",
        "url": siteUrl
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "PLN",
        "lowPrice": "0",
        "highPrice": "149",
        "offerCount": "4",
        "offers": [
          { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "PLN", "description": "1 pojazd, 1 kierowca" },
          { "@type": "Offer", "name": "Starter", "price": "59", "priceCurrency": "PLN", "description": "Do 10 pojazdów, raporty PDF" },
          { "@type": "Offer", "name": "Professional", "price": "89", "priceCurrency": "PLN", "description": "Do 50 pojazdów, eksport FK, mapa real-time" },
          { "@type": "Offer", "name": "Enterprise", "price": "149", "priceCurrency": "PLN", "description": "Bez limitu, multi-tenant, API, white-label" }
        ]
      },
      "featureList": [
        "GPS background tracking",
        "Automatyczna klasyfikacja tras AI",
        "Raport ewidencji przebiegu wg wzoru MF",
        "Eksport Insert GT (EDI++)",
        "Tryb offline",
        "Panel multi-klient dla biur rachunkowych",
        "Dashboard zarządzania flotą",
        "Alerty dokumentów (OC, przegląd, tachograf)"
      ]
    })} />

    <!-- Structured Data: WebSite (for sitelinks search) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "BusiKM",
      "url": siteUrl,
      "description": "Elektroniczna kilometrówka dla flot pojazdów 2,5–3,5 t",
      "inLanguage": "pl-PL"
    })} />

    <!-- Google Analytics placeholder -->
    <!-- Odkomentuj i wstaw swój Measurement ID (G-XXXXXXXXXX) -->
    <!--
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    -->

    <!-- Google Tag Manager placeholder -->
    <!-- Odkomentuj i wstaw swój Container ID (GTM-XXXXXXX) -->
    <!--
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-XXXXXXX');</script>
    -->

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-white">
    <slot />
  </body>
</html>
