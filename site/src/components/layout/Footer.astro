---
import Logo from './Logo.astro';

const col1 = [
  { href: '/dla-kierowcow', label: 'Dla kierowców' },
  { href: '/dla-wlascicieli', label: 'Dla właścicieli flot' },
  { href: '/dla-ksiegowych', label: 'Dla księgowych' },
  { href: '/dla-biur-rachunkowych', label: 'Dla biur rachunkowych' },
];
const col2 = [
  { href: '/funkcje', label: 'Funkcje' },
  { href: '/cennik', label: 'Cennik' },
  { href: '/roadmapa', label: 'Roadmapa' },
];
const col3 = [
  { href: '/docs', label: 'Dokumentacja' },
  { href: '/docs/architektura', label: 'Architektura' },
  { href: '/docs/api', label: 'API' },
  { href: '/docs/bezpieczenstwo', label: 'Bezpieczeństwo' },
];
---

<footer class="bg-[#111113] text-[#A1A1A6]">
  <!-- Top section -->
  <div class="max-w-[1120px] mx-auto px-5 sm:px-8 pt-16 pb-12">
    <div class="grid grid-cols-2 lg:grid-cols-[1fr_auto_auto_auto] gap-10 lg:gap-16">

      <!-- Brand col -->
      <div class="col-span-2 lg:col-span-1">
        <Logo size="sm" color="white" />
        <p class="mt-4 text-[13.5px] font-semibold text-[#A1A1A6]">BusiKM</p>
        <p class="mt-2 text-[13.5px] leading-relaxed text-[#6E6E73] max-w-[260px]">
          Elektroniczna kilometrówka dla firm i&nbsp;flot.<br/>
          GPS + raport MF + eksport do systemów FK.
        </p>
        <!-- Trust badges -->
        <div class="mt-6 flex flex-col gap-2">
          <div class="flex items-center gap-2 text-[12px] text-[#6E6E73]">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M8 1L10.2 5.5L15 6.2L11.5 9.6L12.4 14.4L8 12L3.6 14.4L4.5 9.6L1 6.2L5.8 5.5L8 1Z" stroke="#34C759" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
            </svg>
            Zgodność z ustawą o VAT (art. 86a)
          </div>
          <div class="flex items-center gap-2 text-[12px] text-[#6E6E73]">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="7" width="12" height="8" rx="2" stroke="#34C759" stroke-width="1.4"/>
              <path d="M5 7V5a3 3 0 016 0v2" stroke="#34C759" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            Dane przechowywane w UE (RODO)
          </div>
        </div>
      </div>

      <!-- Nav cols -->
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#6E6E73] mb-4">Dla kogo</p>
        <ul class="flex flex-col gap-3">
          {col1.map(l => (
            <li>
              <a href={l.href} class="text-[13.5px] text-[#A1A1A6] hover:text-white transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#6E6E73] mb-4">Produkt</p>
        <ul class="flex flex-col gap-3">
          {col2.map(l => (
            <li>
              <a href={l.href} class="text-[13.5px] text-[#A1A1A6] hover:text-white transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#6E6E73] mb-4">Dokumentacja</p>
        <ul class="flex flex-col gap-3">
          {col3.map(l => (
            <li>
              <a href={l.href} class="text-[13.5px] text-[#A1A1A6] hover:text-white transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Contact row -->
  <div class="border-t border-white/[0.06]">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8 py-6 flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
      <a href="https://calendly.com/busikm/30min" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-[#005CE8] text-white text-[13px] font-semibold hover:bg-[#003FAD] transition-colors">
        Umów spotkanie
      </a>
      <a href="https://linktr.ee/busikm.pl" target="_blank" rel="noopener" class="text-[13px] text-[#A1A1A6] hover:text-white transition-colors">
        linktr.ee/busikm.pl
      </a>
      <a href="mailto:kontakt@busikm.pl" class="text-[13px] text-[#A1A1A6] hover:text-white transition-colors">
        kontakt@busikm.pl
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.06]">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-[12px] text-[#6E6E73]">&copy; 2026 BusiKM. Wszelkie prawa zastrzeżone.</p>
      <p class="text-[12px] text-[#6E6E73]">Zbudowano z Astro + Tailwind&nbsp;CSS</p>
    </div>
  </div>
</footer>

<!-- Sticky Calendly widget -->
<a
  href="https://calendly.com/busikm/30min"
  target="_blank"
  rel="noopener"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-2 px-5 py-3 rounded-full bg-[#005CE8] text-white text-[14px] font-semibold shadow-[0_4px_20px_rgba(0,92,232,0.4)] hover:bg-[#003FAD] hover:shadow-[0_6px_28px_rgba(0,92,232,0.5)] transition-all duration-300 hover:-translate-y-0.5"
  aria-label="Umów spotkanie"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
  </svg>
  <span class="hidden sm:inline">Umów spotkanie</span>
</a>
