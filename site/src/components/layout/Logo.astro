---
interface Props {
  color?: 'dark' | 'white';
  size?: 'sm' | 'md' | 'lg';
}
const { color = 'dark', size = 'md' } = Astro.props;

const iconSizes = { sm: 24, md: 28, lg: 34 };
const iconH = iconSizes[size];

const icons: Record<string, string> = {
  dark: '/logo/ios-icon-iOS-Default.png',
  white: '/logo/ios-icon-iOS-ClearDark.png',
};

const src = icons[color];
---

<a href="/" class="inline-flex items-center shrink-0" aria-label="BusiKM — strona główna">
  <img
    src={src}
    alt="BusiKM"
    height={iconH}
    width={iconH}
    style={`height:${iconH}px;width:${iconH}px;border-radius:22%;`}
    loading="eager"
  />
</a>

<style>
  a { text-decoration: none; }
</style>
