---
interface Props {
  variant?: 'full' | 'mark';
  color?: 'dark' | 'white' | 'brand';
  size?: 'sm' | 'md' | 'lg';
}
const { variant = 'full', color = 'dark', size = 'md' } = Astro.props;

const heights = { sm: 28, md: 34, lg: 42 };
const h = heights[size];

const logos: Record<string, Record<string, string>> = {
  full: {
    dark: '/logo/logo_light-mode.png',
    white: '/logo/logo_dark-mode.png',
    brand: '/logo/logo_light-mode.png',
  },
  mark: {
    dark: '/logo/logo_rounded-dark.png',
    white: '/logo/logo_rounded-light.png',
    brand: '/logo/logo_rounded-brand.png',
  },
};

const src = logos[variant][color];
---

<a href="/" class="inline-flex items-center shrink-0" aria-label="BusiKM — strona główna">
  <img
    src={src}
    alt="BusiKM"
    height={h}
    style={`height:${h}px;width:auto;`}
    loading="eager"
  />
</a>

<style>
  a { text-decoration: none; }
</style>
