---
interface Props {
  variant?: 'full' | 'mark';
  color?: 'dark' | 'white' | 'brand';
  size?: 'sm' | 'md' | 'lg';
}
const { variant = 'full', color = 'dark', size = 'md' } = Astro.props;

const heights = { sm: 28, md: 34, lg: 42 };
const h = heights[size];

const src = variant === 'full'
  ? (color === 'white' ? '/logo/busikm_full_white.svg' : '/logo/busikm_full_dark.svg')
  : (color === 'brand' ? '/logo/busikm_badge_brand_2x.png' : color === 'white' ? '/logo/busikm_badge_white_2x.png' : '/logo/busikm_badge_dark_2x.png');

const imgWidth = variant === 'full' ? Math.round(h * (128/44)) : h;
---

<a href="/" class="inline-flex items-center shrink-0" aria-label="BusiKM — strona główna">
  <img
    src={src}
    alt="BusiKM"
    width={imgWidth}
    height={h}
    style={`height:${h}px;width:auto;`}
    loading="eager"
  />
</a>

<style>
  a { text-decoration: none; }
</style>
