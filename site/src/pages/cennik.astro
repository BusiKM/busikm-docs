<script>
  // Toggle tabs
  const tabFirms = document.getElementById('tab-firms')!;
  const tabBr = document.getElementById('tab-br')!;
  const pricingFirms = document.getElementById('pricing-firms')!;
  const pricingBr = document.getElementById('pricing-br')!;

  function showFirms() {
    tabFirms.className = 'px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 bg-[#005CE8] text-white';
    tabBr.className = 'px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 text-[#6E6E73] hover:text-[#1D1D1F]';
    pricingFirms.classList.remove('hidden');
    pricingBr.classList.add('hidden');
  }

  function showBr() {
    tabBr.className = 'px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 bg-[#005CE8] text-white';
    tabFirms.className = 'px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 text-[#6E6E73] hover:text-[#1D1D1F]';
    pricingBr.classList.remove('hidden');
    pricingFirms.classList.add('hidden');
  }

  tabFirms.addEventListener('click', showFirms);
  tabBr.addEventListener('click', showBr);

  // BR ROI Calculator
  const brSlider = document.getElementById('br-vehicles') as HTMLInputElement;

  function fmt(n: number): string {
    return Math.round(n).toLocaleString('pl-PL').replace(/\u00a0/g, ' ') + ' zł';
  }

  function calcBrCost(vehicles: number): number {
    if (vehicles <= 30) return vehicles * 49;
    if (vehicles <= 80) return vehicles * 39;
    return vehicles * 29;
  }

  function calcBr() {
    const vehicles = parseInt(brSlider.value);
    (document.getElementById('br-vehicles-val') as HTMLElement).textContent = String(vehicles);

    const cost = calcBrCost(vehicles);
    const manual = vehicles * 76;
    const monthly = manual - cost;
    const yearly = monthly * 12;

    (document.getElementById('br-cost') as HTMLElement).textContent = fmt(cost);
    (document.getElementById('br-manual') as HTMLElement).textContent = fmt(manual);
    (document.getElementById('br-monthly') as HTMLElement).textContent = fmt(monthly);
    (document.getElementById('br-yearly') as HTMLElement).textContent = fmt(yearly);
  }

  brSlider.addEventListener('input', calcBr);
  calcBr();

  // Reveal animations
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));
</script>
