---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Cennik — BusiKM" description="BusiKM — elektroniczna kilometrówka GPS dla firm i flot. Od 19 zł/pojazd/mies. Dla biur rachunkowych: firmy klientów dostają dostęp gratis. Zgodność z art. 86a ustawy o VAT.">

<!-- ======================== HERO ======================== -->
<section class="relative overflow-hidden bg-white px-5 py-24 sm:py-32">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-[#005CE8]/[0.04] blur-[140px]"></div>
  </div>

  <div class="relative z-10 max-w-[820px] mx-auto text-center">
    <div class="reveal inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-[#34C759] animate-pulse"></span>
      <span class="text-[12.5px] font-medium text-[#005CE8] tracking-[0.01em]">Cennik &middot; model per pojazd / miesiąc</span>
    </div>

    <h1 class="reveal font-display text-[clamp(2.2rem,5.5vw,3.8rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
      Transparentny cennik.<br/>Płacisz za&nbsp;pojazd.
    </h1>

    <p class="reveal text-[clamp(1rem,2vw,1.25rem)] leading-relaxed text-[#6E6E73] max-w-[560px] mx-auto mb-10">
      Przewidywalne koszty, które skalują się z Twoją flotą. Bez ukrytych opłat. Bez karty kredytowej.
    </p>

    <!-- Toggle -->
    <div class="reveal inline-flex items-center bg-[#F5F5F7] rounded-full p-1">
      <button id="tab-br" class="px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 bg-[#005CE8] text-white">Dla biur rachunkowych</button>
      <button id="tab-firms" class="px-6 py-2.5 rounded-full text-[14px] font-semibold transition-all duration-200 text-[#6E6E73] hover:text-[#1D1D1F]">Dla firm</button>
    </div>
  </div>
</section>

<!-- ======================== PRICING — DLA FIRM ======================== -->
<section id="pricing-firms" class="relative bg-white px-5 pb-24 hidden">
  <div class="max-w-[960px] mx-auto">
    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-3 gap-5 items-start">

      <!-- Free -->
      <div class="rounded-[20px] p-7 border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 flex flex-col">
        <div class="mb-6">
          <h3 class="font-display text-[1.1rem] font-semibold text-[#1D1D1F] mb-1">Free</h3>
          <p class="text-[13px] text-[#86868B]">Testowanie, jednoosobowe działalności</p>
        </div>
        <div class="mb-6">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">0</span>
          <span class="text-[15px] font-semibold text-[#86868B] ml-1">zł</span>
        </div>
        <ul class="space-y-3 text-[13.5px] text-[#6E6E73] mb-8 flex-1">
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>1 pojazd, 1 kierowca</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>GPS tracking + ewidencja przebiegu</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Klasyfikacja tras (służbowa/prywatna)</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Zdjęcia licznika</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/></svg><span class="text-[#C7C7CC]">Brak raportów PDF, eksportu FK, push, mapy</span></li>
        </ul>
        <a href="#trial" class="block text-center border border-[#D2D2D7] text-[#1D1D1F] font-semibold text-[14px] px-5 py-3 rounded-full hover:bg-[#F5F5F7] transition-all">Rozpocznij za darmo</a>
      </div>

      <!-- Starter -->
      <div class="rounded-[20px] p-7 border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 flex flex-col">
        <div class="mb-6">
          <h3 class="font-display text-[1.1rem] font-semibold text-[#1D1D1F] mb-1">Starter</h3>
          <p class="text-[13px] text-[#86868B]">Małe floty 2–10 pojazdów</p>
        </div>
        <div class="mb-1">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">19</span>
          <span class="text-[15px] font-semibold text-[#86868B] ml-1">zł</span>
        </div>
        <p class="text-[12px] text-[#86868B] mb-6">za pojazd / miesiąc &middot; min. 38 zł/mies.</p>
        <ul class="space-y-3 text-[13.5px] text-[#6E6E73] mb-8 flex-1">
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Wszystko z Free</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Do 10 pojazdów i kierowców</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Raporty PDF wg wzoru MF (art. 86a)</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Eksport CSV</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Alerty dokumentów (push)</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Zaproszenia dla kierowców</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/></svg><span class="text-[#C7C7CC]">Brak eksportu FK i mapy real-time</span></li>
        </ul>
        <a href="#trial" class="block text-center bg-[#1D1D1F] text-white font-semibold text-[14px] px-5 py-3 rounded-full hover:bg-[#333] transition-all">Wypróbuj 14 dni za darmo</a>
      </div>

      <!-- Professional -->
      <div class="rounded-[20px] p-7 border border-[#005CE8] bg-[#005CE8] text-white shadow-[0_8px_40px_rgba(0,92,232,0.30)] transition-all duration-300 sm:scale-[1.04] flex flex-col relative">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span class="bg-[#34C759] text-white text-[11px] font-bold px-4 py-1.5 rounded-full whitespace-nowrap tracking-wide uppercase">Najpopularniejszy</span>
        </div>
        <div class="mb-6 mt-2">
          <h3 class="font-display text-[1.1rem] font-semibold text-white mb-1">Professional</h3>
          <p class="text-[13px] text-white/70">Floty 11–50 pojazdów, firmy z księgową</p>
        </div>
        <div class="mb-1">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-white">29</span>
          <span class="text-[15px] font-semibold text-white/70 ml-1">zł</span>
        </div>
        <p class="text-[12px] text-white/60 mb-6">za pojazd / miesiąc &middot; min. 319 zł/mies.</p>
        <ul class="space-y-3 text-[13.5px] text-white/90 mb-8 flex-1">
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Wszystko ze Starter</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Do 50 pojazdów i kierowców</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Pełny eksport FK: Insert GT, Comarch, Symfonia</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Mapa floty w czasie rzeczywistym</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Dashboard zgodności</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Tryb offline + raporty PDF/CSV/Excel</li>
          <li class="flex items-start gap-2.5"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Alerty dokumentów — push + e-mail</li>
        </ul>
        <a href="#trial" class="block text-center bg-white text-[#005CE8] font-bold text-[14px] px-5 py-3 rounded-full hover:bg-white/90 transition-all">Wypróbuj 14 dni za darmo</a>
      </div>

    </div>

    <div class="reveal text-center mt-8 mb-4">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#34C759]/[0.08] text-[13px] font-semibold text-[#34C759]">14 dni pełnego dostępu do Professional — za darmo, bez karty kredytowej</span>
    </div>
    <p class="reveal text-center text-[13px] text-[#86868B] max-w-[520px] mx-auto">
      Ceny przed pełnym wdrożeniem MVP. Po okresie pilotażowym zapytamy użytkowników o optymalny model cenowy. Przy rozliczeniu rocznym <span class="font-semibold text-[#34C759]">&minus;15%</span>.
    </p>
    <p class="reveal text-center text-[13px] text-[#86868B] mt-3">
      Powyżej 50 pojazdów? Napisz do nas: <a href="mailto:kontakt@busikm.pl" class="text-[#005CE8] font-medium hover:underline">kontakt@busikm.pl</a>
    </p>
  </div>
</section>

<!-- ======================== PRICING — DLA BIUR RACHUNKOWYCH ======================== -->
<section id="pricing-br" class="relative bg-white px-5 pb-24">
  <div class="max-w-[960px] mx-auto">

    <div class="reveal text-center mb-12">
      <h2 class="font-display text-[clamp(1.6rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15] mb-4">
        Model per pojazd. Firmy klientów dostają&nbsp;BusiKM&nbsp;gratis.
      </h2>
      <p class="text-[15px] text-[#6E6E73] max-w-[600px] mx-auto leading-relaxed">
        Płacisz za aktywne pojazdy klientów. Aktywny pojazd = minimum 1 trasa w miesiącu. Twoi klienci otrzymują pełny dostęp Professional bez dodatkowych opłat.
      </p>
    </div>

    <!-- Tier cards -->
    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-3 gap-5 mb-12">
      {[
        { range: '1–30', price: '49', savings: '27' },
        { range: '31–80', price: '39', savings: '37' },
        { range: '81+', price: '29', savings: '47' },
      ].map((t, i) => (
        <div class:list={['rounded-[20px] p-7 border transition-all duration-300', i === 2 ? 'border-[#005CE8]/20 bg-[#005CE8]/[0.03] shadow-[0_4px_20px_rgba(0,92,232,0.10)]' : 'border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)]']}>
          <p class="text-[12px] font-semibold text-[#86868B] uppercase tracking-[0.06em] mb-3">{t.range} pojazdów</p>
          <div class="mb-4">
            <span class="font-display text-[2.2rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">{t.price}</span>
            <span class="text-[14px] text-[#86868B] ml-1">zł / pojazd / mies.</span>
          </div>
          <div class="space-y-2 text-[13px] text-[#6E6E73]">
            <div class="flex justify-between"><span>Koszt ręczny który eliminujesz</span><span class="font-mono text-[#FF3B30]">76 zł</span></div>
            <div class="flex justify-between pt-2 border-t border-black/[0.06]"><span class="font-semibold text-[#1D1D1F]">Oszczędność / pojazd / mies.</span><span class="font-mono font-bold text-[#34C759]">+{t.savings} zł</span></div>
          </div>
        </div>
      ))}
    </div>

    <!-- What BR gets / What clients get -->
    <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">
      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <h3 class="font-display font-semibold text-[1rem] text-[#1D1D1F] mb-4">Co dostaje biuro rachunkowe</h3>
        <ul class="space-y-2.5 text-[13.5px] text-[#6E6E73]">
          {['Panel multi-tenant (wiele firm)', 'Przełączanie kontekstu między klientami', 'Zbiorczy dashboard wszystkich flot', 'Eksport FK: Insert GT, Comarch, Symfonia', 'Zbiorczy raport PDF / CSV', 'Dashboard oszczędności', 'RBAC — poziomy dostępu per klient', 'Alerty dokumentów dla wszystkich flot'].map(b => (
            <li class="flex items-start gap-2"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#005CE8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <h3 class="font-display font-semibold text-[1rem] text-[#1D1D1F] mb-4">Co dostają firmy klienta (gratis)</h3>
        <ul class="space-y-2.5 text-[13.5px] text-[#6E6E73]">
          {['Pełny Professional bez opłat', 'Aplikacja mobilna (iOS + Android)', 'Raporty PDF wg wzoru MF', 'Alert VAT-26 przy dodawaniu pojazdu', 'GPS background tracking', 'Tryb offline'].map(b => (
            <li class="flex items-start gap-2"><svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Trial box -->
    <div id="trial-br" class="reveal rounded-[20px] p-10 bg-[#005CE8] text-center mb-12" style="scroll-margin-top: 120px;">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/15 text-[12px] font-semibold text-white/80 uppercase tracking-[0.08em] mb-4">Oferta dla biur rachunkowych</div>
      <h3 class="font-display font-bold text-[clamp(1.5rem,4vw,2.2rem)] text-white mb-3 tracking-[-0.02em]">3 miesiące gratis</h3>
      <p class="text-[15px] text-white/70 mb-6 max-w-[480px] mx-auto leading-relaxed">Bez warunków, bez karty kredytowej. Pełny dostęp do panelu biura przez cały okres próbny. Po trialu płacisz tylko za aktywne pojazdy klientów — od 29 zł/pojazd.</p>
      <a href="https://calendly.com/busikm/30min" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-[#005CE8] font-bold text-[15px] px-8 py-4 rounded-full hover:bg-white/90 transition-all shadow-[0_2px_8px_rgba(0,0,0,0.15)]">
        Zacznij bezpłatny trial
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <!-- ROI Calculator for BR -->
    <div class="reveal rounded-[20px] p-7 sm:p-10 bg-white border border-black/[0.06] shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
      <h3 class="font-display font-semibold text-[1.1rem] text-[#1D1D1F] mb-6 text-center">Kalkulator oszczędności biura</h3>

      <div class="max-w-[500px] mx-auto mb-8">
        <div class="flex justify-between items-baseline mb-3">
          <label class="text-[14px] font-semibold text-[#1D1D1F]">Ile pojazdów obsługujesz u klientów?</label>
          <span id="br-vehicles-val" class="font-display text-[1.1rem] font-bold text-[#005CE8]">40</span>
        </div>
        <input type="range" id="br-vehicles" min="1" max="120" value="40" step="1" class="w-full h-1.5 bg-[#E8E8ED] rounded-full appearance-none cursor-pointer accent-[#005CE8] [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-5 [&::-webkit-slider-thumb]:h-5 [&::-webkit-slider-thumb]:bg-[#005CE8] [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:shadow-[0_2px_6px_rgba(0,92,232,0.3)] [&::-moz-range-thumb]:w-5 [&::-moz-range-thumb]:h-5 [&::-moz-range-thumb]:bg-[#005CE8] [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0" />
        <div class="flex justify-between text-[11px] text-[#86868B] mt-1"><span>1</span><span>120</span></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="p-4 rounded-2xl bg-[#F5F5F7]">
          <div class="text-[12px] text-[#86868B] mb-1">Koszt BusiKM / mies.</div>
          <div id="br-cost" class="font-display text-[1.2rem] font-bold text-[#1D1D1F]">—</div>
        </div>
        <div class="p-4 rounded-2xl bg-[#F5F5F7]">
          <div class="text-[12px] text-[#86868B] mb-1">Koszt ręczny / mies.</div>
          <div id="br-manual" class="font-display text-[1.2rem] font-bold text-[#FF3B30]">—</div>
        </div>
        <div class="p-4 rounded-2xl bg-[#34C759]/[0.06]">
          <div class="text-[12px] text-[#86868B] mb-1">Oszczędność / mies.</div>
          <div id="br-monthly" class="font-display text-[1.2rem] font-bold text-[#34C759]">—</div>
        </div>
        <div class="p-4 rounded-2xl bg-[#005CE8]/[0.04]">
          <div class="text-[12px] text-[#86868B] mb-1">Oszczędność / rok</div>
          <div id="br-yearly" class="font-display text-[1.4rem] font-bold text-[#005CE8]">—</div>
        </div>
      </div>

      <p class="text-[11px] text-[#86868B] text-center mt-4 max-w-[560px] mx-auto">Kalkulacja oparta na koszcie 2h pracy księgowej per pojazd miesięcznie przy stawce 38 zł/h (koszt pracodawcy wg danych rynkowych 2026: brutto 5 083 zł + ZUS 19,96% = 6 098 zł / 160h).</p>
    </div>
  </div>
</section>

<!-- ======================== FAQ ======================== -->
<section class="py-24 bg-[#F5F5F7] px-5">
  <div class="max-w-[680px] mx-auto">
    <div class="reveal text-center mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">FAQ</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">Najczęściej zadawane pytania</h2>
    </div>

    <div class="reveal space-y-3">
