---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const checkGreen = '<path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>';
const checkWhite = '<path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>';
const xMark = '<line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/>';

interface Feature {
  name: string;
  free: string;
  starter: string;
  pro: string;
  enterprise: string;
}

const featureGroups: { title: string; features: Feature[] }[] = [
  {
    title: 'Autoryzacja i konto',
    features: [
      { name: 'Rejestracja + logowanie (JWT)', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Weryfikacja e-mail', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Zarządzanie użytkownikami', free: '1 kierowca', starter: 'do 10', pro: 'do 50', enterprise: 'Bez limitu' },
    ],
  },
  {
    title: 'Firma i subskrypcja',
    features: [
      { name: 'CRUD firmy', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Multi-tenant (biuro rachunkowe)', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
      { name: 'Stripe billing', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
    ],
  },
  {
    title: 'Flota',
    features: [
      { name: 'Pojazdy (CRUD)', free: '1 pojazd', starter: 'do 10', pro: 'do 50', enterprise: 'Bez limitu' },
      { name: 'Dokumenty pojazdów', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Alerty OC / przegląd / tachograf', free: 'x', starter: 'push', pro: 'push + e-mail', enterprise: 'push + e-mail + SMS' },
    ],
  },
  {
    title: 'Kierowcy',
    features: [
      { name: 'Kierowcy (CRUD)', free: '1 kierowca', starter: 'do 10', pro: 'do 50', enterprise: 'Bez limitu' },
      { name: 'Zaproszenia e-mail', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Alerty prawa jazdy (PJ)', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
    ],
  },
  {
    title: 'Trasy',
    features: [
      { name: 'Start/stop trasy + GPS', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Obliczanie dystansu', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Klasyfikacja (służbowa/prywatna)', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Zdjęcia licznika', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
    ],
  },
  {
    title: 'Dokumenty i raporty',
    features: [
      { name: 'Ewidencja przebiegu PDF (MF)', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Raporty kosztów floty (CSV+PDF)', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Raporty delegacji (CSV+PDF)', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Dashboard zgodności', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Niestandardowe raporty', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
    ],
  },
  {
    title: 'Eksport FK',
    features: [
      { name: 'Insert GT EDI++ (ewidencja)', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'EDI++ delegacje', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Comarch ERP Optima', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
      { name: 'Symfonia', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
      { name: 'KSeF', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
    ],
  },
  {
    title: 'Aplikacja mobilna',
    features: [
      { name: 'Logowanie + rejestracja tras', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'GPS background + aparat', free: 'check', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Powiadomienia push', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Podgląd floty', free: 'Ograniczony', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Tryb offline (WatermelonDB)', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
    ],
  },
  {
    title: 'Panel webowy',
    features: [
      { name: 'Dashboard', free: 'Podstawowy', starter: 'check', pro: 'check', enterprise: 'Zagregowany AF' },
      { name: 'Zarządzanie flotą', free: '1 pojazd', starter: 'do 10', pro: 'do 50', enterprise: 'Bez limitu' },
      { name: 'Pobieranie raportów', free: 'x', starter: 'PDF', pro: 'PDF + CSV', enterprise: 'PDF + CSV + custom' },
      { name: 'Zarządzanie użytkownikami', free: 'x', starter: 'check', pro: 'check', enterprise: 'check' },
      { name: 'Eksport FK (UI)', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Mapa w czasie rzeczywistym', free: 'x', starter: 'x', pro: 'check', enterprise: 'check' },
      { name: 'Przełączanie klientów (AF)', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
      { name: 'Dostęp API', free: 'x', starter: 'x', pro: 'x', enterprise: 'check' },
    ],
  },
];

function cellHtml(val: string, isPro: boolean): string {
  if (val === 'check') return isPro ? checkWhite : checkGreen;
  if (val === 'x') return xMark;
  return '';
}
function cellText(val: string): string | null {
  if (val === 'check' || val === 'x') return null;
  return val;
}
---

<MarketingLayout title="Cennik" description="Transparentny cennik BusiKM -- placisz za pojazd. 4 plany subskrypcji: Free, Starter, Professional, Enterprise. 14-dniowy trial gratis.">

<!-- ======================== HERO ======================== -->
<section class="relative overflow-hidden bg-white px-5 py-24 sm:py-32">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-[#005CE8]/[0.04] blur-[140px]"></div>
  </div>

  <div class="relative z-10 max-w-[820px] mx-auto text-center">
    <!-- Pill badge -->
    <div class="reveal inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-[#34C759] animate-pulse"></span>
      <span class="text-[12.5px] font-medium text-[#005CE8] tracking-[0.01em]">Cennik &middot; model per-vehicle/month</span>
    </div>

    <h1 class="reveal font-display text-[clamp(2.2rem,5.5vw,3.8rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
      Transparentny cennik.<br/>Płacisz za&nbsp;pojazd.
    </h1>

    <p class="reveal text-[clamp(1rem,2vw,1.25rem)] leading-relaxed text-[#6E6E73] max-w-[560px] mx-auto">
      Przewidywalne koszty, które skalują się z Twoją flotą. Bez ukrytych opłat. 14-dniowy trial bez karty kredytowej.
    </p>
  </div>
</section>

<!-- ======================== PRICING CARDS ======================== -->
<section class="relative bg-white px-5 pb-24">
  <div class="max-w-[1120px] mx-auto">

    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 items-start">

      <!-- Free -->
      <div class="rounded-[20px] p-7 border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] transition-all duration-300 hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] flex flex-col">
        <div class="mb-6">
          <h3 class="font-display text-[1.1rem] font-semibold text-[#1D1D1F] mb-1">Free</h3>
          <p class="text-[13px] text-[#86868B]">Na start, jeden pojazd</p>
        </div>
        <div class="mb-6">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">0</span>
          <span class="text-[15px] font-semibold text-[#86868B] ml-1">PLN</span>
        </div>
        <ul class="space-y-3 text-[13.5px] text-[#6E6E73] mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            1 pojazd, 1 kierowca
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Podstawowe śledzenie GPS
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Ewidencja przebiegu
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="text-[#D2D2D7]">Brak raportów i eksportu FK</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="text-[#D2D2D7]">Brak push i mapy</span>
          </li>
        </ul>
        <a href="#trial" class="block text-center border border-[#D2D2D7] text-[#1D1D1F] font-semibold text-[14px] px-5 py-3 rounded-full hover:bg-[#F5F5F7] hover:border-[#B0B0B8] transition-all">
          Rozpocznij za darmo
        </a>
      </div>

      <!-- Starter -->
      <div class="rounded-[20px] p-7 border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] transition-all duration-300 hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] flex flex-col">
        <div class="mb-6">
          <h3 class="font-display text-[1.1rem] font-semibold text-[#1D1D1F] mb-1">Starter</h3>
          <p class="text-[13px] text-[#86868B]">Małe floty do 10 pojazdów</p>
        </div>
        <div class="mb-1">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">59</span>
          <span class="text-[15px] font-semibold text-[#86868B] ml-1">PLN</span>
        </div>
        <p class="text-[12px] text-[#86868B] mb-6">za pojazd / miesiąc &middot; min. 149 PLN/mies.</p>
        <ul class="space-y-3 text-[13.5px] text-[#6E6E73] mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Do 10 pojazdów i kierowców
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Raporty PDF
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Powiadomienia push
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Alerty dokumentów
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Zaproszenia dla kierowców
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><line x1="5" y1="5" x2="11" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="5" x2="5" y2="11" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="text-[#D2D2D7]">Brak eksportu FK i mapy</span>
          </li>
        </ul>
        <a href="#trial" class="block text-center bg-[#1D1D1F] text-white font-semibold text-[14px] px-5 py-3 rounded-full hover:bg-[#333] transition-all">
          Wypróbuj 14 dni
        </a>
      </div>

      <!-- Professional (FEATURED) -->
      <div class="rounded-[20px] p-7 border border-[#005CE8] bg-[#005CE8] text-white shadow-[0_8px_40px_rgba(0,92,232,0.30)] transition-all duration-300 sm:scale-[1.04] flex flex-col relative">
        <!-- Badge -->
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span class="bg-[#34C759] text-white text-[11px] font-bold px-4 py-1.5 rounded-full whitespace-nowrap tracking-wide uppercase">Najpopularniejszy</span>
        </div>
        <div class="mb-6 mt-2">
          <h3 class="font-display text-[1.1rem] font-semibold text-white mb-1">Professional</h3>
          <p class="text-[13px] text-white/70">Średnie floty do 50 pojazdów</p>
        </div>
        <div class="mb-1">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-white">89</span>
          <span class="text-[15px] font-semibold text-white/70 ml-1">PLN</span>
        </div>
        <p class="text-[12px] text-white/60 mb-6">za pojazd / miesiąc &middot; min. 249 PLN/mies.</p>
        <ul class="space-y-3 text-[13.5px] text-white/90 mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Do 50 pojazdów i kierowców
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Raporty PDF + CSV/Excel
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Pełny eksport FK (EDI++)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Mapa w czasie rzeczywistym
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Dashboard zgodności
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Tryb offline + raporty zaawansowane
          </li>
        </ul>
        <a href="#trial" class="block text-center bg-white text-[#005CE8] font-bold text-[14px] px-5 py-3 rounded-full hover:bg-white/90 transition-all">
          Wypróbuj 14 dni
        </a>
      </div>

      <!-- Enterprise -->
      <div class="rounded-[20px] p-7 border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)] transition-all duration-300 hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] flex flex-col">
        <div class="mb-6">
          <h3 class="font-display text-[1.1rem] font-semibold text-[#1D1D1F] mb-1">Enterprise</h3>
          <p class="text-[13px] text-[#86868B]">Duże floty i biura rachunkowe</p>
        </div>
        <div class="mb-1">
          <span class="font-display text-[2.8rem] font-bold tracking-[-0.04em] text-[#1D1D1F]">149</span>
          <span class="text-[15px] font-semibold text-[#86868B] ml-1">PLN</span>
        </div>
        <p class="text-[12px] text-[#86868B] mb-6">za pojazd / miesiąc &middot; min. indywidualnie</p>
        <ul class="space-y-3 text-[13.5px] text-[#6E6E73] mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Bez limitu pojazdów i kierowców
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Multi-tenant (biura rachunkowe)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Dostęp API + white-label
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Comarch, Symfonia, KSeF
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Niestandardowe raporty
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Dedykowane wsparcie
          </li>
        </ul>
        <a href="#trial" class="block text-center bg-[#1D1D1F] text-white font-semibold text-[14px] px-5 py-3 rounded-full hover:bg-[#333] transition-all">
          Skontaktuj się
        </a>
      </div>

    </div>

    <!-- Annual discount note -->
    <p class="reveal text-center text-[13.5px] text-[#86868B] mt-10">
      Przy rozliczeniu rocznym <span class="font-semibold text-[#34C759]">&minus;15%</span> &mdash; Starter 50 PLN, Professional 76 PLN za pojazd/miesiąc.
    </p>
  </div>
</section>

<!-- ======================== FEATURE COMPARISON TABLE ======================== -->
<section class="py-24 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">

    <div class="reveal text-center mb-14">
      <p class="section-label text-[#005CE8]">Porównanie</p>
      <h2 class="section-title">Szczegółowe porównanie planów</h2>
      <p class="text-[#6E6E73] mt-4 max-w-[520px] mx-auto text-[15px]">Pełna matryca funkcji na podstawie dokumentacji technicznej BusiKM.</p>
    </div>

    <div class="reveal overflow-x-auto rounded-[20px] border border-black/[0.06] bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
      <table class="w-full text-[13.5px]">
        <thead>
          <tr class="border-b border-black/[0.06]">
            <th class="text-left px-5 py-4 font-semibold text-[#1D1D1F] min-w-[220px]">Funkcja</th>
            <th class="text-center px-4 py-4 font-semibold text-[#86868B]">Free</th>
            <th class="text-center px-4 py-4 font-semibold text-[#86868B]">Starter</th>
            <th class="text-center px-4 py-4 font-semibold text-[#005CE8] bg-[#005CE8]/[0.04]">Professional</th>
            <th class="text-center px-4 py-4 font-semibold text-[#86868B]">Enterprise</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-black/[0.04]">
          {featureGroups.map(group => (
            <>
              <tr class="bg-[#F5F5F7]">
