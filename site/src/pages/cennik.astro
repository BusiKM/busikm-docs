<style>
  .section-label {
    font-size: 12.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display); font-size: clamp(1.8rem,4vw,2.8rem);
