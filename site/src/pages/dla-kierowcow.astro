---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Dla kierowców — BusiKM"
  description="Aplikacja mobilna dla kierowców w transporcie międzynarodowym. GPS w tle, paragony OCR z DE/IT/FR/ES, alerty czasu pracy AETR zanim zatrzyma Cię BAG, tryb offline. iOS i Android."
>

<!-- ============ HERO ============ -->
<section class="relative overflow-hidden bg-white px-5 py-24 sm:py-32">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[#005CE8]/[0.04] blur-[120px]"></div>
  </div>
  <div class="relative max-w-[1120px] mx-auto">
    <div class="max-w-[720px]">
      <div class="hero-seq-1 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-6">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#005CE8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        <span class="text-[12.5px] font-medium text-[#005CE8]">Aplikacja dla kierowców · iOS 15+ · Android 10+</span>
      </div>

      <h1 class="hero-seq-2 font-display text-[clamp(2.2rem,5vw,3.5rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
        Twoja trasa po Europie —<br/>bez stresu z czasem pracy<br/>i papierem w reklamówce.
      </h1>

      <p class="hero-seq-3 text-[clamp(1rem,2vw,1.15rem)] leading-relaxed text-[#6E6E73] max-w-[600px] mb-9">
        Aplikacja BusiKM rejestruje trasę GPS w tle, robi OCR paragonów w DE/IT/FR/ES, alarmuje przed obowiązkową przerwą zanim wpadniesz na kontrolę BAG, ITD czy Gendarmerie, i działa bez sieci w tunelach i górach.
      </p>

      <div class="hero-seq-4 flex flex-wrap gap-3 mb-12">
        <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#005CE8] text-white text-[15px] font-semibold hover:bg-[#003FAD] transition-colors shadow-[0_1px_3px_rgba(0,92,232,0.4)]">
          Zobacz funkcje aplikacji
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#F5F5F7] transition-colors">
          Cennik (gratis dla pilotów)
        </a>
      </div>

      <div class="hero-seq-5 flex flex-wrap gap-8 sm:gap-12">
        {[
          { num: 'OCR', label: 'paragon → koszty\u00A0w 3 sek.' },
          { num: 'AETR', label: 'alerty zanim zatrzyma\u00A0Cię BAG' },
          { num: 'Offline', label: 'działa bez zasięgu' },
          { num: '6 języków', label: 'PL/EN/DE/IT/FR/ES' },
        ].map(s => (
          <div>
            <div class="font-display text-[1.5rem] font-bold tracking-[-0.03em] text-[#1D1D1F]">{s.num}</div>
            <div class="text-[12.5px] text-[#86868B] mt-0.5 max-w-[140px] leading-snug">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ============ AETR ALERT — DEEP DIVE ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-5">
        <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF9500] mb-4">Najważniejsza funkcja</p>
        <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.12] mb-5">
          Alerty czasu pracy AETR.<br/>Zanim zatrzyma Cię BAG.
        </h2>
        <p class="text-[14.5px] leading-relaxed text-[#6E6E73] mb-5">
          Pakiet mobilności UE i regulacja AETR mają proste reguły, ale dziesiątki przypadków granicznych. BusiKM monitoruje wszystkie limity i ostrzega zanim zaczniesz naruszać:
        </p>
        <ul class="space-y-2 text-[13.5px] text-[#6E6E73]">
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">4,5 h jazdy + 45 min przerwy</strong> — przerwa może być rozbita 15 + 30 min</li>
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">Dzienne 9 h jazdy</strong>, max 10 h dwa razy w tygodniu</li>
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">Dzienny odpoczynek 11 h</strong>, skrócony do 9 h max 3× w tygodniu</li>
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">Tygodniowy odpoczynek 45 h</strong>, skrócony do 24 h naprzemiennie</li>
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">Powrót do bazy</strong> co 4 tygodnie</li>
          <li class="flex items-start gap-2.5"><span class="text-[#FF9500] mt-1 shrink-0">●</span><strong class="text-[#1D1D1F]">Kabotaż 3 operacje w 7 dni</strong> od wjazdu po zleceniu międzynarodowym</li>
        </ul>
        <p class="text-[12.5px] text-[#86868B] mt-5 italic">
          Pierwsza zasada brzmi prosto. W praktyce kierowca pilnuje 6 limitów jednocześnie, w 5 strefach czasowych, w 3 walutach — po 12 godzinach jazdy. BusiKM robi to za Ciebie.
        </p>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-[24px] bg-[#0A0A0B] p-1.5 mx-auto max-w-[360px] sm:max-w-[420px]">
          <div class="rounded-[20px] bg-[#F5F5F7] overflow-hidden">
            <!-- Phone status bar -->
            <div class="bg-white px-4 py-2 flex items-center justify-between text-[10px] text-[#86868B] font-mono">
              <span>14:23</span>
              <div class="flex items-center gap-1">
                <span>●●●</span>
                <span>4G</span>
                <span>87%</span>
              </div>
            </div>

            <!-- Big alert -->
            <div class="bg-[#FF9500] text-white p-5">
              <div class="flex items-center gap-2 mb-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
                <span class="text-[10.5px] font-semibold uppercase tracking-[0.06em]">Obowiązkowa przerwa</span>
              </div>
              <p class="font-display text-[1.6rem] font-bold leading-tight mb-1">30 min do limitu</p>
              <p class="text-[12.5px] text-white/85 leading-snug mb-3">Po 4 h 30 min jazdy musisz zatrzymać się na min. 45 min.</p>
              <div class="bg-white/15 rounded-xl p-3">
                <p class="text-[10px] uppercase tracking-[0.06em] text-white/70 mb-1">Najbliższy parking AETR</p>
                <p class="text-[13px] font-semibold leading-snug">A4 Auchy-lès-Hesdin</p>
                <p class="text-[11px] text-white/80">12 km · ~9 min · darmowy · WC, restauracja</p>
              </div>
            </div>

            <!-- Stats list -->
            <div class="px-4 py-4 space-y-3">
              <div>
                <div class="flex items-center justify-between text-[11px] mb-1.5">
                  <span class="text-[#86868B]">Jazda dzisiaj</span>
                  <span class="font-mono font-semibold text-[#1D1D1F]">7 h 12 min / 9 h</span>
                </div>
                <div class="h-1.5 rounded-full bg-black/[0.06] overflow-hidden"><div class="h-full bg-[#34C759] rounded-full" style="width:80%"></div></div>
              </div>
              <div>
                <div class="flex items-center justify-between text-[11px] mb-1.5">
                  <span class="text-[#86868B]">Jazda w tym tygodniu</span>
                  <span class="font-mono font-semibold text-[#1D1D1F]">38 h 40 min / 56 h</span>
                </div>
                <div class="h-1.5 rounded-full bg-black/[0.06] overflow-hidden"><div class="h-full bg-[#34C759] rounded-full" style="width:69%"></div></div>
              </div>
              <div>
                <div class="flex items-center justify-between text-[11px] mb-1.5">
                  <span class="text-[#86868B]">Dni do powrotu do bazy</span>
                  <span class="font-mono font-semibold text-[#1D1D1F]">9 dni / 28 dni</span>
                </div>
                <div class="h-1.5 rounded-full bg-black/[0.06] overflow-hidden"><div class="h-full bg-[#005CE8] rounded-full" style="width:32%"></div></div>
              </div>
              <div>
                <div class="flex items-center justify-between text-[11px] mb-1.5">
                  <span class="text-[#86868B]">Operacje kabotażowe (od 12 maja)</span>
                  <span class="font-mono font-semibold text-[#1D1D1F]">2 z 3 w 7 dni</span>
                </div>
                <div class="h-1.5 rounded-full bg-black/[0.06] overflow-hidden"><div class="h-full bg-[#FF9500] rounded-full" style="width:67%"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ PARAGON OCR ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#34C759] mb-4">Koniec reklamówki z paragonami</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Pstryk telefonem.<br/>Aplikacja resztę zrobi sama.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-3 gap-5 max-w-[960px] mx-auto">
      {[
        {
          step: '01',
          country: 'Niemcy · Aral',
          title: 'Robisz zdjęcie paragonu',
          desc: 'Po zatankowaniu w stacji Aral. Aparat z nakładką ramki, jeden klik. Działa offline — wyśle się gdy będzie zasięg.',
          extracted: [
            { label: 'Sprzedawca', value: 'Aral Tankstelle GmbH' },
            { label: 'Data', value: '12.05.2026' },
            { label: 'Kwota brutto', value: '147,32 €' },
            { label: 'VAT 19%', value: '23,52 €' },
            { label: 'Liczba litrów', value: '94,5 l' },
          ],
        },
        {
          step: '02',
          country: 'Włochy · Telepass',
          title: 'OCR czyta po włosku',
          desc: 'Faktura Telepass (autostrada A4 Mediolan→Wenecja). Aplikacja rozumie „Pedaggio", „IVA", „Fattura n." — bez Twojej pracy.',
          extracted: [
            { label: 'Sprzedawca', value: 'Telepass S.p.A.' },
            { label: 'Data', value: '14.05.2026' },
            { label: 'Pedaggio (opłata)', value: '38,40 €' },
            { label: 'IVA 22%', value: '6,93 €' },
            { label: 'Trasa', value: 'Milano Est → Venezia' },
          ],
        },
        {
          step: '03',
          country: 'Wszystko gotowe',
          title: 'Trafia do biura',
          desc: 'Faktura przeliczona po kursie NBP tabela A z dnia poprzedzającego. Przypisana do zlecenia BKM-2842 i Twojego busa. Księgowa widzi to w panelu firmowym.',
          extracted: [
            { label: 'Status', value: 'Zaksięgowana' },
            { label: 'Zlecenie', value: 'BKM-2842' },
            { label: 'Pojazd', value: 'Crafter KR 67890' },
            { label: 'Kurs NBP', value: '4,2731 zł/€' },
            { label: 'Wartość PLN', value: '629,57 zł' },
          ],
        },
      ].map(s => (
        <div class="bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
          <div class="flex items-center justify-between mb-4">
            <span class="font-display text-[1.6rem] font-bold tracking-tight text-[#005CE8]/[0.15] leading-none">{s.step}</span>
            <span class="text-[10.5px] font-mono text-[#86868B] bg-[#F5F5F7] px-2 py-0.5 rounded">{s.country}</span>
          </div>
          <h3 class="font-display font-semibold text-[1rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{s.title}</h3>
          <p class="text-[13px] text-[#6E6E73] leading-relaxed mb-4">{s.desc}</p>
          <div class="bg-[#F5F5F7] rounded-2xl p-3.5">
            <p class="text-[10px] uppercase tracking-[0.06em] text-[#86868B] mb-2">Wyciągnięte z OCR</p>
            <div class="space-y-1.5">
              {s.extracted.map(e => (
                <div class="flex items-center justify-between text-[11.5px]">
                  <span class="text-[#86868B]">{e.label}</span>
                  <span class="font-mono font-semibold text-[#1D1D1F]">{e.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ FUNKCJE GŁÓWNE ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal max-w-[620px] mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Funkcje aplikacji</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Wszystko w jednej aplikacji.<br/>Po polsku. Z prostym interfejsem.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-5">
      {[
        {
          title: 'GPS w tle, bez papieru',
          desc: 'Klikasz „Rozpocznij trasę" przed wyjazdem. Zamykasz aplikację. Telefon w kieszeni. GPS rejestruje pozycję adaptacyjnie — częściej w ruchu, rzadziej na postoju. Bateria starcza na 12+ h.',
          color: '#005CE8',
          bullets: ['Background tracking iOS + Android', 'Adaptacyjny GPS — oszczędza baterię', 'Auto-pauza poniżej 10% baterii', 'Powiadomienie systemowe potwierdza śledzenie'],
          icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-width="1.6"/><circle cx="12" cy="10" r="3" stroke-width="1.6"/>`,
        },
        {
          title: 'OCR paragonów wielojęzyczny',
          desc: 'Aplikacja czyta faktury i paragony w 6 językach: PL, EN, DE, IT, FR, ES. Rozumie różne formaty: niemiecki „Rechnung", włoski „Fattura", francuski „Facture", hiszpański „Factura". Wyciąga kwoty, VAT, sprzedawcę, datę.',
          color: '#34C759',
          bullets: ['Auto-rozpoznanie waluty (EUR/CHF/GBP/CZK/HUF)', 'Przeliczenie po kursie NBP tabela A', 'Auto-przypisanie do aktywnego zlecenia i pojazdu', 'Zdjęcie zachowane jako dowód księgowy (RODO + 5 lat)'],
          icon: `<rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.6"/><path d="M7 8h10M7 12h6M7 16h8" stroke-width="1.6"/>`,
        },
        {
          title: 'Alerty AETR i pakiet mobilności',
          desc: 'Pełna kontrola: 4,5h jazdy + 45 min przerwy, 9h dziennego, 11h dziennego odpoczynku, 45h tygodniowego, powrót do bazy co 4 tyg., kabotaż 3/7. Alerty zanim naruszysz limity.',
          color: '#FF9500',
          bullets: ['Powiadomienie 30 min przed obowiązkową przerwą', 'Mapa najbliższych parkingów AETR (TIR-tauglich)', 'Licznik dni do powrotu do bazy', 'Historia naruszeń (jeśli były) z eksportem PDF'],
          icon: `<circle cx="12" cy="12" r="9" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke-width="1.6"/>`,
        },
        {
          title: 'Tryb offline — w tunelu, w górach',
          desc: 'Mont Blanc, Brennero, Korsyka, Pireneje, Karpaty — wszędzie tam, gdzie inne aplikacje przestają działać. BusiKM pracuje lokalnie i synchronizuje dane gdy zasięg wraca. Trasa nigdy nie pęka na pół.',
          color: '#8B5CF6',
          bullets: ['Pełna funkcjonalność bez sieci', 'Offline-first SQLite z replikacją', 'Kolejka uploadów (paragony, zdjęcia, GPS)', 'Brak utraty danych nawet przy braku zasięgu kilkadziesiąt godzin'],
          icon: `<line x1="1" y1="1" x2="23" y2="23" stroke-width="1.6"/><path d="M16.72 11.06A10.94 10.94 0 0119 12.55" stroke-width="1.6"/><path d="M5 12.55a10.94 10.94 0 015.17-2.39" stroke-width="1.6"/><path d="M10.71 5.05A16 16 0 0122.56 9" stroke-width="1.6"/><path d="M1.42 9a15.91 15.91 0 014.7-2.88" stroke-width="1.6"/><path d="M8.53 16.11a6 6 0 016.95 0" stroke-width="1.6"/>`,
        },
        {
          title: 'Pin lokalizacji do biura',
          desc: 'Awaria, kontrola, problem na granicy? Jedno tapnięcie i biuro dostaje powiadomienie z dokładną lokalizacją, godziną oraz statusem trasy. Mniej rozmów telefonicznych, mniej tłumaczenia po polsku gdzie dokładnie jesteś.',
          color: '#FF3B30',
          bullets: ['Push do dyspozytora z mapą i adresem', 'Najbliższy serwis ciężarowy / parking ITD na mapie', 'Rezerwa: telefon awaryjny do dyspozytora', 'Logi wszystkich zdarzeń (kto, kiedy, gdzie)'],
          icon: `<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke-width="1.6"/>`,
        },
        {
          title: 'Diety i ryczałty automatycznie',
          desc: 'Aplikacja wie kiedy przekroczyłeś granicę i ile godzin spędziłeś w danym kraju. Dieta zagraniczna liczona automatycznie wg rozporządzenia MRPiPS: 49 € DE, 50 € FR, 48 € IT, 50 € ES. Plus ryczałt noclegowy gdy brak rachunku.',
          color: '#0A84FF',
          bullets: ['Granice wykryte z GPS automatycznie', 'Stawki diet per kraj (rozporządzenie MRPiPS)', 'Ryczałt 25% diety gdy brak hotelu/rachunku', 'Eksport zestawienia delegacji do FK'],
          icon: `<rect x="3" y="6" width="18" height="13" rx="2" stroke-width="1.6"/><path d="M3 10h18M8 6V4m8 2V4" stroke-width="1.6"/>`,
        },
      ].map(f => (
        <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 group">
          <div class="w-11 h-11 rounded-[14px] mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style={`background: ${f.color}12;`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={f.color} stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}/>
          </div>
          <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{f.title}</h3>
          <p class="text-[14px] leading-relaxed text-[#6E6E73] mb-4">{f.desc}</p>
          <ul class="flex flex-col gap-2">
            {f.bullets.map(b => (
              <li class="flex items-start gap-2.5 text-[12.5px] text-[#6E6E73]">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="shrink-0 mt-0.5"><path d="M2 8l4 4 8-8" stroke={f.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ DOKUMENTY KIEROWCY ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[900px] mx-auto">
    <div class="reveal text-center mb-12">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Twoje dokumenty</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Cztery dokumenty których ITD pyta na każdej kontroli.<br/>Wszystkie w jednym miejscu.
      </h2>
    </div>

    <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-4">
      {[
        { name: 'Prawo jazdy', cat: 'kategoria B/C/C+E', alert: 'Alert 30 dni przed', color: '#005CE8' },
