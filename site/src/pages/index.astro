---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="BusiKM — Elektroniczna kilometrówka GPS dla biur rachunkowych i flot"
  description="Automatyzuj kilometrówkę klientów biura rachunkowego. GPS + AI + eksport Insert GT, Comarch, Symfonia. Klienci biura korzystają gratis."
>

<!-- ======================== HERO ======================== -->
<section class="relative min-h-[92vh] flex flex-col items-center justify-center overflow-hidden bg-white px-5">
  <div class="absolute inset-0 pointer-events-none">
    <div class="hero-glow absolute top-[-10%] left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full bg-[#005CE8]/[0.04] blur-[140px]"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-[#34C759]/[0.03] blur-[100px]"></div>
  </div>

  <div class="relative z-10 text-center max-w-[820px] mx-auto pt-16 pb-10">
    <div class="hero-seq-1 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#8B5CF6]/15 bg-[#8B5CF6]/[0.04] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-[#34C759] animate-pulse"></span>
      <span class="text-[12.5px] font-medium text-[#8B5CF6] tracking-[0.01em]">Dla biur rachunkowych · Klienci korzystają gratis</span>
    </div>

    <h1 class="hero-seq-2 font-display text-[clamp(2.4rem,6vw,4.2rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
      Automatyzuj kilometrówkę<br/>swoich&nbsp;klientów.
    </h1>

    <p class="hero-seq-3 text-[clamp(1rem,2vw,1.25rem)] leading-relaxed text-[#6E6E73] max-w-[580px] mx-auto mb-10">
      Kierowcy klientów jeżdżą — BusiKM rejestruje trasy GPS. Eksport do Insert&nbsp;GT, Comarch, Symfonia jednym kliknięciem. Twoi klienci płacą&nbsp;0&nbsp;zł.
    </p>

    <div class="hero-seq-4 flex flex-col sm:flex-row items-center justify-center gap-3 mb-14">
      <a href="https://calendly.com/busikm/30min" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#005CE8] text-white text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#003FAD] transition-all duration-200" style="box-shadow:0 1px 3px rgba(0,92,232,0.4)">
        3 miesiące gratis
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#F5F5F7] transition-all duration-200">
        Zobacz cennik
      </a>
      <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#F5F5F7] transition-all duration-200">
        Funkcje
      </a>
    </div>

    <!-- Value props -->
    <div class="hero-seq-5 flex flex-wrap justify-center gap-8 sm:gap-14 text-center">
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#005CE8]">76 zł</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">oszczędzasz na każdym pojeździe</div>
      </div>
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#34C759]">0 zł</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">dla firm Twoich klientów</div>
      </div>
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#1D1D1F]">1 klik</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">eksport do Insert GT / Comarch</div>
      </div>
    </div>
  </div>

  <!-- Hero dashboard -->
  <div class="hero-seq-5 relative w-full max-w-[860px] mx-auto">
    <div class="relative rounded-[20px] bg-[#F5F5F7] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
      <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <div class="ml-4 flex-1 max-w-[260px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B]">app.busikm.pl/dashboard</div>
      </div>
      <div class="p-6 sm:p-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { label: 'Przejechane km (mies.)', value: '4 820', change: '+12%', color: '#005CE8' },
          { label: 'Trasy zatwierdzone', value: '143 / 147', change: '97% auto', color: '#34C759' },
          { label: 'Raport MF', value: 'Gotowy', change: 'Pobierz PDF', color: '#FF9500' },
        ].map(c => (
          <div class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <p class="text-[11.5px] text-[#86868B] mb-2">{c.label}</p>
            <p class="font-display text-[1.5rem] font-bold tracking-[-0.03em] text-[#1D1D1F]">{c.value}</p>
            <p class="text-[11.5px] mt-1" style={`color:${c.color}`}>{c.change}</p>
          </div>
        ))}
        <!-- Map - hidden on very small screens, simplified -->
        <div class="sm:col-span-3 bg-white rounded-2xl overflow-hidden shadow-[0_1px_4px_rgba(0,0,0,0.06)] hidden sm:block" style="height:200px">
          <svg viewBox="0 0 840 200" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
            <defs>
              <pattern id="mg" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="#F0F0F2" stroke-width="0.8"/></pattern>
            </defs>
            <rect width="840" height="200" fill="#FAFAFA"/><rect width="840" height="200" fill="url(#mg)"/>
            <path d="M 0 130 C 100 125 180 110 280 100 C 380 90 500 95 600 85 C 700 75 780 60 840 55" stroke="#E2E2E7" stroke-width="10" fill="none" stroke-linecap="round"/>
            <path d="M 0 80 C 120 75 200 60 320 50 C 440 40 560 55 680 45 C 760 38 800 30 840 25" stroke="#E2E2E7" stroke-width="5" fill="none" stroke-linecap="round"/>
            <path d="M 120 0 C 130 50 160 100 180 200" stroke="#E2E2E7" stroke-width="5" fill="none"/><path d="M 400 0 C 420 60 440 120 480 200" stroke="#E2E2E7" stroke-width="5" fill="none"/><path d="M 680 0 C 690 50 710 110 720 200" stroke="#E2E2E7" stroke-width="5" fill="none"/>
            <!-- Route 1: blue — realistic city driving with turns, intersections, direction changes -->
            <path id="hr1" d="M 70 165 C 80 160 95 158 110 145 C 125 132 130 118 150 108 C 170 98 195 102 220 95 C 245 88 255 72 280 65 C 305 58 340 62 380 55 C 420 48 440 38 470 42 C 500 46 520 55 550 48 C 580 41 610 32 650 35 C 680 38 710 40 745 38" stroke="#005CE8" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="1200" stroke-dashoffset="1200"><animate attributeName="stroke-dashoffset" from="1200" to="0" dur="3s" begin="0.3s" fill="freeze" calcMode="spline" keySplines="0.16 1 0.3 1"/></path>
            <!-- Route 1 glow -->
            <path d="M 70 165 C 80 160 95 158 110 145 C 125 132 130 118 150 108 C 170 98 195 102 220 95 C 245 88 255 72 280 65 C 305 58 340 62 380 55 C 420 48 440 38 470 42 C 500 46 520 55 550 48 C 580 41 610 32 650 35 C 680 38 710 40 745 38" stroke="#005CE8" stroke-width="10" fill="none" stroke-linecap="round" opacity="0.07" stroke-dasharray="1200" stroke-dashoffset="1200"><animate attributeName="stroke-dashoffset" from="1200" to="0" dur="3s" begin="0.3s" fill="freeze" calcMode="spline" keySplines="0.16 1 0.3 1"/></path>

            <!-- Route 2: green — shorter delivery route with sharp turns -->
            <path id="hr2" d="M 460 175 C 445 165 420 148 400 130 C 385 115 375 95 355 78 C 340 65 310 52 285 40 C 265 30 240 22 220 18" stroke="#34C759" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="500" stroke-dashoffset="500" opacity="0.8"><animate attributeName="stroke-dashoffset" from="500" to="0" dur="2.2s" begin="1.2s" fill="freeze" calcMode="spline" keySplines="0.16 1 0.3 1"/></path>
            <path d="M 460 175 C 445 165 420 148 400 130 C 385 115 375 95 355 78 C 340 65 310 52 285 40 C 265 30 240 22 220 18" stroke="#34C759" stroke-width="8" fill="none" stroke-linecap="round" opacity="0.05" stroke-dasharray="500" stroke-dashoffset="500"><animate attributeName="stroke-dashoffset" from="500" to="0" dur="2.2s" begin="1.2s" fill="freeze" calcMode="spline" keySplines="0.16 1 0.3 1"/></path>

            <!-- Start point: blue with pulse ring -->
            <circle cx="70" cy="165" r="12" fill="#005CE8" opacity="0.08"><animate attributeName="r" values="10;18;10" dur="3s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.1;0;0.1" dur="3s" repeatCount="indefinite"/></circle>
            <circle cx="70" cy="165" r="7" fill="white" stroke="#005CE8" stroke-width="2.5"/><circle cx="70" cy="165" r="3" fill="#005CE8"/>

            <!-- Moving vehicle dot on route 1 -->
            <g><circle r="5" fill="#005CE8" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.3s" begin="3.3s" fill="freeze"/><animateMotion dur="8s" repeatCount="indefinite" begin="3.3s"><mpath href="#hr1"/></animateMotion></circle>
            <circle r="12" fill="#005CE8" opacity="0"><animate attributeName="opacity" values="0;0.08;0" dur="1.5s" begin="3.3s" repeatCount="indefinite"/><animateMotion dur="8s" repeatCount="indefinite" begin="3.3s"><mpath href="#hr1"/></animateMotion></circle></g>

            <!-- Destination 1: orange with pulse -->
            <circle cx="745" cy="38" r="12" fill="#FF9500" opacity="0.08"><animate attributeName="r" values="10;16;10" dur="3s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.1;0;0.1" dur="3s" repeatCount="indefinite"/></circle>
            <circle cx="745" cy="38" r="7" fill="white" stroke="#FF9500" stroke-width="2.5"/><circle cx="745" cy="38" r="3" fill="#FF9500"/>

            <!-- Green route endpoints -->
            <circle cx="460" cy="175" r="6" fill="white" stroke="#34C759" stroke-width="2"/><circle cx="460" cy="175" r="2.5" fill="#34C759"/>
            <circle cx="220" cy="18" r="6" fill="white" stroke="#34C759" stroke-width="2"/><circle cx="220" cy="18" r="2.5" fill="#34C759"/>

            <!-- Info card — positioned between routes, not overlapping -->
            <g opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.6s" begin="2.2s" fill="freeze"/>
              <rect x="530" y="68" width="130" height="42" rx="12" fill="white" filter="drop-shadow(0 3px 12px rgba(0,0,0,0.12))"/>
              <text x="595" y="85" text-anchor="middle" fill="#1D1D1F" font-size="11" font-family="system-ui" font-weight="700">14,2 km</text>
              <text x="595" y="100" text-anchor="middle" fill="#86868B" font-size="8.5" font-family="system-ui">00:18:34 · w trasie</text>
            </g>

            <!-- Labels with fade-in -->
            <g opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.4s" begin="0.5s" fill="freeze"/><rect x="38" y="177" width="64" height="20" rx="7" fill="#005CE8"/><text x="70" y="191" text-anchor="middle" fill="white" font-size="9.5" font-family="system-ui" font-weight="600">Baza</text></g>
            <g opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.4s" begin="3s" fill="freeze"/><rect x="713" y="48" width="64" height="20" rx="7" fill="#FF9500"/><text x="745" y="62" text-anchor="middle" fill="white" font-size="9.5" font-family="system-ui" font-weight="600">Klient</text></g>
            <g opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.4s" begin="1.5s" fill="freeze"/><rect x="428" y="180" width="64" height="18" rx="6" fill="#34C759"/><text x="460" y="193" text-anchor="middle" fill="white" font-size="8.5" font-family="system-ui" font-weight="600">Magazyn</text></g>
          </svg>
        </div>
        <!-- Mobile: simple stat instead of map -->
        <div class="sm:hidden bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgba(0,0,0,0.06)] text-center">
          <p class="text-[11.5px] text-[#86868B] mb-1">Aktywne pojazdy w trasie</p>
          <p class="font-display text-[2rem] font-bold text-[#005CE8]">3</p>
          <p class="text-[11.5px] text-[#34C759] mt-1">GPS aktywny</p>
        </div>
      </div>
    </div>

    <!-- Floating badges -->
    <div class="absolute -top-4 -right-2 sm:right-4 bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.12)] border border-black/[0.05] px-4 py-3 flex items-center gap-3 animate-float">
      <div class="w-8 h-8 rounded-full bg-[#34C759]/12 flex items-center justify-center shrink-0">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#34C759" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div>
        <p class="text-[11px] font-semibold text-[#1D1D1F]">Raport zatwierdzony</p>
        <p class="text-[10.5px] text-[#86868B]">Właśnie teraz</p>
      </div>
    </div>
    <div class="absolute -bottom-3 -left-2 sm:left-4 bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.12)] border border-black/[0.05] px-4 py-3 flex items-center gap-3 animate-float" style="animation-delay: 1.5s;">
      <div class="w-8 h-8 rounded-full bg-[#005CE8]/12 flex items-center justify-center shrink-0">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" fill="#005CE8"/><circle cx="8" cy="8" r="6" stroke="#005CE8" stroke-width="1.5" fill="none"/></svg>
      </div>
      <div>
        <p class="text-[11px] font-semibold text-[#1D1D1F]">GPS aktywny</p>
        <p class="text-[10.5px] text-[#86868B]">3 pojazdy w trasie</p>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30 animate-bounce-slow">
    <svg width="20" height="28" viewBox="0 0 20 28" fill="none"><rect x="6" y="1" width="8" height="14" rx="4" stroke="#86868B" stroke-width="1.2"/><circle cx="10" cy="7" r="1.5" fill="#86868B"><animate attributeName="cy" values="6;11;6" dur="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="1;0.2;1" dur="2s" repeatCount="indefinite"/></circle></svg>
  </div>
</section>

<!-- ======================== PROBLEM ======================== -->
<section class="py-24 sm:py-32 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal max-w-[620px] mb-16">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF3B30] mb-4">Problem biura rachunkowego</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Ręczna kilometrówka zabiera czas Twoim&nbsp;księgowym.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-3 gap-5">
      {[
        { title: '2h na każdy pojazd', desc: 'Weryfikacja dokumentów, wprowadzenie 30 wpisów, faktury paliwowe, kalkulacja km × stawka, weryfikacja końcowa. Pomnóż × liczbę pojazdów klientów.', accent: '#FF9500', icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>` },
        { title: '76 zł / pojazd / mies.', desc: 'Tyle kosztuje Cię ręczne prowadzenie ewidencji jednego pojazdu (2h × 38 zł/h kosztu pracodawcy). Przy 30 pojazdach to 2 280 zł miesięcznie.', accent: '#FF3B30', icon: `<path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>` },
        { title: 'Błędy = ryzyko klienta', desc: 'Ręcznie wpisywane km i cele tras → błędy w ewidencji → US kwestionuje 100% VAT klienta. To Twoja odpowiedzialność jako biura.', accent: '#005CE8', icon: `<path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>` },
      ].map(item => (
        <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 group">
          <div class="w-11 h-11 rounded-[14px] mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style={`background:${item.accent}12`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={item.accent} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}/>
          </div>
          <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{item.title}</h3>
          <p class="text-[14px] leading-relaxed text-[#6E6E73]">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal mt-8 text-center">
      <p class="text-[14px] text-[#86868B]">BusiKM eliminuje tę pracę — <span class="font-semibold text-[#1D1D1F]">kierowcy jeżdżą, dane trafiają do Twojego FK automatycznie</span></p>
    </div>
  </div>
</section>

<!-- ======================== KALKULATOR OSZCZĘDNOŚCI BR ======================== -->
<section class="py-24 sm:py-32 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center max-w-[720px] mx-auto mb-16">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Kalkulator oszczędności</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15] mb-4">
        Ile zaoszczędzi Twoje biuro z&nbsp;BusiKM?
      </h2>
      <p class="text-[16px] text-[#6E6E73] leading-relaxed">
        Każdy pojazd klienta to 2h pracy Twojej księgowej (76 zł). BusiKM automatyzuje ten proces — eksport do FK jednym kliknięciem. Klienci biura korzystają z BusiKM gratis.
      </p>
    </div>

    <!-- BR Calculator -->
    <div class="reveal bg-white rounded-[20px] p-7 sm:p-10 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-black/[0.06] max-w-[900px] mx-auto mb-12">
      <div class="max-w-[500px] mx-auto mb-8">
        <div class="flex justify-between items-baseline mb-3">
          <label class="text-[14px] font-semibold text-[#1D1D1F]">Ile pojazdów obsługujesz u klientów?</label>
          <span id="roi-vehicles-val" class="font-display text-[1.1rem] font-bold text-[#005CE8]">30</span>
        </div>
        <input type="range" id="roi-vehicles" min="5" max="200" value="30" step="5" class="w-full h-1.5 bg-[#E8E8ED] rounded-full appearance-none cursor-pointer accent-[#005CE8] [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-5 [&::-webkit-slider-thumb]:h-5 [&::-webkit-slider-thumb]:bg-[#005CE8] [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:shadow-[0_2px_6px_rgba(0,92,232,0.3)] [&::-moz-range-thumb]:w-5 [&::-moz-range-thumb]:h-5 [&::-moz-range-thumb]:bg-[#005CE8] [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0" />
        <div class="flex justify-between text-[11px] text-[#86868B] mt-1"><span>5</span><span>200</span></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center mb-6">
        <div class="p-4 rounded-2xl bg-[#F5F5F7]"><div class="text-[12px] text-[#86868B] mb-1">Koszt BusiKM / mies.</div><div id="roi-cost" class="font-display text-[1.2rem] font-bold text-[#1D1D1F]">—</div></div>
        <div class="p-4 rounded-2xl bg-[#FF3B30]/[0.04]"><div class="text-[12px] text-[#86868B] mb-1">Koszt ręczny / mies.</div><div id="roi-manual" class="font-display text-[1.2rem] font-bold text-[#FF3B30]">—</div></div>
        <div class="p-4 rounded-2xl bg-[#34C759]/[0.06]"><div class="text-[12px] text-[#86868B] mb-1">Oszczędność / mies.</div><div id="roi-monthly" class="font-display text-[1.2rem] font-bold text-[#34C759]">—</div></div>
        <div class="p-4 rounded-2xl bg-[#005CE8]/[0.04]"><div class="text-[12px] text-[#86868B] mb-1">Oszczędność / rok</div><div id="roi-yearly" class="font-display text-[1.4rem] font-bold text-[#005CE8]">—</div></div>
      </div>
      <div class="text-center p-5 rounded-2xl bg-[#005CE8]/[0.04] border border-[#005CE8]/15">
        <div class="text-[13px] text-[#6E6E73] mb-1">Twoja roczna oszczędność</div>
        <div id="roi-yearly-big" class="font-display text-[2.5rem] font-bold tracking-[-0.03em] text-[#005CE8]">—</div>
        <div id="roi-equiv" class="text-[12px] text-[#6E6E73] mt-1">—</div>
      </div>
    </div>

    <!-- Why it works -->
    <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-[900px] mx-auto mb-12">
      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
