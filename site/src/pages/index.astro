<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  .animate-float { animation: float 4s ease-in-out infinite; }

  @keyframes bounce-slow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  .animate-bounce-slow { animation: bounce-slow 2.5s ease-in-out infinite; }
</style>

<script>
  // Scroll reveal
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));

  // Staggered FK names
  const fkStagger = document.querySelector('.fk-stagger');
  if (fkStagger) {
    const fkIO = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const children = fkStagger.children;
          for (let i = 0; i < children.length; i++) {
            const child = children[i] as HTMLElement;
            child.style.opacity = '0';
            child.style.transform = 'translateY(10px)';
            child.style.transition = `opacity 0.5s ease ${i * 100}ms, transform 0.5s ease ${i * 100}ms`;
            requestAnimationFrame(() => {
              child.style.opacity = '1';
              child.style.transform = 'none';
            });
          }
          fkIO.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    fkIO.observe(fkStagger);
  }

  // BR ROI Calculator
  const roiVehicles = document.getElementById('roi-vehicles') as HTMLInputElement;

  function fmt(n: number): string {
    return Math.round(n).toLocaleString('pl-PL').replace(/\u00a0/g, ' ') + ' zł';
  }

  function calcBrCost(v: number): number {
    if (v <= 50) return v * 49;
    if (v <= 150) return 50 * 49 + (v - 50) * 39;
    return 50 * 49 + 100 * 39 + (v - 150) * 29;
  }

  function calcROI() {
    const vehicles = parseInt(roiVehicles.value);
    (document.getElementById('roi-vehicles-val') as HTMLElement).textContent = String(vehicles);

    const manualCost = vehicles * 76;
    const busikm = calcBrCost(vehicles);
    const monthly = manualCost - busikm;
    const yearly = monthly * 12;

    (document.getElementById('roi-cost') as HTMLElement).textContent = fmt(busikm);
    (document.getElementById('roi-manual') as HTMLElement).textContent = fmt(manualCost);
    (document.getElementById('roi-monthly') as HTMLElement).textContent = fmt(monthly);
    (document.getElementById('roi-yearly') as HTMLElement).textContent = fmt(yearly);
    (document.getElementById('roi-yearly-big') as HTMLElement).textContent = '+' + fmt(yearly);

    const hoursPerMonth = vehicles * 2;
    (document.getElementById('roi-equiv') as HTMLElement).textContent = 'To ' + hoursPerMonth + 'h pracy księgowej mniej / miesiąc';
  }

  roiVehicles.addEventListener('input', calcROI);
  calcROI();

  // FK tabs
  document.querySelectorAll('.fk-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.fkTab;
      document.querySelectorAll('.fk-tab').forEach(b => {
        (b as HTMLElement).className = 'fk-tab flex-1 py-2 px-3 rounded-lg text-[12.5px] font-semibold transition-all text-[#6E6E73] hover:text-[#1D1D1F]';
      });
      (btn as HTMLElement).className = 'fk-tab flex-1 py-2 px-3 rounded-lg text-[12.5px] font-semibold transition-all bg-[#005CE8] text-white';
      document.querySelectorAll('.fk-content').forEach(c => c.classList.add('hidden'));
      document.getElementById('fk-' + tab)?.classList.remove('hidden');
    });
  });
</script>
