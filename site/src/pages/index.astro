        var toCoord = r.coords[n - 1];
        var driverCoord = r.coords[driverIdx];

        // 1) Soft halo behind the route — adds depth, stronger than before
        L.polyline(r.coords, {
          color: r.color, weight: 11, opacity: 0.12, lineCap: 'round', lineJoin: 'round',
        }).addTo(map);

        // 2) Completed segment — bold and saturated, easy to follow
        L.polyline(r.coords.slice(0, driverIdx + 1), {
          color: r.color, weight: 4, opacity: 1, lineCap: 'round', lineJoin: 'round',
        }).addTo(map);

        // 3) Remaining segment — dashed, dimmed but clearly visible
        L.polyline(r.coords.slice(driverIdx), {
          color: r.color, weight: 3, opacity: 0.55, dashArray: '6 7', lineCap: 'round', lineJoin: 'round',
        }).addTo(map);

        // 4) Origin endpoint — large filled dot with double white ring
        L.marker(fromCoord, {
          icon: L.divIcon({
            className: '',
            html: '<div class="route-endpoint route-endpoint-origin" style="background:' + r.color + ';"></div>',
            iconSize: [16, 16], iconAnchor: [8, 8],
          }),
          interactive: false,
          zIndexOffset: 500,
        }).addTo(map);

        // 5) Destination endpoint — checkered/ring marker, colored
        L.marker(toCoord, {
          icon: L.divIcon({
            className: '',
            html:
              '<div class="route-endpoint route-endpoint-dest" style="border-color:' + r.color + ';">' +
                '<span style="background:' + r.color + ';"></span>' +
              '</div>',
            iconSize: [18, 18], iconAnchor: [9, 9],
          }),
          interactive: false,
          zIndexOffset: 500,
        }).addTo(map);

        // 6) City labels — placed AWAY from route line so they never cover it
        var fromPlace = cityPlacements[idx].from;
        var toPlace = cityPlacements[idx].to;

        L.marker(fromCoord, {
          icon: L.divIcon({
            className: '',
            html: '<div class="city-label" style="transform: translate(' +
              (fromPlace.dx >= 0 ? fromPlace.dx + 'px' : 'calc(-100% + ' + fromPlace.dx + 'px)') +
              ', ' + fromPlace.dy + 'px);">' + r.fromLabel + '</div>',
            iconSize: [0, 0], iconAnchor: [0, 0],
          }),
          interactive: false,
          zIndexOffset: 600,
        }).addTo(map);

        L.marker(toCoord, {
          icon: L.divIcon({
            className: '',
            html: '<div class="city-label" style="transform: translate(' +
              (toPlace.dx >= 0 ? toPlace.dx + 'px' : 'calc(-100% + ' + toPlace.dx + 'px)') +
              ', ' + toPlace.dy + 'px);">' + r.toLabel + '</div>',
            iconSize: [0, 0], iconAnchor: [0, 0],
          }),
          interactive: false,
          zIndexOffset: 600,
        }).addTo(map);

        // 7) Driver — bus icon directly on route + pill (plate) offset to the side
        var busIconHtml =
          '<div class="bus-icon-wrap">' +
            '<span class="bus-icon-pulse" style="background:' + r.color + ';"></span>' +
            '<div class="bus-icon" style="background:' + r.color + ';">' +
              '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<path d="M3 6h15a3 3 0 013 3v8h-2"/>' +
                '<path d="M3 6v11h2"/>' +
                '<path d="M9 17h6"/>' +
                '<circle cx="7" cy="17.5" r="2"/>' +
                '<circle cx="17" cy="17.5" r="2"/>' +
                '<path d="M3 12h15"/>' +
                '<path d="M7 6V4"/>' +
              '</svg>' +
            '</div>' +
          '</div>';

        L.marker(driverCoord, {
          icon: L.divIcon({
            className: '',
            html: busIconHtml,
            iconSize: [28, 28], iconAnchor: [14, 14],
          }),
          interactive: false,
          zIndexOffset: 1000,
        }).addTo(map);

        // 8) Plate pill — separate marker, offset away from route
        var pillPlace = pillPlacements[idx];
        var pillHtml =
          '<div class="bus-pill" style="border-color:' + r.color + '; transform: translate(' +
          (pillPlace.dx >= 0 ? pillPlace.dx + 'px' : 'calc(-100% + ' + pillPlace.dx + 'px)') +
          ', ' + pillPlace.dy + 'px);">' +
            '<span class="bus-pill-dot" style="background:' + r.color + ';"></span>' +
            '<span class="bus-pill-text">' +
              '<span class="bus-pill-order">' + r.orderId + '</span>' +
              '<span class="bus-pill-plate">' + r.plate + '</span>' +
            '</span>' +
          '</div>';

        L.marker(driverCoord, {
          icon: L.divIcon({
            className: '',
            html: pillHtml,
            iconSize: [0, 0], iconAnchor: [0, 0],
          }),
          interactive: false,
          zIndexOffset: 1100,
        }).addTo(map);

        r.coords.forEach(function(c) { allBounds.extend(c); });
      });

      // Fit map to all routes — responsive padding so labels never get clipped.
      function refit() {
        var w = el.clientWidth || 600;
        var padTop    = w < 500 ? 60 : 90;
        var padBottom = w < 500 ? 40 : 70;
        var padSide   = w < 500 ? 50 : 110;
        map.invalidateSize();
        map.fitBounds(allBounds, {
          paddingTopLeft: [padSide, padTop],
          paddingBottomRight: [padSide, padBottom],
          maxZoom: w < 500 ? 5 : 6,
          animate: false,
        });
      }
      refit();
      var resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(refit, 150);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroMap);
    } else {
      initHeroMap();
    }
  </script>
</section>

