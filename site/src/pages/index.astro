---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="BusiKM — Kontrola pracy kierowców i rentowność zleceń dla firm transportowych"
  description="Aplikacja dla firm transportowych krajowych i międzynarodowych. GPS w czasie rzeczywistym, ewidencja czasu pracy kierowcy, dokumenty floty, alerty tachograf G2V2, eksport do FK. Gotowa na obowiązek tachografu od 2 lipca 2026."
>

<!-- ======================== HERO ======================== -->
<section class="relative min-h-[92vh] flex flex-col items-center justify-center overflow-hidden bg-white px-5">
  <div class="absolute inset-0 pointer-events-none">
    <div class="hero-glow absolute top-[-10%] left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full bg-[#005CE8]/[0.04] blur-[140px]"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-[#34C759]/[0.03] blur-[100px]"></div>
  </div>

  <div class="relative z-10 text-center max-w-[860px] mx-auto pt-16 pb-10">
    <div class="hero-seq-1 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#FF9500]/20 bg-[#FF9500]/[0.06] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-[#FF9500] animate-pulse"></span>
      <span class="text-[12.5px] font-medium text-[#1D1D1F] tracking-[0.01em]">Tachograf G2V2 od 2 lipca 2026 &middot; Pakiet mobilności UE &middot; BusiKM jest gotowy</span>
    </div>

    <h1 class="hero-seq-2 font-display text-[clamp(2.4rem,6vw,4.2rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
      Każdy kilometr Twojej floty<br/>pod&nbsp;<span class="bg-gradient-to-r from-[#005CE8] to-[#3380FF] bg-clip-text text-transparent">pełną kontrolą</span>.
    </h1>

    <p class="hero-seq-3 text-[clamp(1rem,2vw,1.25rem)] leading-relaxed text-[#6E6E73] max-w-[640px] mx-auto mb-10">
      BusiKM łączy GPS w czasie rzeczywistym, ewidencję pracy kierowców, dokumenty floty i rozliczanie kosztów zleceń &mdash; w jednym narzędziu zaprojektowanym dla firm transportowych krajowych i międzynarodowych.
    </p>

    <div class="hero-seq-4 flex flex-col sm:flex-row items-center justify-center gap-3 mb-14">
      <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#005CE8] text-white text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#003FAD] transition-all duration-200" style="box-shadow:0 1px 3px rgba(0,92,232,0.4)">
        Dołącz do pilotażu
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#F5F5F7] transition-all duration-200">
        Funkcje produktu
      </a>
      <a href="/roadmapa" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold tracking-[-0.01em] hover:bg-[#F5F5F7] transition-all duration-200">
        Roadmapa
      </a>
    </div>

    <!-- Value props -->
    <div class="hero-seq-5 flex flex-wrap justify-center gap-8 sm:gap-12 text-center">
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#005CE8]">GPS</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">w czasie rzeczywistym</div>
      </div>
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#34C759]">7</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">typów dokumentów<br/>z alertami</div>
      </div>
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#FF9500]">G2V2</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">tachograf<br/>od 2 lipca 2026</div>
      </div>
      <div>
        <div class="font-display text-[1.75rem] font-bold tracking-[-0.03em] text-[#1D1D1F]">3</div>
        <div class="text-[12.5px] text-[#86868B] mt-0.5">integracje FK<br/>jednym kliknięciem</div>
      </div>
    </div>
  </div>

  <!-- Hero — Owner dashboard mockup -->
  <div class="hero-seq-5 relative w-full max-w-[920px] mx-auto">
    <div class="relative rounded-[20px] bg-[#F5F5F7] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
      <!-- Browser chrome -->
      <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <div class="ml-4 flex-1 max-w-[260px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B]">app.busikm.pl/dashboard</div>
        <div class="flex items-center gap-1.5 ml-auto">
          <span class="w-2 h-2 rounded-full bg-[#34C759] animate-pulse"></span>
          <span class="text-[11px] text-[#34C759] font-semibold hidden sm:inline">5 pojazdów w trasie</span>
        </div>
      </div>

      <!-- Stat strip -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 p-4 sm:p-5 bg-white border-b border-black/[0.04]">
        <div>
          <p class="text-[10.5px] font-semibold uppercase tracking-[0.06em] text-[#86868B]">Aktywne trasy</p>
          <p class="font-display text-[1.4rem] font-bold text-[#1D1D1F]">5 / 12</p>
        </div>
        <div>
          <p class="text-[10.5px] font-semibold uppercase tracking-[0.06em] text-[#86868B]">Łączny przebieg</p>
          <p class="font-display text-[1.4rem] font-bold text-[#1D1D1F]">1 247 km</p>
        </div>
        <div>
          <p class="text-[10.5px] font-semibold uppercase tracking-[0.06em] text-[#86868B]">Koszty (mies.)</p>
          <p class="font-display text-[1.4rem] font-bold text-[#1D1D1F]">42 380 zł</p>
        </div>
        <div>
          <p class="text-[10.5px] font-semibold uppercase tracking-[0.06em] text-[#FF3B30]">Alerty</p>
          <p class="font-display text-[1.4rem] font-bold text-[#FF3B30]">3</p>
        </div>
      </div>

      <!-- Map with active routes -->
      <div class="hidden sm:block" style="height:240px">
        <svg viewBox="0 0 920 240" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
          <defs><filter id="hmBlur"><feGaussianBlur stdDeviation="12"/></filter></defs>
          <rect width="920" height="240" fill="#E8ECE5"/>

          <!-- Terrain -->
          <ellipse cx="320" cy="120" rx="140" ry="65" fill="#D5E8D0" opacity="0.3" filter="url(#hmBlur)"/>
          <ellipse cx="700" cy="150" rx="100" ry="50" fill="#D5E8D0" opacity="0.2" filter="url(#hmBlur)"/>

          <!-- Roads (highways) -->
          <path d="M 60 130 Q 220 80, 380 110 T 720 90 L 880 70" stroke="#FFFFFF" stroke-width="6" fill="none" opacity="0.7"/>
          <path d="M 60 180 Q 250 200, 460 170 T 880 150" stroke="#FFFFFF" stroke-width="6" fill="none" opacity="0.7"/>
          <path d="M 200 40 Q 240 100, 280 160 T 360 220" stroke="#FFFFFF" stroke-width="4" fill="none" opacity="0.5"/>

          <!-- Active route 1 (Polska → Niemcy) -->
          <path d="M 100 170 Q 200 130, 320 110 T 540 100" stroke="#005CE8" stroke-width="3" fill="none" stroke-dasharray="0"/>
          <circle cx="540" cy="100" r="8" fill="#005CE8"/>
          <circle cx="540" cy="100" r="14" fill="#005CE8" opacity="0.25"><animate attributeName="r" values="8;18;8" dur="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.4;0;0.4" dur="2s" repeatCount="indefinite"/></circle>
          <text x="556" y="96" font-family="ui-sans-serif,system-ui" font-size="10" font-weight="600" fill="#1D1D1F">DAF · DK 12345</text>
          <text x="556" y="108" font-family="ui-monospace,monospace" font-size="9" fill="#34C759">w trasie · 4h 12min</text>

          <!-- Active route 2 (Polska wewnętrzna) -->
          <path d="M 80 70 L 220 130 L 380 165" stroke="#34C759" stroke-width="3" fill="none"/>
          <circle cx="380" cy="165" r="7" fill="#34C759"/>
          <circle cx="380" cy="165" r="13" fill="#34C759" opacity="0.25"><animate attributeName="r" values="7;17;7" dur="2.4s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.4;0;0.4" dur="2.4s" repeatCount="indefinite"/></circle>
          <text x="394" y="161" font-family="ui-sans-serif,system-ui" font-size="10" font-weight="600" fill="#1D1D1F">MAN · KR 67890</text>
          <text x="394" y="173" font-family="ui-monospace,monospace" font-size="9" fill="#34C759">w trasie · 2h 05min</text>

          <!-- Active route 3 (po PL) -->
          <path d="M 700 200 Q 760 170, 820 140" stroke="#FF9500" stroke-width="3" fill="none"/>
          <circle cx="820" cy="140" r="7" fill="#FF9500"/>
          <circle cx="820" cy="140" r="13" fill="#FF9500" opacity="0.25"><animate attributeName="r" values="7;17;7" dur="2.6s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.4;0;0.4" dur="2.6s" repeatCount="indefinite"/></circle>
          <text x="700" y="226" font-family="ui-sans-serif,system-ui" font-size="10" font-weight="600" fill="#1D1D1F">Volvo · WA 11223</text>
          <text x="700" y="238" font-family="ui-monospace,monospace" font-size="9" fill="#FF9500">parking · pauza 30min</text>

          <!-- City labels -->
          <text x="80" y="50" font-family="ui-sans-serif,system-ui" font-size="9" fill="#86868B">Gdańsk</text>
          <text x="220" y="60" font-family="ui-sans-serif,system-ui" font-size="9" fill="#86868B">Warszawa</text>
          <text x="380" y="225" font-family="ui-sans-serif,system-ui" font-size="9" fill="#86868B">Kraków</text>
          <text x="540" y="80" font-family="ui-sans-serif,system-ui" font-size="9" fill="#86868B">Berlin</text>
          <text x="820" y="120" font-family="ui-sans-serif,system-ui" font-size="9" fill="#86868B">Wrocław</text>
        </svg>
      </div>

      <!-- Driver activity row -->
      <div class="px-4 sm:px-5 py-4 bg-white">
        <p class="text-[10.5px] font-semibold uppercase tracking-[0.06em] text-[#86868B] mb-3">Status kierowców (ostatnia godzina)</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F5F5F7]">
            <div class="w-7 h-7 rounded-full bg-[#005CE8] text-white flex items-center justify-center text-[11px] font-bold">JK</div>
            <div class="flex-1 min-w-0">
              <p class="text-[12px] font-semibold text-[#1D1D1F] truncate">Jan Kowalski</p>
              <p class="text-[10.5px] text-[#34C759]">Jazda &middot; 4h 12min / 9h max</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F5F5F7]">
            <div class="w-7 h-7 rounded-full bg-[#34C759] text-white flex items-center justify-center text-[11px] font-bold">MN</div>
            <div class="flex-1 min-w-0">
              <p class="text-[12px] font-semibold text-[#1D1D1F] truncate">Marek Nowak</p>
              <p class="text-[10.5px] text-[#34C759]">Jazda &middot; 2h 05min / 9h max</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F5F5F7]">
            <div class="w-7 h-7 rounded-full bg-[#FF9500] text-white flex items-center justify-center text-[11px] font-bold">PW</div>
            <div class="flex-1 min-w-0">
              <p class="text-[12px] font-semibold text-[#1D1D1F] truncate">Piotr Wiśniewski</p>
              <p class="text-[10.5px] text-[#FF9500]">Pauza &middot; 30min / 45min wymagane</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Floating notification -->
    <div class="absolute -top-3 -right-3 sm:top-6 sm:-right-6 z-20 bg-white rounded-[14px] shadow-[0_8px_32px_rgba(0,0,0,0.12)] px-3.5 py-2.5 flex items-center gap-2.5 border border-black/[0.04] animate-pulse">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF3B30" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div>
        <p class="text-[10.5px] font-bold text-[#1D1D1F]">Tachograf DK 12345</p>
        <p class="text-[10px] text-[#FF3B30]">Legalizacja wygasa za 14 dni</p>
      </div>
    </div>
  </div>
</section>

<!-- ======================== TACHOGRAF — REGULACJA UE ======================== -->
<section class="relative bg-[#1D1D1F] py-20 sm:py-28 px-5 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-[600px] h-[400px] rounded-full bg-[#FF9500]/[0.10] blur-[140px]"></div>
  </div>
  <div class="relative max-w-[1100px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-center">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#FF9500]/30 bg-[#FF9500]/[0.10] mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF9500]"></span>
          <span class="text-[12px] font-semibold text-[#FF9500] tracking-[0.04em] uppercase">Pakiet mobilności UE &middot; 2 lipca 2026</span>
        </div>
        <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-[-0.03em] text-white leading-[1.15] mb-5">
          Nowy obowiązek tachografu G2V2.<br/>BusiKM jest&nbsp;na&nbsp;to&nbsp;gotowy.
        </h2>
        <p class="text-[16px] text-white/70 leading-relaxed mb-7 max-w-[600px]">
          Od 2 lipca 2026 pojazdy o DMC powyżej 2,5 t używane w&nbsp;transporcie międzynarodowym muszą być wyposażone w&nbsp;tachograf cyfrowy drugiej generacji wersji 2 (G2V2). Termin legalizacji, ewidencja czasu pracy i&nbsp;przechowywanie danych przez 56&nbsp;dni &mdash; obowiązki, których brak grozi karą do&nbsp;10&nbsp;000&nbsp;zł od&nbsp;Inspekcji Transportu Drogowego.
        </p>
        <ul class="space-y-2.5 text-[14.5px] text-white/85">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Alerty 90 / 30 / 14 dni przed wygaśnięciem legalizacji tachografu G2V2
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Ewidencja czasu pracy kierowcy z&nbsp;dokładnością do&nbsp;sekundy &mdash; gotowa pod kontrolę ITD
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Monitoring wypisów z&nbsp;licencji transportowej i&nbsp;dokumentów uprawniających do&nbsp;przewozów
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Pakiet mobilności: świadectwo kierowcy, ADR, kategoria prawa jazdy &mdash; alerty per kierowca
          </li>
        </ul>
      </div>

      <!-- Side panel — Alert preview -->
      <div class="reveal w-full lg:w-[340px]">
        <div class="rounded-[18px] bg-white p-5 shadow-[0_8px_32px_rgba(0,0,0,0.20)]">
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-black/[0.06]">
            <svg class="w-4 h-4 text-[#FF3B30]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-[11px] font-semibold uppercase tracking-[0.06em] text-[#FF3B30]">Alert krytyczny</p>
          </div>
          <p class="font-display font-bold text-[1.1rem] text-[#1D1D1F] mb-1.5">Tachograf G2V2 &mdash; DAF DK 12345</p>
          <p class="text-[13px] text-[#6E6E73] leading-relaxed mb-4">Świadectwo legalizacji tachografu wygasa za <strong>14 dni</strong>. Bez aktualnej legalizacji pojazd nie może wykonywać przewozów. Kara ITD: do <strong>10 000 zł</strong>.</p>
          <div class="space-y-2 text-[12.5px] text-[#6E6E73]">
            <div class="flex justify-between"><span>Wygaśnięcie</span><span class="font-mono text-[#FF3B30] font-semibold">16.05.2026</span></div>
            <div class="flex justify-between"><span>Pojazd</span><span class="font-mono text-[#1D1D1F]">DAF XF · DK 12345</span></div>
            <div class="flex justify-between"><span>Kierowca</span><span class="font-mono text-[#1D1D1F]">Jan Kowalski</span></div>
          </div>
          <button class="w-full mt-4 py-2.5 rounded-lg bg-[#1D1D1F] text-white text-[13px] font-semibold">Umów wizytę w warsztacie</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ======================== PROBLEM — DLA WŁAŚCICIELA TRANSPORTU ======================== -->
<section class="bg-white py-20 sm:py-28 px-5">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-14 reveal">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Problem właścicieli firm transportowych</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15] max-w-[800px] mx-auto">
        Trzy pytania, na które dziś nie ma jednej odpowiedzi.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 reveal-stagger">
      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <div class="w-11 h-11 rounded-[14px] bg-[#FF3B30]/[0.10] flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#FF3B30]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2.5 tracking-tight">Gdzie są moi kierowcy?</h3>
        <p class="text-[13.5px] text-[#6E6E73] leading-relaxed">Właściciel dzwoni do kierowcy, żeby się dowiedzieć, gdzie jest. Pyta dyspozytora, sprawdza WhatsAppa, czeka na zdjęcie z trasy. W&nbsp;tym czasie 5&nbsp;innych pojazdów też jeździ &mdash; nie wiadomo, jak długo, czy zgodnie z&nbsp;planem zlecenia.</p>
      </div>

      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <div class="w-11 h-11 rounded-[14px] bg-[#FF9500]/[0.10] flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#FF9500]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2.5 tracking-tight">Czy to zlecenie się opłaciło?</h3>
        <p class="text-[13.5px] text-[#6E6E73] leading-relaxed">Faktura za paliwo przyszła z&nbsp;trzytygodniowym opóźnieniem, kierowca wpisał stan licznika z&nbsp;głowy, a&nbsp;dyspozytor zapomniał odnotować, że trasa miała 200&nbsp;km objazdu. Po miesiącu nikt już nie wie, ile firma faktycznie zarobiła na&nbsp;tym kontrakcie.</p>
      </div>

      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <div class="w-11 h-11 rounded-[14px] bg-[#005CE8]/[0.10] flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#005CE8]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
