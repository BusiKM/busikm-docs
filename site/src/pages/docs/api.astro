      <thead><tr><th>Metoda</th><th>Ścieżka</th><th>Opis</th><th>Uprawnienia</th></tr></thead>
      <tbody>
        <tr><td>POST</td><td><code>/auth/register/</code></td><td>Rejestracja nowego użytkownika</td><td>AllowAny</td></tr>
        <tr><td>GET</td><td><code>/auth/verify-email/</code></td><td>Weryfikacja tokena e-mail (<code>?token=...</code>)</td><td>AllowAny</td></tr>
        <tr><td>POST</td><td><code>/auth/login/</code></td><td>Logowanie — zwraca parę JWT (access + refresh)</td><td>AllowAny</td></tr>
