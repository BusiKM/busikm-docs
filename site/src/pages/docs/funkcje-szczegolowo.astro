      <thead><tr><th>Rola</th><th>Kod</th><th>Interfejs</th><th>Opis</th></tr></thead>
      <tbody>
        <tr><td>Kierowca</td><td>DRIVER</td><td>Mobile</td><td>Rejestracja tras, GPS, zdjęcia licznika</td></tr>
        <tr><td>Właściciel</td><td>OWNER</td><td>Web + Mobile</td><td>Zarządzanie flotą, raporty, alerty</td></tr>
        <tr><td>Księgowy</td><td>ACCOUNTANT</td><td>Web</td><td>Raporty, eksport FK, tylko odczyt</td></tr>
        <tr><td>Biuro rachunkowe</td><td>ACCOUNTING_FIRM</td><td>Web</td><td>Multi-klient, dashboard zagregowany</td></tr>
      </tbody>
    </table>

