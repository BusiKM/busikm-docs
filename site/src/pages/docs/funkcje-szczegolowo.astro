      <tbody>
        <tr><td>Pojazdy</td><td>Maks. 1</td><td>"Uaktualnij plan, aby dodać więcej pojazdów"</td></tr>
        <tr><td>Kierowcy</td><td>Maks. 1</td><td>"Uaktualnij plan, aby zaprosić więcej kierowców"</td></tr>
        <tr><td>Raporty</td><td>Brak</td><td>"Raporty dostępne od planu Starter"</td></tr>
        <tr><td>Eksport FK</td><td>Zablokowany</td><td>"Eksport FK dostępny od planu Professional"</td></tr>
