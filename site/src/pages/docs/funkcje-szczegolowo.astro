    <table>
      <thead><tr><th>Grupa</th><th>Funkcje</th></tr></thead>
      <tbody>
        <tr><td>Panel biura rachunkowego</td><td>Rejestracja biura, zarzadzanie klientami, przelaczanie miedzy firmami</td></tr>
        <tr><td>Mapa</td><td>Pozycje kierowcow w czasie rzeczywistym na mapie interaktywnej</td></tr>
        <tr><td>Raporty</td><td>Dashboard zgodnosci, koszty floty, delegacje</td></tr>
