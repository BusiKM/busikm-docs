---
import DocsLayout from '../../layouts/DocsLayout.astro';

const productDocs = [
  { href: '/docs/funkcje-szczegolowo', title: 'Funkcje i plany', description: 'Pełna funkcjonalność produktu w pilotażu — co otrzymują firmy, księgowi i biura rachunkowe.', icon: `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke-width="1.5"/><polyline points="14 2 14 8 20 8" stroke-width="1.5"/><line x1="16" y1="13" x2="8" y2="13" stroke-width="1.5"/><line x1="16" y1="17" x2="8" y2="17" stroke-width="1.5"/>`, color: '#005CE8' },
  { href: '/docs/integracje-fk', title: 'Integracje FK', description: 'Eksport ewidencji przebiegu do Insert GT (EDI++), Comarch ERP Optima (XML) i Symfonia FK (TXT/AMS). Formaty plików, instrukcje importu, podstawy prawne.', icon: `<polyline points="16 18 22 12 16 6" stroke-width="1.5"/><polyline points="8 6 2 12 8 18" stroke-width="1.5"/>`, color: '#FF9500' },
  { href: '/docs/aplikacja-mobilna', title: 'Aplikacja mobilna', description: 'GPS w tle, klasyfikacja tras, zdjęcia licznika, tryb offline, powiadomienia push. iOS i Android.', icon: `<rect x="5" y="2" width="14" height="20" rx="2" ry="2" stroke-width="1.5"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="1.5"/>`, color: '#34C759' },
  { href: '/docs/aplikacja-webowa', title: 'Panel webowy', description: 'Dashboard właściciela, panel biura rachunkowego z przełączaniem klientów, mapa floty real-time, dashboard zgodności, eksport do FK.', icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke-width="1.5"/><line x1="8" y1="21" x2="16" y2="21" stroke-width="1.5"/><line x1="12" y1="17" x2="12" y2="21" stroke-width="1.5"/>`, color: '#8B5CF6' },
];

const infoDocs = [
  { href: '/docs/bezpieczenstwo', title: 'Bezpieczeństwo i RODO', description: 'Szyfrowanie, kontrola dostępu, zgodność z RODO, archiwizacja zgodna z Ordynacją podatkową, dziennik audytowy.', icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0110 0v4" stroke-width="1.5"/>`, color: '#FF3B30' },
  { href: '/docs/slownik', title: 'Słownik pojęć', description: 'Terminy podatkowe (art. 86a, VAT-26, stawki Dz.U. 2023), pojazdowe (OC, tachograf, ADR), funkcje BusiKM.', icon: `<path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke-width="1.5"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke-width="1.5"/>`, color: '#8B5CF6' },
];
---

<DocsLayout title="Dokumentacja" description="Dokumentacja produktu BusiKM — funkcje, integracje FK, aplikacja mobilna i webowa, bezpieczeństwo i zgodność z prawem podatkowym.">
  <div class="prose">
    <h1>Dokumentacja produktu</h1>
    <p>
      BusiKM jest elektroniczną ewidencją przebiegu pojazdu zaprojektowaną z myślą o&nbsp;biurach rachunkowych, księgowych i&nbsp;firmach prowadzących mobilną działalność.
      Zapewnia zgodność z&nbsp;art.&nbsp;86a ustawy o&nbsp;VAT, art.&nbsp;23 ust.&nbsp;7 ustawy o&nbsp;PIT oraz art.&nbsp;21 ust.&nbsp;1 pkt&nbsp;23b
      dotyczącym zwrotów kilometrowych pracowników. Eksport do trzech najpopularniejszych w&nbsp;Polsce systemów księgowych: Insert GT, Comarch ERP Optima oraz Symfonia FK.
    </p>
    <p>
      Mają Państwo pytania merytoryczne lub specyficzny scenariusz obsługi klienta? Prosimy o&nbsp;kontakt na&nbsp;<a href="mailto:kontakt@busikm.pl">kontakt@busikm.pl</a> &mdash; odpowiadamy w&nbsp;tym samym dniu roboczym.
    </p>

    <h2>Produkt</h2>
    <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
      {productDocs.map((doc) => (
        <a
          href={doc.href}
          class="group block p-5 rounded-[16px] border border-[#E8E8ED] bg-white hover:border-[#005CE8]/30 hover:shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-all duration-300"
        >
          <div class="w-10 h-10 rounded-[12px] mb-3 flex items-center justify-center" style={`background: ${doc.color}12;`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={doc.color} stroke-linecap="round" stroke-linejoin="round" set:html={doc.icon}/>
          </div>
          <h3 class="font-display font-semibold text-[#1D1D1F] group-hover:text-[#005CE8] transition-colors mb-1 text-[0.95rem]">
            {doc.title}
          </h3>
          <p class="text-[13px] text-[#6E6E73] leading-relaxed">
            {doc.description}
          </p>
        </a>
      ))}
    </div>

    <h2>Informacje</h2>
    <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
      {infoDocs.map((doc) => (
        <a
          href={doc.href}
          class="group block p-5 rounded-[16px] border border-[#E8E8ED] bg-white hover:border-[#005CE8]/30 hover:shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-all duration-300"
        >
          <div class="w-10 h-10 rounded-[12px] mb-3 flex items-center justify-center" style={`background: ${doc.color}12;`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={doc.color} stroke-linecap="round" stroke-linejoin="round" set:html={doc.icon}/>
          </div>
          <h3 class="font-display font-semibold text-[#1D1D1F] group-hover:text-[#005CE8] transition-colors mb-1 text-[0.95rem]">
            {doc.title}
          </h3>
          <p class="text-[13px] text-[#6E6E73] leading-relaxed">
            {doc.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</DocsLayout>
