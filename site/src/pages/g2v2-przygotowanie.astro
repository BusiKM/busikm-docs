<script is:inline>
  // Live countdown to 2 July 2026 00:00 (Warsaw / CEST UTC+2)
  (function() {
    var target = new Date('2026-07-02T00:00:00+02:00').getTime();
    var els = {
      days: document.getElementById('countdown-days'),
      hours: document.getElementById('countdown-hours'),
      minutes: document.getElementById('countdown-minutes'),
      seconds: document.getElementById('countdown-seconds'),
    };
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function tick() {
      var diff = target - Date.now();
      if (diff <= 0) {
        if (els.days) els.days.textContent = '00';
        if (els.hours) els.hours.textContent = '00';
        if (els.minutes) els.minutes.textContent = '00';
        if (els.seconds) els.seconds.textContent = '00';
        return;
      }
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      if (els.days) els.days.textContent = d;
      if (els.hours) els.hours.textContent = pad(h);
      if (els.minutes) els.minutes.textContent = pad(m);
      if (els.seconds) els.seconds.textContent = pad(s);
    }
    tick();
    setInterval(tick, 1000);
  })();

  // Cost calculator
  (function() {
    var inputs = {
      vehicles: document.getElementById('calc-vehicles'),
      drivers: document.getElementById('calc-drivers'),
      nonEu: document.getElementById('calc-non-eu'),
      kod95: document.getElementById('calc-kod95'),
    };
    var outputs = {
      total: document.getElementById('calc-total'),
      tacho: document.getElementById('calc-tacho'),
      cards: document.getElementById('calc-cards'),
      cert: document.getElementById('calc-cert'),
      kod95Row: document.getElementById('calc-kod95-row'),
      kod95Amount: document.getElementById('calc-kod95-amount'),
      psycho: document.getElementById('calc-psycho'),
    };
    if (!inputs.vehicles || !outputs.total) return;

    var RATES = {
      tacho: 6500,    // PLN per vehicle
      card: 175,      // PLN per driver
      cert: 350,      // PLN per non-EU driver
      kod95: 1100,    // PLN per driver (training)
      psycho: 250,    // PLN per driver
    };

    function fmt(n) {
      return n.toLocaleString('pl-PL', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' zł';
    }

    function recalc() {
      var v = Math.max(0, parseInt(inputs.vehicles.value, 10) || 0);
      var d = Math.max(0, parseInt(inputs.drivers.value, 10) || 0);
      var n = Math.min(d, Math.max(0, parseInt(inputs.nonEu.value, 10) || 0));
      var needsKod95 = inputs.kod95.checked;

      var costTacho = v * RATES.tacho;
      var costCards = d * RATES.card;
      var costCert = n * RATES.cert;
      var costKod95 = needsKod95 ? d * RATES.kod95 : 0;
      var costPsycho = d * RATES.psycho;
      var total = costTacho + costCards + costCert + costKod95 + costPsycho;

      outputs.tacho.textContent = fmt(costTacho);
      outputs.cards.textContent = fmt(costCards);
      outputs.cert.textContent = fmt(costCert);
      outputs.psycho.textContent = fmt(costPsycho);
      outputs.kod95Row.style.display = needsKod95 ? 'flex' : 'none';
      outputs.kod95Amount.textContent = fmt(costKod95);
      outputs.total.textContent = fmt(total);
    }

    [inputs.vehicles, inputs.drivers, inputs.nonEu, inputs.kod95].forEach(function(el) {
      el.addEventListener('input', recalc);
      el.addEventListener('change', recalc);
    });
    recalc();
  })();
</script>

<script>
  const io = new IntersectionObserver(
    (entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }); },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));
</script>

