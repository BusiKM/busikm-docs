---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Przygotowanie do G2V2 — BusiKM"
  description="Od 2 lipca 2026 busy 2,5–3,5 t w transporcie międzynarodowym muszą mieć tachograf G2V2. Sprawdź ile dni zostało, przejdź 5-krokową checklistę i policz koszt wymiany floty."
>

<!-- ============ HERO + COUNTDOWN ============ -->
<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full bg-[#FF9500]/[0.06] blur-[140px]"></div>
  </div>

  <div class="relative max-w-[1100px] mx-auto px-4 sm:px-6 pt-24 pb-16 sm:pt-32 sm:pb-20">
    <div class="text-center max-w-[820px] mx-auto reveal">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#FF9500]/25 bg-[#FF9500]/[0.06] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#FF9500] animate-pulse"></span>
        <span class="text-[12.5px] font-semibold text-[#FF9500] tracking-[0.04em] uppercase">Pakiet mobilności UE · 2 lipca 2026</span>
      </div>

      <h1 class="font-display text-[clamp(2.2rem,5.5vw,3.8rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
        Twoja flota busów 2,5–3,5 t<br/>
        <span class="text-[#FF9500]">wchodzi w obowiązek tachografu G2V2.</span>
      </h1>

      <p class="text-[clamp(1rem,2vw,1.2rem)] leading-relaxed text-[#6E6E73] max-w-[680px] mx-auto mb-10">
        Dotychczas tachograf był obowiązkowy dla pojazdów powyżej 3,5 t. Od 2 lipca 2026 obejmuje również busy 2,5–3,5 t używane w transporcie międzynarodowym. Karty kierowców, świadectwa kierowcy, ewidencja czasu pracy AETR, kabotaż 3/7, powrót do bazy co 4 tygodnie — wszystko to staje się Twoim obowiązkiem.
      </p>

      <!-- Live countdown -->
      <div id="g2v2-countdown" class="grid grid-cols-4 gap-2 sm:gap-4 max-w-[600px] mx-auto mb-10">
        {[
          { id: 'days', label: 'dni' },
          { id: 'hours', label: 'godzin' },
          { id: 'minutes', label: 'minut' },
          { id: 'seconds', label: 'sekund' },
        ].map(s => (
          <div class="bg-[#1D1D1F] rounded-2xl py-4 sm:py-5 px-2 sm:px-3 text-center shadow-[0_4px_20px_rgba(0,0,0,0.08)]">
            <div id={`countdown-${s.id}`} class="font-display font-bold text-[clamp(1.4rem,4vw,2.4rem)] text-white tabular-nums leading-none tracking-tight">--</div>
            <div class="text-[10.5px] sm:text-[11.5px] text-white/50 mt-2 uppercase tracking-[0.06em]">{s.label}</div>
          </div>
        ))}
      </div>

      <p class="text-[12.5px] text-[#86868B] mb-10">do wejścia w życie obowiązku tachografu G2V2 dla busów 2,5–3,5 t</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#checklist" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#FF9500] text-white text-[15px] font-semibold hover:bg-[#E08600] transition-colors shadow-[0_1px_3px_rgba(255,149,0,0.4)]">
          Przejdź do checklisty
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#kalkulator" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#F5F5F7] transition-colors">
          Policz koszt wymiany
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ============ CO SIĘ ZMIENIA ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center max-w-[680px] mx-auto mb-12">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF9500] mb-4">Co się zmienia 2 lipca 2026</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Sześć obowiązków, których wcześniej<br/>nie miałeś.
      </h2>
      <p class="text-[15px] leading-relaxed text-[#6E6E73] mt-4">
        Pakiet mobilności UE i regulacja AETR rozszerzają zakres regulacji TIR-ów na busy 2,5–3,5 t w przewozach międzynarodowych. Brak każdego z poniższych = mandat lub zatrzymanie pojazdu.
      </p>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-4 max-w-[920px] mx-auto">
      {[
        {
          title: 'Tachograf cyfrowy G2V2',
          desc: 'Każdy pojazd 2,5–3,5 t musi mieć zainstalowany tachograf cyfrowy drugiej generacji wersja 2 wraz z aktualną legalizacją.',
          penalty: 'Kara ITD do 10 000 zł + zatrzymanie pojazdu',
          icon: `<rect x="3" y="6" width="18" height="13" rx="2" stroke-width="1.6"/><circle cx="12" cy="12.5" r="3.5" stroke-width="1.6"/><path d="M12 11v1.5l1 1" stroke-width="1.6"/>`,
        },
        {
          title: 'Karta kierowcy',
          desc: 'Każdy kierowca prowadzący pojazd z tachografem musi mieć imienną kartę cyfrową wystawioną przez PWPW (ważna 5 lat, koszt ~175 zł).',
          penalty: 'Kara ITD/BAG 1 800–3 000 EUR za kierowcę',
          icon: `<rect x="2" y="5" width="20" height="14" rx="2" stroke-width="1.6"/><circle cx="8" cy="12" r="2.5" stroke-width="1.6"/><path d="M14 10h6M14 14h4" stroke-width="1.6"/>`,
        },
        {
          title: 'Ewidencja czasu pracy AETR',
          desc: '4,5 h jazdy + 45 min przerwy, 9/11 h dziennego odpoczynku, 45 h tygodniowego, 56 h tygodniowego limitu jazdy, 90 h dwutygodniowego.',
          penalty: 'Mandaty 50–700 EUR za każde naruszenie',
          icon: `<circle cx="12" cy="12" r="9" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke-width="1.6"/>`,
        },
        {
          title: 'Powrót do bazy co 4 tygodnie',
          desc: 'Kierowca musi wrócić do siedziby firmy lub miejsca zamieszkania co 4 tygodnie na wymagany odpoczynek tygodniowy.',
          penalty: 'Naruszenie pakietu mobilności — kary do 30 000 EUR',
          icon: `<path d="M3 12l9-9 9 9M5 10v10a2 2 0 002 2h10a2 2 0 002-2V10" stroke-width="1.6"/>`,
        },
        {
          title: 'Kabotaż 3 operacje w 7 dni',
          desc: 'Po wjeździe z międzynarodowym ładunkiem masz prawo do 3 operacji kabotażowych w ciągu 7 dni, potem 4-dniowy „cooling off period".',
          penalty: 'Cofnięcie licencji + kara do 12 000 EUR',
          icon: `<path d="M5 12h14M5 12l4-4M5 12l4 4M19 12l-4-4M19 12l-4 4" stroke-width="1.6"/>`,
        },
        {
          title: 'Świadectwo kierowcy spoza UE',
          desc: 'Jeśli zatrudniasz kierowcę z kraju trzeciego (UA, BY, MD), musisz mieć świadectwo kierowcy wystawione przez GITD — ważne max 5 lat.',
          penalty: 'Kara 8 000 zł + odpowiedzialność solidarna',
          icon: `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke-width="1.6"/><path d="M14 2v6h6M9 13l2 2 4-4" stroke-width="1.6"/>`,
        },
      ].map(item => (
        <div class="bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-[14px] flex items-center justify-center shrink-0" style="background:#FF950012;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF9500" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}/>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{item.title}</h3>
              <p class="text-[13.5px] text-[#6E6E73] leading-relaxed mb-3">{item.desc}</p>
              <p class="text-[11.5px] font-semibold text-[#FF3B30] flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {item.penalty}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ 5-KROKOWA CHECKLISTA ============ -->
<section id="checklist" class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center max-w-[680px] mx-auto mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Plan przygotowania</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Pięć kroków do wejścia w obowiązek<br/>bez paniki i mandatów.
      </h2>
    </div>

    <ol class="reveal-stagger space-y-4 max-w-[820px] mx-auto">
      {[
        {
          step: '01',
          title: 'Audyt floty — które pojazdy wymagają wymiany',
          desc: 'Sprawdź każdy pojazd 2,5–3,5 t, którym wykonujesz przewozy międzynarodowe. Zanotuj rok produkcji, obecny tachograf (jeśli jest), datę pierwszej rejestracji. Pojazdy bez tachografu i te z G1 / G2V1 wymagają instalacji G2V2.',
          deliverable: 'Lista pojazdów + status zgodności',
          time: '1 dzień',
        },
        {
          step: '02',
          title: 'Plan wymiany — timeline i budżet',
          desc: 'Zarezerwuj wizyty w autoryzowanym warsztacie tachograficznym (dostępność spada bliżej deadline). Zaplanuj 2–4 dni na pojazd (instalacja + legalizacja). Skalkuluj koszt całkowity — patrz kalkulator niżej.',
          deliverable: 'Harmonogram wizyt + kosztorys',
          time: '2–3 dni',
        },
        {
          step: '03',
          title: 'Karty kierowców — wnioski do PWPW',
          desc: 'Każdy kierowca składa wniosek o kartę kierowcy (formularz + zdjęcie + opłata 175 zł) przez e-Urząd Skarbowy. Czas oczekiwania: 4–6 tygodni. Zacznij wcześnie — bliżej lipca kolejka się wydłuża.',
          deliverable: 'Karty kierowców dla całego zespołu',
          time: '4–6 tygodni oczekiwania',
        },
        {
          step: '04',
          title: 'Szkolenie zespołu — AETR, pakiet mobilności, Kod 95',
          desc: 'Twoi kierowcy przechodzili wcześniej C/C+E? Świetnie — mają Kod 95 i kwalifikację zawodową. Jeśli nie — wymagane szkolenie okresowe (35 h, 600–1500 zł). Plus krótkie szkolenie wewnętrzne z AETR i pakietu mobilności.',
          deliverable: 'Świadectwa kwalifikacji + onboarding zespołu',
          time: '1–2 tygodnie',
        },
        {
          step: '05',
          title: 'Konfiguracja narzędzia — BusiKM jako system',
          desc: 'Załaduj flotę i kierowców do BusiKM, podłącz dokumenty (OC, przegląd, tachograf G2V2, karty, świadectwa). System od dnia X przejmuje monitoring terminów, ewidencję czasu pracy i alerty 90 / 30 / 14 dni przed wygaśnięciem.',
          deliverable: 'Compliance dashboard zielony przed 2 lipca',
          time: '1 dzień konfiguracji',
        },
      ].map(item => (
        <li class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-[#005CE8]/20 hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300">
          <div class="flex items-start gap-5">
            <span class="font-display text-[2.2rem] font-bold tracking-tight text-[#005CE8] shrink-0 leading-none">{item.step}</span>
            <div class="flex-1 min-w-0">
              <h3 class="font-display font-semibold text-[1.1rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{item.title}</h3>
              <p class="text-[14px] text-[#6E6E73] leading-relaxed mb-4">{item.desc}</p>
              <div class="flex flex-wrap gap-3 text-[11.5px]">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#34C759]/[0.08] text-[#34C759] font-semibold">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {item.deliverable}
                </span>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#F5F5F7] text-[#86868B] font-medium">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {item.time}
                </span>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ============ KALKULATOR KOSZTÓW ============ -->
<section id="kalkulator" class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center max-w-[680px] mx-auto mb-12">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF9500] mb-4">Kalkulator</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Ile kosztuje przygotowanie<br/>Twojej floty?
      </h2>
      <p class="text-[14.5px] leading-relaxed text-[#6E6E73] mt-4">
        Realne stawki rynkowe w Polsce, maj 2026. Kalkulator dla orientacji — finalne kwoty zależą od warsztatu i regionu.
      </p>
    </div>

    <div class="reveal grid grid-cols-1 lg:grid-cols-12 gap-5 max-w-[920px] mx-auto">
      <!-- Inputs -->
      <div class="lg:col-span-5 bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
        <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-5 tracking-[-0.01em]">Twoja flota</h3>

        <div class="space-y-5">
          <div>
            <label for="calc-vehicles" class="block text-[12.5px] font-semibold text-[#1D1D1F] mb-2">Liczba pojazdów 2,5–3,5 t</label>
            <input type="number" id="calc-vehicles" min="0" max="200" value="5" class="w-full px-4 py-3 rounded-xl border border-[#D2D2D7] bg-white text-[15px] font-mono font-semibold text-[#1D1D1F] focus:outline-none focus:border-[#FF9500] focus:ring-2 focus:ring-[#FF9500]/20 transition-all"/>
          </div>

          <div>
            <label for="calc-drivers" class="block text-[12.5px] font-semibold text-[#1D1D1F] mb-2">Liczba kierowców</label>
            <input type="number" id="calc-drivers" min="0" max="200" value="6" class="w-full px-4 py-3 rounded-xl border border-[#D2D2D7] bg-white text-[15px] font-mono font-semibold text-[#1D1D1F] focus:outline-none focus:border-[#FF9500] focus:ring-2 focus:ring-[#FF9500]/20 transition-all"/>
          </div>

          <div>
            <label for="calc-non-eu" class="block text-[12.5px] font-semibold text-[#1D1D1F] mb-2">Kierowcy spoza UE (UA / BY / MD)</label>
            <input type="number" id="calc-non-eu" min="0" max="200" value="2" class="w-full px-4 py-3 rounded-xl border border-[#D2D2D7] bg-white text-[15px] font-mono font-semibold text-[#1D1D1F] focus:outline-none focus:border-[#FF9500] focus:ring-2 focus:ring-[#FF9500]/20 transition-all"/>
          </div>

          <div>
            <label class="flex items-center gap-2.5 cursor-pointer">
              <input type="checkbox" id="calc-kod95" class="w-4 h-4 rounded border-[#D2D2D7] text-[#FF9500] focus:ring-[#FF9500]/20"/>
              <span class="text-[12.5px] text-[#6E6E73] leading-snug">Kierowcy potrzebują szkolenia okresowego Kod 95</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Output -->
      <div class="lg:col-span-7 bg-[#1D1D1F] rounded-[20px] p-7 sm:p-8 text-white shadow-[0_8px_40px_rgba(0,0,0,0.20)]">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-white/50 mb-2">Szacunkowy koszt całkowity</p>
        <p id="calc-total" class="font-display font-bold text-[clamp(2rem,5vw,3rem)] tracking-[-0.03em] mb-6 leading-none">— zł</p>

        <div class="space-y-3 text-[13px]">
          <div class="flex items-center justify-between py-2.5 border-b border-white/10">
            <div>
              <p class="font-semibold">Tachograf G2V2 (instalacja + legalizacja)</p>
              <p class="text-[11px] text-white/50 mt-0.5">~6 500 zł × pojazd · jednorazowo</p>
            </div>
            <p id="calc-tacho" class="font-mono font-semibold whitespace-nowrap">— zł</p>
          </div>

          <div class="flex items-center justify-between py-2.5 border-b border-white/10">
            <div>
              <p class="font-semibold">Karty kierowcy (PWPW)</p>
              <p class="text-[11px] text-white/50 mt-0.5">175 zł × kierowca · ważne 5 lat</p>
            </div>
            <p id="calc-cards" class="font-mono font-semibold whitespace-nowrap">— zł</p>
          </div>

          <div class="flex items-center justify-between py-2.5 border-b border-white/10">
            <div>
              <p class="font-semibold">Świadectwa kierowcy (kraje trzecie)</p>
              <p class="text-[11px] text-white/50 mt-0.5">~350 zł × kierowca z UA/BY/MD</p>
            </div>
            <p id="calc-cert" class="font-mono font-semibold whitespace-nowrap">— zł</p>
          </div>

          <div id="calc-kod95-row" class="flex items-center justify-between py-2.5 border-b border-white/10" style="display:none">
            <div>
              <p class="font-semibold">Szkolenie okresowe Kod 95</p>
              <p class="text-[11px] text-white/50 mt-0.5">~1 100 zł × kierowca · 35 h kursu</p>
            </div>
            <p id="calc-kod95-amount" class="font-mono font-semibold whitespace-nowrap">— zł</p>
          </div>

          <div class="flex items-center justify-between py-2.5">
            <div>
              <p class="font-semibold">Badania psychotechniczne</p>
              <p class="text-[11px] text-white/50 mt-0.5">~250 zł × kierowca · jednorazowo</p>
            </div>
            <p id="calc-psycho" class="font-mono font-semibold whitespace-nowrap">— zł</p>
          </div>
        </div>

        <p class="text-[11px] text-white/40 mt-6 italic leading-relaxed">
          Stawki orientacyjne na podstawie cen rynkowych w PL (maj 2026). Nie wliczone: utrata pracy podczas wymiany (2–4 dni / pojazd), koszty ITD/BAG przy ewentualnych wcześniejszych kontrolach, marża subskrypcji oprogramowania monitorującego.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============ CO BUSIKM ZAŁATWIA ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center max-w-[680px] mx-auto mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Co BusiKM robi za Ciebie</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Sprzęt kupujesz w warsztacie.<br/>Resztą zajmujesz się tutaj.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {
          title: 'Compliance dashboard G2V2',
          desc: 'Status każdego pojazdu: zgodny / wymaga wymiany / w trakcie / pełna legalizacja. Filtrujesz po dacie pierwszej rejestracji albo typie tachografu.',
          color: '#FF9500',
        },
        {
          title: 'Alerty 90 / 30 / 14 / 7 dni',
          desc: 'Push i e-mail przed wygaśnięciem legalizacji tachografu, karty kierowcy, świadectwa kierowcy, kwalifikacji zawodowej, OC i przeglądu.',
          color: '#FF3B30',
        },
        {
          title: 'Ewidencja czasu pracy AETR',
