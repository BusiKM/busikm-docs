---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Dla biur rachunkowych obsługujących transport — BusiKM"
  description="Twoi klienci transportowi mają księgowe, które przerabiają faktury z UE w BusiKM. Ty dostajesz gotowy import — bez wpisywania paragonów z Niemiec i Włoch. Multi-tenant, dożywotnio gratis dla pilotów."
>

<!-- ============ HERO ============ -->
<section class="relative overflow-hidden bg-white px-5 py-24 sm:py-32">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[#8B5CF6]/[0.04] blur-[120px]"></div>
  </div>
  <div class="relative max-w-[1120px] mx-auto">
    <div class="max-w-[760px]">
      <div class="hero-seq-1 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#8B5CF6]/15 bg-[#8B5CF6]/[0.04] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#8B5CF6] animate-pulse"></span>
        <span class="text-[12.5px] font-medium text-[#8B5CF6] tracking-[0.01em]">Panel multi-tenant · Specjalizacja: transport międzynarodowy</span>
      </div>

      <h1 class="hero-seq-2 font-display text-[clamp(2.2rem,5vw,3.5rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
        Klient transportowy<br/>w 30 minut, nie w 3 dni.
      </h1>

      <p class="hero-seq-3 text-[clamp(1rem,2vw,1.15rem)] leading-relaxed text-[#6E6E73] max-w-[620px] mb-9">
        Twoi klienci transportu międzynarodowego mają w BusiKM wewnętrzne księgowe, które już przerobiły faktury z DE/IT/FR/ES, przeliczyły kursy NBP i policzyły diety. Ty otwierasz panel, klikasz „Eksport" i importujesz gotowe dane do swojego Insert GT, Comarch lub Symfonia.
      </p>

      <div class="hero-seq-4 flex flex-wrap gap-3 mb-12">
        <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#8B5CF6] text-white text-[15px] font-semibold hover:bg-[#7C3AED] transition-colors shadow-[0_1px_3px_rgba(139,92,246,0.4)]">
          Dołącz do pilotażu
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#F5F5F7] transition-colors">
          Zobacz funkcje
        </a>
      </div>

      <div class="hero-seq-5 grid grid-cols-2 sm:flex sm:flex-wrap gap-x-6 gap-y-7 sm:gap-8 md:gap-12 text-center sm:text-left">
        {[
          { num: '∞', label: 'klientów\u00A0bez\u00A0limitu' },
          { num: '1 panel', label: 'multi-tenant' },
          { num: 'Gotowe', label: 'JPK\u00A0/\u00A0VAT-REF\u00A0/\u00A0CIT' },
          { num: '0 zł', label: 'pilotaż dożywotnio' },
        ].map(s => (
          <div class="flex flex-col items-center sm:items-start">
            <div class="font-display text-[1.5rem] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-none">{s.num}</div>
            <div class="text-[12.5px] text-[#86868B] mt-2 max-w-[160px] leading-snug min-h-[2.4rem] flex items-start">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ============ DASHBOARD MULTI-TENANT ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#8B5CF6] mb-4">Pierwszy ekran po zalogowaniu</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Wszyscy klienci.<br/>Wszystkie zaległe rzeczy. Jeden ekran.
      </h2>
    </div>

    <div class="reveal rounded-[20px] bg-[#F8F7F2] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
      <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <div class="ml-4 flex-1 max-w-[340px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B] font-mono">app.busikm.pl/biuro/dashboard</div>
      </div>

      <div class="p-5 sm:p-7">
        <!-- Top stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5 auto-rows-fr">
          {[
            { label: 'Aktywni klienci', value: '8', sub: '6 transport · 2 logistyka', color: '#8B5CF6' },
            { label: 'JPK_V7 do złożenia', value: '5', sub: 'termin: 25 maja', color: '#FF3B30' },
            { label: 'VAT-REF czeka', value: '14 200 €', sub: 'DE 8 100 / FR 4 200 / IT 1 900', color: '#34C759' },
            { label: 'Eksporty gotowe', value: '23', sub: 'do importu w FK', color: '#FF9500' },
          ].map(s => (
            <div class="bg-white rounded-2xl p-4 shadow-[0_1px_3px_rgba(0,0,0,0.04)] flex flex-col">
              <p class="text-[10.5px] text-[#86868B] mb-1.5 uppercase tracking-[0.04em]">{s.label}</p>
              <p class="font-display text-[clamp(1.05rem,2vw,1.4rem)] font-bold tracking-[-0.02em] text-[#1D1D1F] leading-tight">{s.value}</p>
              <p class="text-[11px] mt-1 leading-tight mt-auto pt-1" style={`color: ${s.color};`}>{s.sub}</p>
            </div>
          ))}
        </div>

        <!-- Client list -->
        <div class="bg-white rounded-2xl shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="px-4 py-3 bg-[#FAFAFA] border-b border-black/[0.04] flex items-center justify-between">
            <span class="text-[11px] font-semibold uppercase tracking-[0.06em] text-[#86868B]">Klienci · status pracy</span>
            <span class="text-[11px] text-[#86868B]">filtr: maj 2026</span>
          </div>
          <div class="divide-y divide-black/[0.04]">
            {[
              { name: 'TransKowalski Sp. z o.o.', vehicles: 12, accountant: 'Joanna K. (księgowa)', status: 'Gotowe do JPK_V7', statusColor: '#34C759', vat: 'VAT-REF: 4 280 €' },
              { name: 'FlotaNowak', vehicles: 8, accountant: 'Marta L. (księgowa)', status: 'Czeka na 3 paragony', statusColor: '#FF9500', vat: 'VAT-REF: 2 100 €' },
              { name: 'EuroSpeed Logistics', vehicles: 15, accountant: 'Adam M. (księgowy)', status: 'Gotowe do JPK_V7', statusColor: '#34C759', vat: 'VAT-REF: 5 820 €' },
              { name: 'TransAlpina', vehicles: 6, accountant: 'Anna W. (księgowa)', status: 'Wymaga zatwierdzenia korekty', statusColor: '#FF3B30', vat: 'VAT-REF: 1 100 €' },
              { name: 'BusiPol Express', vehicles: 9, accountant: 'Piotr S. (księgowy)', status: 'Gotowe do JPK_V7', statusColor: '#34C759', vat: 'VAT-REF: 900 €' },
            ].map(c => (
              <div class="grid grid-cols-12 gap-3 items-center px-4 py-3.5 hover:bg-[#FAFAFA] transition-colors text-[12px]">
                <div class="col-span-12 sm:col-span-4">
                  <p class="font-semibold text-[#1D1D1F] leading-tight">{c.name}</p>
                  <p class="text-[11px] text-[#86868B] leading-tight">{c.vehicles} pojazdów · {c.accountant}</p>
                </div>
                <div class="col-span-12 sm:col-span-5">
                  <span class="inline-block px-2.5 py-1 rounded-md text-[11px] font-semibold" style={`background: ${c.statusColor}15; color: ${c.statusColor}`}>{c.status}</span>
                </div>
                <div class="col-span-12 sm:col-span-3 text-left sm:text-right">
                  <span class="text-[11px] font-mono text-[#34C759] font-semibold">{c.vat}</span>
                </div>
              </div>
            ))}
          </div>
          <div class="px-4 py-3 bg-[#FAFAFA] border-t border-black/[0.04] text-[11px] text-[#86868B] flex items-center justify-between">
            <span>+ 3 inni klienci (handlowi, bez transportu)</span>
            <span class="text-[#1D1D1F] font-semibold">Łącznie 8 firm transportowych · 50 pojazdów</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FUNKCJE BR ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal max-w-[620px] mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#8B5CF6] mb-4">Funkcje multi-tenant</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Sześć narzędzi, które robią z transportu<br/>najbardziej dochodową branżę BR.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {
          title: 'Przełączanie kontekstu klienta',
          desc: 'Lista klientów w menu bocznym. Klikasz nazwę firmy, cały panel pokazuje jej dane: ewidencję przebiegu, faktury kosztowe, rejestry VAT, paczkę VAT-REF, kosztorys delegacji. Bez ponownego logowania.',
          tech: 'Header X-Company-Context · Cache Redis 8h',
          color: '#8B5CF6',
        },
        {
          title: 'Eksport per klient — wszystkie systemy FK',
          desc: 'Każdy klient transportowy jednym kliknięciem eksportuje się do Insert GT (.epp EDI++), Comarch ERP Optima (XML), Symfonia FK (TXT/AMS), CSV uniwersalnego. Bez ręcznego przepisywania.',
          tech: 'EDI++ · XML · TXT/AMS · CSV · JPK ready',
          color: '#0A84FF',
        },
        {
          title: 'VAT-REFUND paczka per kraj',
          desc: 'BusiKM agreguje faktury kwalifikujące się do zwrotu VAT z DE, FR, IT, NL, AT, BE, ES (dyrektywa 2008/9/WE). Eksportujesz paczkę z załącznikami i składasz wniosek przez polski US do administracji kraju zwrotu. Termin: 30 września roku następnego.',
          tech: '8 dyrektywa · paczka XML+PDF · per kraj',
          color: '#34C759',
        },
        {
          title: 'JPK_V7 z auto-kategoryzacją',
          desc: 'Faktury z BusiKM mają już kategorie zgodne z planem kont (paliwo PL/UE, opłaty drogowe, hotele, serwisy), oznaczenia GTU jeśli wymagane, NIP-y polskie i unijne (zweryfikowane przez VIES). JPK_V7 generuje się bez korekt.',
          tech: 'GTU · VIES · JPK_V7-ready',
          color: '#FF9500',
        },
        {
          title: 'Audit trail i kontrola integralności',
          desc: 'Każda zmiana w systemie ma timestamp, autora i historię. Przy kontroli US widzisz: kto wprowadził fakturę, kiedy, jakim dokumentem, na jakiej podstawie. Pełna ścieżka audytu (5 lat retencji).',
          tech: 'Append-only log · 5 lat retencji',
          color: '#FF3B30',
        },
        {
          title: 'Trzy poziomy dostępu per klient',
          desc: 'Pełen zarząd (jak właściciel firmy), tylko odczyt (przegląd + raporty + eksport), tylko raporty (bez wglądu w operacje floty). Dla każdego klienta osobno — tak jak ustaliłeś w umowie.',
          tech: 'RBAC per klient · konfiguracja w panelu',
          color: '#005CE8',
        },
      ].map(f => (
        <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 group">
          <div class="w-11 h-11 rounded-[14px] mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style={`background: ${f.color}12;`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={f.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{f.title}</h3>
          <p class="text-[13.5px] leading-relaxed text-[#6E6E73] mb-3">{f.desc}</p>
          <p class="text-[11px] font-mono text-[#86868B]">{f.tech}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ JAK WYGLĄDA WSPÓŁPRACA ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#8B5CF6] mb-4">Trójkąt współpracy</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Klient ma księgową. Ty robisz JPK i CIT.<br/>BusiKM łączy was bez papieru.
      </h2>
    </div>

    <div class="reveal grid grid-cols-1 lg:grid-cols-3 gap-5">
      <div class="rounded-[20px] p-7 bg-[#F5F5F7]">
        <div class="w-11 h-11 rounded-[14px] bg-[#005CE8]/10 flex items-center justify-center mb-4">
          <span class="font-mono text-[14px] font-bold text-[#005CE8]">01</span>
        </div>
        <h3 class="font-display font-semibold text-[1rem] text-[#1D1D1F] mb-2">Firma transportowa</h3>
        <p class="text-[13px] text-[#6E6E73] leading-relaxed mb-3">Właściciel + dyspozytor + kierowcy. Aplikacja mobilna na telefon (GPS, paragony OCR), panel webowy do zarządzania flotą i zleceniami.</p>
        <p class="text-[11px] font-mono text-[#86868B]">Co generuje: trasy GPS, paragony, faktury sprzedaży, dokumenty floty.</p>
      </div>

      <div class="rounded-[20px] p-7 bg-[#FF9500]/[0.06] border border-[#FF9500]/10">
        <div class="w-11 h-11 rounded-[14px] bg-[#FF9500]/10 flex items-center justify-center mb-4">
          <span class="font-mono text-[14px] font-bold text-[#FF9500]">02</span>
        </div>
        <h3 class="font-display font-semibold text-[1rem] text-[#1D1D1F] mb-2">Wewnętrzna księgowa firmy</h3>
        <p class="text-[13px] text-[#6E6E73] leading-relaxed mb-3">Pracuje w panelu BusiKM. Sprawdza i zatwierdza faktury z OCR, kategoryzuje koszty, weryfikuje kursy, liczy diety i rentowność per zlecenie.</p>
        <p class="text-[11px] font-mono text-[#86868B]">Co przekazuje do BR: gotowe rejestry VAT, kategoryzacja, kursy NBP.</p>
      </div>

      <div class="rounded-[20px] p-7 bg-[#8B5CF6] text-white shadow-[0_4px_20px_rgba(139,92,246,0.20)]">
        <div class="w-11 h-11 rounded-[14px] bg-white/15 flex items-center justify-center mb-4">
          <span class="font-mono text-[14px] font-bold text-white">03</span>
        </div>
        <h3 class="font-display font-semibold text-[1rem] mb-2">Twoje biuro rachunkowe</h3>
        <p class="text-[13px] text-white/80 leading-relaxed mb-3">Multi-tenant panel. Przeglądasz dane wszystkich obsługiwanych firm, eksportujesz do swojego systemu FK, składasz JPK_V7, CIT-8, VAT-REF.</p>
        <p class="text-[11px] font-mono text-white/60">Co robisz: JPK_V7 · CIT-8 · VAT-REF · sprawozdania finansowe · korekty.</p>
      </div>
    </div>

    <p class="reveal text-[14px] text-[#86868B] text-center mt-7 max-w-[640px] mx-auto leading-relaxed italic">
      Niektóre małe firmy transportowe nie mają wewnętrznej księgowej — wtedy Ty pełnisz obie role. BusiKM dostosowuje panel: jeśli jesteś jedyną osobą obsługującą fakturę, widzisz pełen workflow OCR + zatwierdzania + eksportu.
    </p>
  </div>
</section>

<!-- ============ 3 POZIOMY DOSTĘPU ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-12">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#8B5CF6] mb-4">Poziomy dostępu</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Dopasuj zakres do umowy z klientem.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-3 gap-5">
      {[
        {
          level: 'PEŁNY ZARZĄD',
          title: 'Operacyjny + księgowy',
          desc: 'Wszystko jak właściciel firmy. Stosowane gdy obsługujesz operacje firmy „od A do Z" (mała firma bez wewnętrznej księgowej).',
          bullets: ['Pełen zarząd flotą i kierowcami', 'Konfiguracja zleceń', 'OCR, kursy, diety, rentowność', 'JPK_V7, VAT-REF, eksporty FK'],
          featured: false,
        },
        {
          level: 'CO NAJCZĘŚCIEJ',
          title: 'Tylko odczyt + eksport',
          desc: 'Domyślny model dla firm z wewnętrzną księgową. Ty sprawdzasz, eksportujesz, składasz deklaracje. Brak zmian operacyjnych.',
          bullets: ['Podgląd floty, kierowców, tras', 'Podgląd zatwierdzonych faktur', 'Eksport FK + paczki VAT-REF', 'JPK_V7 ready · brak edycji danych'],
          featured: true,
        },
        {
          level: 'TYLKO RAPORTY',
          title: 'Wyłącznie raporty',
          desc: 'Najbardziej restrykcyjny model. Stosowany przy dużych firmach z własnym pełnym działem księgowym, gdzie BR robi tylko sprawozdania finansowe.',
          bullets: ['Kilometrówki PDF', 'Eksporty FK (bez wglądu w operacje)', 'Raporty rentowności', 'Brak dostępu do tras i kierowców'],
          featured: false,
        },
      ].map(item => (
        <div class:list={[
          'rounded-[20px] p-7 transition-all duration-300',
          item.featured
            ? 'bg-[#8B5CF6] text-white border border-[#8B5CF6] shadow-[0_8px_40px_rgba(139,92,246,0.30)]'
            : 'bg-white shadow-[0_1px_4px_rgba(0,0,0,0.06)]',
        ]}>
          <p class:list={['text-[10.5px] font-bold uppercase tracking-[0.1em] mb-3', item.featured ? 'text-white/60' : 'text-[#8B5CF6]']}>{item.level}</p>
          <h3 class:list={['font-display font-semibold text-[1.15rem] mb-2 tracking-[-0.01em]', item.featured ? 'text-white' : 'text-[#1D1D1F]']}>{item.title}</h3>
          <p class:list={['text-[13.5px] leading-relaxed mb-5', item.featured ? 'text-white/80' : 'text-[#6E6E73]']}>{item.desc}</p>
          <ul class="flex flex-col gap-2.5">
            {item.bullets.map(b => (
              <li class:list={['flex items-start gap-2.5 text-[13px]', item.featured ? 'text-white/90' : 'text-[#6E6E73]']}>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="shrink-0 mt-0.5">
                  <path d="M2 8l4 4 8-8" stroke={item.featured ? 'white' : '#8B5CF6'} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ PILOTAŻ ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[900px] mx-auto">
    <div class="reveal rounded-[24px] bg-[#8B5CF6] p-8 sm:p-12 text-white shadow-[0_8px_40px_rgba(139,92,246,0.30)]">
      <div class="flex flex-col sm:flex-row items-start gap-6 mb-8">
        <div class="w-14 h-14 bg-white/15 rounded-[18px] flex items-center justify-center flex-shrink-0">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold uppercase tracking-[0.08em] text-white/60 mb-2">Pilotaż MVP dla biur rachunkowych</p>
          <h3 class="font-display text-[clamp(1.4rem,3vw,1.9rem)] font-bold tracking-[-0.02em] mb-3 leading-tight">Twoje biuro + wszystkie firmy klientów — dożywotnio gratis.</h3>
