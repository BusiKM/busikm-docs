<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  .animate-float { animation: float 4s ease-in-out infinite; }

  @keyframes bounce-slow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  .animate-bounce-slow { animation: bounce-slow 2.5s ease-in-out infinite; }

  .btn-primary-purple {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.875rem 1.75rem; border-radius: 9999px;
    background: #8B5CF6; color: white; font-size: 15px; font-weight: 600;
    letter-spacing: -0.01em; transition: all 0.2s;
    box-shadow: 0 1px 3px rgba(139,92,246,0.4);
  }
  .btn-primary-purple:hover { background: #7C3AED; box-shadow: 0 4px 12px rgba(139,92,246,0.35); }

  .btn-secondary-purple {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.875rem 1.75rem; border-radius: 9999px;
    border: 1px solid #D2D2D7; color: #1D1D1F; font-size: 15px; font-weight: 600;
    letter-spacing: -0.01em; transition: all 0.2s;
  }
  .btn-secondary-purple:hover { border-color: #8B5CF6; background: #8B5CF6/5; color: #8B5CF6; }

  .section-label {
    font-size: 12.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display); font-size: clamp(1.8rem,4vw,2.8rem);
    font-weight: 700; letter-spacing: -0.03em; color: #1D1D1F; line-height: 1.15;
  }

  .card {
    background: white; border-radius: 20px; padding: 1.75rem;
    border: 1px solid transparent; transition: all 0.3s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .card:hover {
    border-color: rgba(0,0,0,0.08);
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  }

  /* Reveal animations */
  .reveal, .reveal-stagger { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.is-visible, .reveal-stagger.is-visible { opacity: 1; transform: none; }
  .reveal-stagger.is-visible > * { animation: stagger-in 0.5s ease both; }
  .reveal-stagger.is-visible > *:nth-child(1) { animation-delay: 0s; }
  .reveal-stagger.is-visible > *:nth-child(2) { animation-delay: 0.08s; }
  .reveal-stagger.is-visible > *:nth-child(3) { animation-delay: 0.16s; }
  .reveal-stagger.is-visible > *:nth-child(4) { animation-delay: 0.24s; }
  .reveal-stagger.is-visible > *:nth-child(5) { animation-delay: 0.32s; }
  .reveal-stagger.is-visible > *:nth-child(6) { animation-delay: 0.40s; }

  @keyframes stagger-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: none; }
  }

  /* Hero sequencing */
  .hero-seq-1, .hero-seq-2, .hero-seq-3, .hero-seq-4, .hero-seq-5 {
    opacity: 0; animation: hero-fade-in 0.8s ease forwards;
  }
  .hero-seq-1 { animation-delay: 0.1s; }
  .hero-seq-2 { animation-delay: 0.25s; }
  .hero-seq-3 { animation-delay: 0.4s; }
  .hero-seq-4 { animation-delay: 0.55s; }
  .hero-seq-5 { animation-delay: 0.7s; }

  @keyframes hero-fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: none; }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));
</script>
