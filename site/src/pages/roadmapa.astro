---
import MarketingLayout from '../layouts/MarketingLayout.astro';

// Realne dane sprintów z Jira (projekt BKM, board 34)
// Synchronizowane komendą UPDATE ROADMAP. Ostatnia synchronizacja: 4 maja 2026.
// Zamknięte sprinty 0-6b (9 sprintów, 120 ticketów Done). Zaplanowane: 7a-22.

const closedSprints = 9;
const closedTickets = 120;

const phases = [
  {
    id: 'backend',
    label: 'Faza 1 — Domknięcie funkcji systemowych',
    period: '5 — 9 maja 2026',
    color: '#005CE8',
    summary: 'Cztery obszary funkcjonalne dopracowywane przed publicznym wdrożeniem. Każdy z nich przekłada się na konkretną wartość widoczną dla właściciela floty, dyspozytora, kierowcy i księgowego.',
    sprints: [
      { id: '7a', range: '5 maja', title: 'Powiadomienia push', desc: 'Trzy kanały komunikacji: alerty wygasających dokumentów, potwierdzenia zakończonych tras dla właściciela, komunikaty produktowe od zespołu.', tickets: 10 },
      { id: '7b', range: '6 maja', title: 'Automatyzacja cyklu próbnego', desc: 'Sekwencja przypomnień przed wygaśnięciem trialu, automatyczne przedłużenie dla kont, które jeszcze nie zarejestrowały żadnej trasy.', tickets: 6 },
      { id: '8', range: '7—8 maja', title: 'Mapa floty w czasie rzeczywistym', desc: 'Pozycje pojazdów aktualizowane na żywo dla właściciela floty i dyspozytora — bez konieczności odświeżania strony.', tickets: 12 },
      { id: '9', range: '9 maja', title: 'Domknięcie zakresu MVP', desc: 'Walidacje danych firmowych przy tworzeniu klienta, bezpieczne odzyskiwanie usuniętych obiektów, rozszerzony monitoring stanu systemu.', tickets: 7 },
    ],
  },
  {
    id: 'web',
    label: 'Faza 2 — Panel webowy',
    period: '10 — 19 maja 2026',
    color: '#34C759',
    summary: 'Pełen panel webowy dla właścicieli firm transportowych, dyspozytorów, księgowych i biur rachunkowych obsługujących firmy — od dashboardu floty po zaawansowane raporty i eksport do systemów księgowych.',
    sprints: [
      { id: '10a', range: '10 maja', title: 'Fundament panelu webowego', desc: 'Bezpieczna autoryzacja, spójny system designu, pełna responsywność — działa na komputerze, laptopie i tablecie.', tickets: 6 },
      { id: '10b', range: '11 maja', title: 'Główne widoki dla właściciela firmy', desc: 'Dashboard floty ze statystykami, listy pojazdów, kierowców, tras i faktur paliwowych z filtrowaniem i sortowaniem, szczegóły każdego obiektu z dokumentami i historią.', tickets: 7 },
      { id: '11a', range: '12 maja', title: 'Panel biura rachunkowego', desc: 'Przełączanie kontekstu między klientami jednym kliknięciem, zbiorczy dashboard wszystkich obsługiwanych firm, zarządzanie zaproszeniami klientów.', tickets: 5 },
      { id: '11b', range: '13 maja', title: 'Raporty i eksport do systemów księgowych', desc: 'Interfejs generowania raportów PDF zgodnych z art. 86a oraz eksport do Insert GT, Comarch ERP Optima i Symfonia FK jednym kliknięciem.', tickets: 6 },
      { id: '12a', range: '14 maja', title: 'Mapa floty w panelu webowym', desc: 'Wizualizacja pozycji pojazdów na żywo, komunikaty informacyjne o stanie programu pilotażowego.', tickets: 5 },
      { id: '12b', range: '15 maja', title: 'Onboarding pilota', desc: 'Bezpieczna ścieżka rejestracji z linku zaproszenia, ekrany powitalne dla nowych pilotów.', tickets: 1 },
      { id: '12c', range: '16 maja', title: 'Konfiguracja konta i zespołu', desc: 'Ustawienia firmy, profil użytkownika, zaproszenia członków zespołu z odpowiednimi uprawnieniami.', tickets: 3 },
      { id: '13a', range: '17—18 maja', title: 'Publiczna strona busikm.pl', desc: 'Pełna treść marketingowa, integracja z systemem zgłoszeń do pilotażu, optymalizacja pod wyszukiwarki.', tickets: 6 },
      { id: '13b', range: '19 maja', title: 'Testy automatyczne panelu', desc: 'Pełne pokrycie testami kluczowych ścieżek użytkownika z regresją uruchamianą przy każdej zmianie.', tickets: 2 },
    ],
  },
  {
    id: 'mobile',
    label: 'Faza 3 — Aplikacja mobilna',
    period: '20 — 28 maja 2026',
    color: '#FF9500',
    summary: 'Aplikacja na iOS i Android — narzędzie dla kierowcy w terenie i właściciela firmy w drodze. Kluczowa zasada: kierowca nie wpisuje niczego ręcznie.',
    sprints: [
      { id: '14a', range: '20 maja', title: 'Fundament aplikacji mobilnej', desc: 'Architektura aplikacji, struktura nawigacji dostosowana do roli użytkownika.', tickets: 4 },
      { id: '14b', range: '21 maja', title: 'Logowanie i pierwsze kroki', desc: 'Bezpieczna autoryzacja na urządzeniu, przewodnik dla nowego kierowcy, zarządzanie sesją.', tickets: 3 },
      { id: '15', range: '22—23 maja', title: 'Pełen flow pracy kierowcy', desc: 'Śledzenie GPS w tle, start/stop trasy jednym przyciskiem, zdjęcia drogomierza, klasyfikacja służbowa/prywatna, zatwierdzanie tras.', tickets: 8 },
      { id: '16a', range: '24 maja', title: 'Widok właściciela na telefonie', desc: 'Dashboard floty na telefonie, alerty dokumentów, przegląd tras zespołu, szybkie akcje zarządcze.', tickets: 4 },
      { id: '16b', range: '25 maja', title: 'Powiadomienia push w aplikacji', desc: 'Trzy kanały (alerty dokumentów, potwierdzenia tras, komunikaty produktowe), ustawienia preferencji per kanał.', tickets: 5 },
      { id: '16c', range: '26 maja', title: 'Pełny tryb offline', desc: 'Aplikacja działa bez internetu — trasy nagrywane lokalnie, automatyczna synchronizacja po odzyskaniu połączenia, bez ryzyka utraty danych.', tickets: 4 },
      { id: '17a', range: '27 maja', title: 'Wydanie do App Store i Google Play', desc: 'Aplikacja gotowa do publicznej dystrybucji w sklepach Apple i Google, automatyczne aktualizacje dla użytkowników.', tickets: 4 },
      { id: '17b', range: '28 maja', title: 'Testy aplikacji mobilnej', desc: 'Pokrycie testami jednostkowymi i scenariuszowymi przed pierwszym wydaniem.', tickets: 2 },
    ],
  },
  {
    id: 'launch',
    label: 'Faza 4 — Launch i rozszerzenia',
    period: '29 maja — 6 czerwca 2026',
    color: '#8B5CF6',
    summary: 'Wdrożenie produkcyjne, audyt bezpieczeństwa, testy z pierwszymi pilotami, a następnie funkcje rozszerzające zakres zgodności podatkowej i analityki.',
    sprints: [
      { id: '18', range: '29—30 maja', title: 'MVP LIVE — wdrożenie produkcyjne', desc: 'Pełen audyt bezpieczeństwa, testy wydajnościowe na docelowych obciążeniach, wdrożenie środowiska produkcyjnego, monitoring 24/7, dokumentacja operacyjna, UAT z pierwszymi pilotami.', tickets: 12, milestone: true },
      { id: '19', range: '31 maja — 1 czerwca', title: 'Automatyczne fakturowanie', desc: 'Samodzielna rejestracja firm bez biura rachunkowego, automatyczne faktury VAT, samoobsługowe zarządzanie subskrypcją.', tickets: 7 },
      { id: '20', range: '2—3 czerwca', title: 'Delegacje pracownicze i KSeF', desc: 'Eksport zwrotów kilometrowych pracowników (art. 21 ust. 1 pkt 23b) do trzech systemów księgowych. Integracja z Krajowym Systemem e-Faktur — faktury paliwowe powiązane z trasami pojazdu.', tickets: 5 },
      { id: '21', range: '4—5 czerwca', title: 'Zaawansowana analityka rentowności', desc: 'Raporty kosztów per zlecenie, per pojazd i per kierowca, porównania międzymiesięczne, wykrywanie trendów wykorzystania floty — dla właścicieli firm transportowych i biur rachunkowych prowadzących analizę.', tickets: 4 },
      { id: '22', range: '6 czerwca', title: 'Finalizacja dokumentacji produktu', desc: 'Spójność dokumentacji z wdrożonymi funkcjami, materiały dla nowych pilotów i biur rachunkowych.', tickets: 16 },
    ],
  },
];

const totalSprints = phases.reduce((acc, p) => acc + p.sprints.length, 0);
const totalTickets = phases.reduce((acc, p) => acc + p.sprints.reduce((a, s) => a + s.tickets, 0), 0);
---

<MarketingLayout title="Roadmapa — BusiKM" description="Plan rozwoju BusiKM. 9 sprintów ukończonych, 26 zaplanowanych. MVP LIVE 29-30 maja 2026. Pełna roadmapa zsynchronizowana z tablicą Jira.">

  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at top,#EBF2FF 0%,transparent 70%)"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-24 pb-20 sm:pt-32 sm:pb-28 text-center">

      <div class="hero-seq-1 inline-flex items-center gap-2 bg-[#34C759]/[0.08] border border-[#34C759]/15 rounded-full px-4 py-1.5 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#34C759] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#34C759]"></span>
        </span>
        <span class="text-sm font-medium text-gray-700">Sprint 6b zakończony — dashboard zgodności dokumentów floty gotowy</span>
      </div>

      <h1 class="hero-seq-2 text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-gray-900 leading-[1.1] tracking-tight mb-6">
        Plan rozwoju produktu.<br>
        <span class="bg-gradient-to-r from-[#005CE8] to-[#3380FF] bg-clip-text text-transparent">Z myślą o firmach transportowych.</span>
      </h1>

      <p class="hero-seq-3 text-lg sm:text-xl text-gray-500 leading-relaxed max-w-2xl mx-auto mb-10">
        Dziewięć sprintów za nami, dwadzieścia sześć przed nami. MVP LIVE 29–30 maja 2026, finalizacja produktu w pierwszym tygodniu czerwca. Każda nowa funkcja BusiKM trafia najpierw do pilotów — właścicieli firm transportowych, dyspozytorów, księgowych i biur rachunkowych obsługujących firmy.
      </p>

      <div class="hero-seq-4 flex flex-wrap justify-center gap-4 mb-16">
        <a href="/cennik" class="inline-flex items-center gap-2 bg-[#005CE8] hover:bg-[#003FAD] text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:shadow-lg hover:-translate-y-0.5">
          Dołącz do pilotażu
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="#fazy" class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:-translate-y-0.5">
          Zobacz fazy projektu
        </a>
      </div>

      <div class="hero-seq-5 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto text-center">
        <div class="flex flex-col items-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-[#34C759] font-display leading-none">{ closedTickets }</div>
          <div class="text-sm text-gray-400 mt-2 min-h-[2.5rem] flex items-start justify-center">ukończonych ticketów</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-[#005CE8] font-display leading-none">{ closedSprints }/{ totalSprints + closedSprints }</div>
          <div class="text-sm text-gray-400 mt-2 min-h-[2.5rem] flex items-start justify-center">sprintów gotowych</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display leading-none">{ totalTickets }</div>
          <div class="text-sm text-gray-400 mt-2 min-h-[2.5rem] flex items-start justify-center">ticketów w backlogu</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display leading-none">29 maj</div>
          <div class="text-sm text-gray-400 mt-2 min-h-[2.5rem] flex items-start justify-center">MVP LIVE</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== UKOŃCZONE SPRINTY ===================== -->
  <section class="bg-[#F5F5F7] py-20 sm:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="text-center mb-12 reveal">
        <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#34C759] mb-4">Co zostało zbudowane</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Dziewięć sprintów za nami. 120 ticketów ukończonych.</h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">Fundament aplikacji jest gotowy: autoryzacja, role, izolacja danych, kompletna ewidencja przebiegu zgodna z art. 86a, eksport do trzech systemów księgowych, hurtowe rozliczanie aktywnych pojazdów i plan indywidualny dla większych flot.</p>
      </div>

      <div class="space-y-3 reveal-stagger">

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S0</span>
              <div>
                <h3 class="font-bold text-gray-900">Środowisko produkcyjne i CI/CD</h3>
                <p class="text-xs text-gray-400">14–18 kwietnia 2026 · 13 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Środowisko produkcyjne, automatyzacja wdrożeń, monitoring infrastruktury i błędów aplikacji, dokumentacja architektury wewnętrznej.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S1</span>
              <div>
                <h3 class="font-bold text-gray-900">Autoryzacja i system ról</h3>
                <p class="text-xs text-gray-400">19–20 kwietnia 2026 · 10 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Bezpieczne logowanie z automatycznym odświeżaniem sesji, weryfikacja adresu e-mail, cztery role z dedykowanymi uprawnieniami: kierowca, właściciel, księgowy, biuro rachunkowe.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S2</span>
              <div>
                <h3 class="font-bold text-gray-900">Firmy, subskrypcje, izolacja danych</h3>
                <p class="text-xs text-gray-400">21 kwietnia 2026 · 16 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Profil firmy, subskrypcja, fundament multi-tenant z pełną izolacją danych między firmami oraz mechanizm przełączania kontekstu dla biur rachunkowych obsługujących wielu klientów.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S3</span>
              <div>
                <h3 class="font-bold text-gray-900">Pojazdy, kierowcy, dokumenty</h3>
                <p class="text-xs text-gray-400">22–23 kwietnia 2026 · 14 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Pełne zarządzanie flotą i kierowcami, upload dokumentów (OC, przegląd, tachograf, prawo jazdy), monitoring terminów ważności, zaproszenia nowych kierowców e-mailem.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S4</span>
              <div>
                <h3 class="font-bold text-gray-900">Kilometrówka, eksport FK, dokumenty</h3>
                <p class="text-xs text-gray-400">23–30 kwietnia 2026 · 35 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Pełna ewidencja przebiegu zgodna z art. 86a ust. 7 ustawy o VAT, dziennik audytowy zmian, eksport jednym kliknięciem do trzech systemów księgowych: Insert GT, Comarch ERP Optima oraz Symfonia FK. Stawki przebiegu zgodne z aktualnym rozporządzeniem, dobierane automatycznie po dacie trasy.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S5a</span>
              <div>
                <h3 class="font-bold text-gray-900">Model rozliczeń per aktywny pojazd</h3>
                <p class="text-xs text-gray-400">2 maja 2026 · 14 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Hurtowe rozliczanie aktywnych pojazdów floty w jednym cyklu, automatyczne miesięczne podsumowanie. Obsługa firm transportowych z wieloma oddziałami oraz biur rachunkowych prowadzących wiele firm transportowych jednocześnie.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S5b</span>
              <div>
                <h3 class="font-bold text-gray-900">Plan indywidualny dla większych flot</h3>
                <p class="text-xs text-gray-400">2 maja 2026 · 7 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
          <p class="text-sm text-gray-500">Wsparcie dla firm transportowych, które nie mieszczą się w standardowym zakresie — indywidualne warunki cenowe per pojazd, panel administracyjny do zarządzania umowami i walidacje rozdzielające plan indywidualny od standardowego pilotażu.</p>
        </div>

        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] opacity-90 hover:opacity-100 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 bg-[#34C759] text-white rounded-2xl text-[12.5px] font-bold tracking-tight shrink-0">S6a</span>
              <div>
                <h3 class="font-bold text-gray-900">System rejestracji pilotów</h3>
                <p class="text-xs text-gray-400">3–4 maja 2026 · 8 ticketów</p>
              </div>
            </div>
            <div class="sm:ml-auto"><span class="text-xs font-semibold text-[#34C759] bg-[#34C759]/[0.08] px-3 py-1 rounded-full">DONE</span></div>
          </div>
