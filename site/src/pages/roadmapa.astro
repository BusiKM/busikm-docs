---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Roadmapa - BusiKM" description="Od MVP do Exit — roadmapa 3 lata. Sprint Plan, prognozy przychodowe, skalowanie zespołu.">

  <!-- ===================== WHITE HERO ===================== -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at top,#EBF2FF 0%,transparent 70%)"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-24 pb-20 sm:pt-32 sm:pb-28 text-center">

      <div class="hero-seq-1 inline-flex items-center gap-2 bg-[#005CE8]/[0.06] border border-[#005CE8]/10 rounded-full px-4 py-1.5 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#34C759] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#34C759]"></span>
        </span>
        <span class="text-sm font-medium text-gray-600">Sprint 3 w toku &mdash; Kwiecień 2026</span>
      </div>

      <h1 class="hero-seq-2 text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-gray-900 leading-[1.1] tracking-tight mb-6">
        Od MVP do Exit.<br>
        <span class="bg-gradient-to-r from-[#005CE8] to-[#3380FF] bg-clip-text text-transparent">Roadmapa 3 lata.</span>
      </h1>

      <p class="hero-seq-3 text-lg sm:text-xl text-gray-500 leading-relaxed max-w-2xl mx-auto mb-10">
        104 tickety, 8 sprintów, 16 tygodni do uruchomienia MVP. Potem &mdash; monetyzacja, AI, ekspansja międzynarodowa i exit.
      </p>

      <div class="hero-seq-4 flex flex-wrap justify-center gap-4 mb-16">
        <a href="/funkcje" class="inline-flex items-center gap-2 bg-[#005CE8] hover:bg-[#003FAD] text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:shadow-lg hover:-translate-y-0.5">
          Poznaj funkcje
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/cennik" class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:-translate-y-0.5">
          Zobacz cennik
        </a>
      </div>

      <div class="hero-seq-5 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto">
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">104</div>
          <div class="text-sm text-gray-400 mt-1">tickety Jira</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">8</div>
          <div class="text-sm text-gray-400 mt-1">sprintów</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">16 tyg.</div>
          <div class="text-sm text-gray-400 mt-1">do MVP</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">20M</div>
          <div class="text-sm text-gray-400 mt-1">docelowy ARR</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TIMELINE ===================== -->
  <section class="bg-[#F5F5F7] py-20 sm:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Roadmapa produktowa</h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">Każda faza przybliża BusiKM do pozycji lidera ewidencji przebiegu w CEE.</p>
      </div>

      <!-- Timeline wrapper -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-[#005CE8] via-[#34C759] to-[#FF9500]"></div>

        <!-- Q3 2026 — MVP Launch (CURRENT) -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#005CE8] ring-4 ring-[#005CE8]/20 z-10">
            <span class="absolute -top-0.5 -left-0.5 w-6 h-6 rounded-full bg-[#005CE8]/30 animate-ping"></span>
          </div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#005CE8] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Aktualnie</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q3 2026 &mdash; MVP Launch</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#005CE8] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                5&ndash;10 firm pilotażowych, landing page live
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#005CE8] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                System trialowy (odwrócony 14-dniowy trial, 6-miesięczny pilot)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#005CE8] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                NPS &gt; 30
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex items-baseline gap-3">
              <span class="text-2xl font-extrabold text-[#005CE8] font-display">5 000 PLN</span>
              <span class="text-sm text-gray-400">MRR target</span>
            </div>
          </div>
        </div>

        <!-- Q4 2026 — Monetyzacja -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#34C759] ring-4 ring-[#34C759]/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#34C759]/10 text-[#34C759] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Planowane</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q4 2026 &mdash; Monetyzacja</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Stripe Billing (Checkout, Customer Portal, faktury VAT)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Feature gating per plan subskrypcyjny
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Start integracji Comarch Optima i Symfonia
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Pełny tryb offline (WatermelonDB)
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex flex-wrap items-baseline gap-4">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-extrabold text-gray-900 font-display">30 000 PLN</span>
                <span class="text-sm text-gray-400">MRR</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-gray-400">100</span>
                <span class="text-sm text-gray-400">płatnych firm</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-gray-400">+2</span>
                <span class="text-sm text-gray-400">nowe osoby w zespole</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Q2 2027 — AI Features -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#34C759] ring-4 ring-[#34C759]/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#34C759]/10 text-[#34C759] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Planowane</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q2 2027 &mdash; Funkcje AI</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                RAG Engine &mdash; &bdquo;Asystent Przepisów&rdquo; transportowych
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                OCR do skanowania faktur
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Optymalizacja tras (AI)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#34C759] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Public API + webhooks
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex flex-wrap items-baseline gap-4">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-extrabold text-gray-900 font-display">150 000 PLN</span>
                <span class="text-sm text-gray-400">MRR</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-[#005CE8] font-display">1,8M PLN</span>
                <span class="text-sm text-gray-400">ARR</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Q3 2027 — International -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#FF9500] ring-4 ring-[#FF9500]/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#FF9500]/10 text-[#FF9500] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Przyszłość</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q3 2027 &mdash; Ekspansja międzynarodowa</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Wejście na rynki: Czechy i Słowacja
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Lokalizacja UI, przepisów i systemów FK
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex flex-wrap items-baseline gap-4">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-extrabold text-gray-900 font-display">250 000 PLN</span>
                <span class="text-sm text-gray-400">MRR</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-[#005CE8] font-display">3M PLN</span>
                <span class="text-sm text-gray-400">ARR</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Q4 2027 — Enterprise -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#FF9500] ring-4 ring-[#FF9500]/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#FF9500]/10 text-[#FF9500] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Przyszłość</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q4 2027 &mdash; Enterprise</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Integracja e-TOLL
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Integracja systemu SENT
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                SSO (SAML 2.0 / OIDC)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Audit logs, custom roles
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex flex-wrap items-baseline gap-4">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-extrabold text-gray-900 font-display">400 000 PLN</span>
                <span class="text-sm text-gray-400">MRR</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-gray-400">8</span>
                <span class="text-sm text-gray-400">osób w zespole</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 2028 — Scale -->
        <div class="relative pl-16 sm:pl-20 pb-14 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-[#FF9500] ring-4 ring-[#FF9500]/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-[#FF9500]/10 text-[#FF9500] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Przyszłość</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">2028 &mdash; Skalowanie</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)]">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Q1&ndash;Q3: wejście na 5&ndash;9 rynków (RO, HU, BG, LT, LV, EE)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Runda finansowania (RBF lub Series A)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#FF9500] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Marketplace integracji
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex flex-wrap items-baseline gap-4">
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-extrabold text-gray-900 font-display">1 250 000 PLN</span>
                <span class="text-sm text-gray-400">MRR</span>
              </div>
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-gray-400">11</span>
                <span class="text-sm text-gray-400">osób w zespole</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Q4 2028 — Pre-Exit -->
        <div class="relative pl-16 sm:pl-20 reveal">
          <div class="absolute left-[17px] sm:left-[25px] top-1 w-5 h-5 rounded-full bg-gray-900 ring-4 ring-gray-900/20 z-10"></div>

          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 bg-gray-900 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Exit</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Q4 2028 &mdash; Pre-Exit</h3>
          </div>

          <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border-2 border-gray-900/10">
            <ul class="space-y-3 text-[15px] text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-900 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Audyt Big 4, IP cleanup, data room
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-900 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Churn &lt; 3%, NPS &gt; 50
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-900 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                12 osób w zespole
              </li>
            </ul>
            <div class="mt-5 pt-5 border-t border-gray-100 flex items-baseline gap-3">
              <span class="text-3xl font-extrabold text-gray-900 font-display">20M PLN</span>
              <span class="text-sm text-gray-400">docelowy ARR</span>
            </div>
          </div>
        </div>

      </div><!-- /timeline -->
    </div>
  </section>

  <!-- ===================== SPRINT PLAN ===================== -->
  <section class="bg-white py-20 sm:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Plan sprintów</h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">Sprinty 0&ndash;5 = MVP (12 tygodni). Sprinty 6&ndash;7 = post-MVP (4 tygodnie). Razem 104 tickety.</p>
      </div>

      <div class="space-y-3 reveal-stagger">

        <!-- Sprint 0 -->
        <div class="group bg-white rounded-[20px] p-6 shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)] transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-10 h-10 bg-[#005CE8] text-white rounded-2xl text-sm font-bold">S0</span>
              <div>
                <h3 class="font-bold text-gray-900">Infrastruktura</h3>
                <p class="text-xs text-gray-400">15 kwi &ndash; 30 kwi 2026</p>
              </div>
            </div>
            <div class="sm:ml-auto flex items-center gap-2">
              <span class="text-xs font-semibold text-[#005CE8] bg-[#005CE8]/[0.06] px-3 py-1 rounded-full">13 ticketów</span>
