---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const featureGroups = [
  {
    title: 'Automatyczne zbieranie danych',
    subtitle: 'Kierowca jedzie — BusiKM zapisuje. Jedyne pole ręczne: cel wyjazdu.',
    color: '#005CE8',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    features: [
      'GPS background tracking (iOS + Android)',
      'Automatyczne obliczanie dystansu z GPS',
      'Klasyfikacja tras: służbowa / prywatna',
      'Zdjęcia licznika (start / stop)',
      'Tryb offline — sync po powrocie online',
      'Dane pojazdu: nr rej., VIN, stan licznika',
      'Alert VAT-26 przy dodawaniu pojazdu',
      'Alerty dokumentów (OC, przegląd, prawo jazdy)',
    ],
  },
  {
    title: 'Raporty i ewidencja',
    subtitle: 'PDF wg wzoru MF, kalkulacja VAT, stawki km — wszystko automatyczne.',
    color: '#34C759',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
    features: [
      'Ewidencja przebiegu PDF wg wzoru MF (art. 86a)',
      'Kalkulacja VAT: 50% vs 100% wg statusu VAT-26',
      'Stawki km wg Dz.U. 2023 poz. 5 — dobierane po dacie',
      'Raport kosztów floty (PDF + CSV + Excel)',
      'Podsumowanie miesięczne per pojazd',
      'Elektroniczny podpis (login = podpis wg interpretacji MF)',
      'Archiwizacja danych — 5 lat, serwery w UE',
    ],
  },
  {
    title: 'Eksport do systemów FK',
    subtitle: 'Jeden klik — dane w Insert GT, Comarch lub Symfonia. Zero przepisywania.',
    color: '#FF9500',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>',
    features: [
      { name: 'Insert GT / Rewizor GT / nexo (EPP / EDI++)', tag: 'MVP' },
      { name: 'Comarch ERP Optima (XML)', tag: 'POST-MVP' },
      { name: 'Symfonia FK (TXT + szablon AMS)', tag: 'POST-MVP' },
      { name: 'Eksport ewidencji przebiegu + faktur paliwowych', tag: null },
      { name: 'Historia eksportów + statusy pobierania', tag: null },
      { name: 'Automatyczne kodowanie Windows-1250 (Insert GT)', tag: null },
    ],
  },
  {
    title: 'Panel biura rachunkowego',
    subtitle: 'Jeden dashboard dla wszystkich firm klientów. 3 miesiące gratis.',
    color: '#8B5CF6',
    featured: true,
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>',
    features: [
      'Multi-tenant — zarządzanie wieloma firmami',
      'Przełączanie kontekstu klienta jednym kliknięciem',
      'Zbiorczy dashboard wszystkich flot',
      'Dashboard oszczędności (godziny i złotówki)',
      'RBAC — poziomy dostępu per klient',
      'Zbiorczy eksport FK dla wszystkich firm',
      'Alerty dokumentów dla wszystkich flot',
      'Klienci biura korzystają z BusiKM gratis',
    ],
  },
  {
    title: 'Platforma i bezpieczeństwo',
    subtitle: 'Web, iOS, Android. Szyfrowanie, RODO, monitoring 24/7.',
    color: '#1D1D1F',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    features: [
      'Web dashboard (Next.js 14)',
      'Aplikacja mobilna iOS + Android (React Native + Expo)',
      'Mapa floty w czasie rzeczywistym (WebSocket)',
      'Push notifications + alerty e-mail',
      'Szyfrowanie AES-256 (transit + rest)',
      'Zgodność z RODO, dane w UE',
      'JWT z refresh rotation + secure storage',
      'OTA updates (Expo)',
    ],
  },
];
---

<MarketingLayout title="Funkcje — BusiKM" description="GPS tracking, raporty wg MF, eksport do Insert GT / Comarch / Symfonia, panel multi-klient dla biur rachunkowych. Web + iOS + Android.">

  <!-- HERO -->
  <section class="bg-white">
    <div class="max-w-[980px] mx-auto px-6 pt-24 pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-[#34C759] animate-pulse"></span>
        <span class="text-[12.5px] font-medium text-[#005CE8] tracking-[0.01em]">Web · iOS · Android</span>
      </div>

      <h1 class="text-[48px] sm:text-[56px] font-semibold tracking-tight leading-[1.07] text-[#1d1d1f]">
        Jedna platforma.<br/>
        <span class="text-[#6e6e73]">Od GPS po eksport do FK.</span>
      </h1>
      <p class="mt-6 text-[19px] sm:text-[21px] leading-relaxed text-[#6e6e73] max-w-2xl mx-auto">
        Kierowca jedzie z aplikacją — GPS rejestruje trasę. AI klasyfikuje cel.
        Księgowa klika Eksportuj — dane trafiają do Insert GT, Comarch lub Symfonia.
      </p>
    </div>
  </section>

  <!-- FEATURE GROUPS -->
  {featureGroups.map((group, groupIndex) => (
    <section class={groupIndex % 2 === 0 ? 'bg-[#F5F5F7]' : 'bg-white'}>
      <div class="max-w-[980px] mx-auto px-6 py-20">
        <div class:list={[
          'reveal-on-scroll rounded-[20px] p-7 sm:p-9 shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.1)] transition-shadow duration-300',
          (group as any).featured ? 'bg-[#8B5CF6] text-white' : 'bg-white',
        ]}>
          <div class="flex items-start gap-3.5 mb-2">
            <div
              class:list={[
                'w-11 h-11 rounded-[14px] flex items-center justify-center flex-shrink-0',
                (group as any).featured ? 'bg-white/20' : '',
              ]}
              style={!(group as any).featured ? `background-color: ${group.color};` : undefined}
              set:html={group.icon}
            />
            <div>
              <h2 class:list={[
                'text-[22px] font-semibold tracking-tight',
                (group as any).featured ? 'text-white' : 'text-[#1d1d1f]',
              ]}>
                {group.title}
              </h2>
              <p class:list={[
                'text-[14px] mt-1',
                (group as any).featured ? 'text-white/70' : 'text-[#86868B]',
              ]}>{group.subtitle}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mt-6">
            {group.features.map((feature) => {
              const isObj = typeof feature === 'object' && feature !== null;
              const name = isObj ? (feature as any).name : feature;
              const tag = isObj ? (feature as any).tag : null;
              const isFeatured = (group as any).featured;
              return (
                <div class="flex items-center gap-2.5 py-1">
                  <svg class="w-4 h-4 shrink-0" viewBox="0 0 16 16" fill="none">
                    <path d="M2 8l4 4 8-8" stroke={isFeatured ? 'white' : '#34C759'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class:list={[
                    'text-[15px] leading-snug',
                    isFeatured ? 'text-white/90' : 'text-[#1d1d1f]',
                  ]}>
                    {name}
                  </span>
                  {tag && (
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-semibold whitespace-nowrap flex-shrink-0 ${
                      tag === 'MVP'
                        ? (isFeatured ? 'bg-white/20 text-white' : 'bg-[#005CE8]/10 text-[#005CE8]')
                        : (isFeatured ? 'bg-white/10 text-white/60' : 'bg-[#FF9500]/10 text-[#FF9500]')
                    }`}>
                      {tag}
                    </span>
                  )}
                </div>
              );
            })}
          </div>

          {(group as any).featured && (
            <div class="mt-6 pt-5 border-t border-white/20">
              <a href="/cennik#trial-br" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-[#8B5CF6] text-[14px] font-bold hover:bg-white/90 transition-all">
                3 miesiące gratis dla biur
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="bg-[#1d1d1f]">
    <div class="max-w-[980px] mx-auto px-6 py-24 text-center">
      <h2 class="text-[40px] sm:text-[48px] font-semibold tracking-tight leading-tight text-white">
        3 miesiące gratis<br/>dla biur rachunkowych.
      </h2>
      <p class="mt-5 text-[19px] text-[#a1a1a6] max-w-xl mx-auto leading-relaxed">
        Pełny dostęp do panelu multi-klient. Bez karty kredytowej.
        Po trialu — od 29 zł za aktywny pojazd klienta.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/cennik#trial-br"
          class="inline-flex items-center gap-2 bg-[#005CE8] hover:bg-[#0040B0] text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          Zacznij bezpłatny trial
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href="/cennik"
          class="inline-flex items-center gap-2 bg-transparent border border-[#424245] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          Zobacz cennik
        </a>
      </div>
    </div>
  </section>

  <!-- Reveal animation script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('.reveal-on-scroll');

      elements.forEach((el) => {
        const htmlEl = el as HTMLElement;
        htmlEl.style.opacity = '0';
        htmlEl.style.transform = 'translateY(30px)';
        htmlEl.style.transition = 'opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const htmlEl = entry.target as HTMLElement;
              htmlEl.style.opacity = '1';
              htmlEl.style.transform = 'translateY(0)';
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );

      elements.forEach((el) => observer.observe(el));
    });
  </script>

</MarketingLayout>
