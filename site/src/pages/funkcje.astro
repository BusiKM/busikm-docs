---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const featureGroups = [
  {
    title: 'Aplikacja kierowcy',
    subtitle: 'GPS w tle, paragony zdjęciem, alerty czasu pracy. Działa bez zasięgu, w sześciu językach.',
    color: '#005CE8',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>',
    features: [
      { name: 'Lokalizacja GPS w tle (iOS + Android) — bez ręcznego startu', tag: 'MVP' },
      { name: 'Tryb offline — pełna praca bez zasięgu, sync po powrocie', tag: 'MVP' },
      { name: 'OCR paragonów — PL, EN, DE, IT, FR, ES', tag: 'MVP' },
      { name: 'Klasyfikacja kosztów: paliwo, Maut, hotel, posiłek, opłaty drogowe', tag: 'MVP' },
      { name: 'Zdjęcia liczników, dokumentów, CMR i protokołów', tag: 'MVP' },
      { name: 'Alerty czasu pracy AETR — przed naruszeniem (4,5h / 9h / 11h)', tag: 'MVP' },
      { name: 'Powiadomienia push + e-mail dla kierowcy i właściciela', tag: 'MVP' },
      { name: 'Sześć języków interfejsu — kierowca z UA, RO, BY rozumie wszystko', tag: 'MVP' },
    ],
  },
  {
    title: 'Panel właściciela floty',
    subtitle: 'Pojazdy, kierowcy, zlecenia i koszty na jednym ekranie. Real-time mapa po MVP.',
    color: '#34C759',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>',
    features: [
      { name: 'Dashboard floty — pojazdy, kierowcy, alerty, koszty miesiąca', tag: 'MVP' },
      { name: 'Lista zleceń + przypisanie kierowca/pojazd', tag: 'MVP' },
      { name: 'Raporty per pojazd / kierowca / okres', tag: 'MVP' },
      { name: 'Plan indywidualny dla większych flot — rozliczenie hurtowe', tag: 'MVP' },
      { name: 'Mapa floty w czasie rzeczywistym', tag: 'Po MVP' },
      { name: 'ETA dostawy + udostępnianie linku klientowi', tag: 'Po MVP' },
      { name: 'Strefy alertów — bus opuszcza wyznaczony obszar bez zlecenia', tag: 'Po MVP' },
      { name: 'Marża per zlecenie — które kursy się opłacają', tag: 'Po MVP' },
    ],
  },
  {
    title: 'Compliance i kontrola ITD',
    subtitle: 'AETR, dokumenty kierowcy, tachograf G2V2 (deadline 2 lipca 2026). Kary do 10 000 zł — pod kontrolą.',
    color: '#FF9500',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v6c0 5 3.5 9.5 9 11 5.5-1.5 9-6 9-11V7l-9-5z"/><path d="M9 12l2 2 4-4"/></svg>',
    features: [
      { name: 'Alerty czasu pracy AETR — 4,5h / 9h / 11h / dzień / tydzień / dwutydzień', tag: 'MVP' },
      { name: 'Pakiet mobilności UE — przerwy 45h, powroty cotygodniowe', tag: 'MVP' },
      { name: 'Dokumenty kierowcy — prawo jazdy, ADR, świadectwo kierowcy', tag: 'MVP' },
      { name: 'Dokumenty firmy — licencja transportowa, OCP, OC, przegląd', tag: 'MVP' },
      { name: 'Alerty terminów — 30 / 14 / 7 dni przed wygaśnięciem', tag: 'MVP' },
      { name: 'Tachograf G2V2 — monitoring legalizacji per pojazd', tag: 'Po MVP' },
      { name: 'Dashboard pod kontrolę ITD — wszystko gotowe na żądanie', tag: 'Po MVP' },
      { name: 'Ewidencja czasu pracy kierowcy — pełna historia + eksport', tag: 'Po MVP' },
    ],
  },
  {
    title: 'Księgowość transportu międzynarodowego',
    subtitle: 'Każdy paragon, każdy kurs walut, każdy eksport. OCR w sześciu językach, NBP automatycznie.',
    color: '#8B5CF6',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
    features: [
      { name: 'OCR paragonów — 6 języków, 7 typów dokumentów (paliwo, Maut, hotel, posiłek, prom, parking, naprawa)', tag: 'MVP' },
      { name: 'Kursy NBP automatyczne — przewalutowanie z dnia poprzedniego', tag: 'MVP' },
      { name: 'Eksport do Insert GT / Rewizor / nexo', tag: 'MVP' },
      { name: 'Eksport do Comarch ERP Optima', tag: 'MVP' },
      { name: 'Eksport do Symfonia FK', tag: 'MVP' },
      { name: 'Faktury zagraniczne — DE, FR, IT, AT i pozostałe kraje UE', tag: 'Po MVP' },
      { name: 'VAT-REF — gotowy raport zwrotu VAT z UE', tag: 'Po MVP' },
      { name: 'Rozliczenie kierowcy — diety, mandaty, wypłata w jednym', tag: 'Po MVP' },
      { name: 'Eksport delegacji do FK + obowiązkowy e-system fakturowy', tag: 'Po MVP' },
    ],
  },
  {
    title: 'Biuro rachunkowe — multi-tenant',
    subtitle: 'Jeden panel dla wszystkich klientów biura. Pilotaż dożywotnio gratis.',
    color: '#1D1D1F',
    featured: true,
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>',
    features: [
      'Multi-tenant — zarządzanie wszystkimi klientami z jednego konta',
      'Przełączanie kontekstu klienta jednym kliknięciem',
      'Zbiorczy dashboard wszystkich flot pod opieką biura',
      'Dashboard oszczędności — godziny i złotówki per klient',
      'Poziomy dostępu (RBAC) — pełen / tylko podgląd / tylko eksport',
      'Zbiorczy eksport FK dla wszystkich firm jednocześnie',
      'Alerty dokumentów i terminów dla wszystkich flot razem',
      'Wszyscy klienci biura korzystają z BusiKM gratis dożywotnio',
    ],
  },
  {
    title: 'Platforma i bezpieczeństwo',
    subtitle: 'Web + iOS + Android. Szyfrowanie, RODO, dane na serwerach w UE.',
    color: '#1D1D1F',
    icon: '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    features: [
      'Aplikacja webowa — działa w przeglądarce, bez instalacji',
      'Aplikacja mobilna na iOS i Android — z trybem offline',
      'Powiadomienia push + e-mail',
      'Szyfrowanie danych w transmisji i w spoczynku',
      'Zgodność z RODO — dane przechowywane wyłącznie w UE',
      'Codzienny backup + monitoring 24/7',
      'Aktualizacje aplikacji w tle, bez sklepu',
      'Bezpieczne logowanie + automatyczne wylogowywanie po bezczynności',
    ],
  },
];
---

<MarketingLayout title="Funkcje — BusiKM" description="Wszystko dla firm transportowych z busami 2,5–3,5 t: GPS, OCR paragonów w 6 językach, alerty AETR, dokumenty kierowcy, eksport do Insert GT / Comarch / Symfonia, panel multi-klient dla biur rachunkowych.">

  <!-- HERO -->
  <section class="bg-white">
    <div class="max-w-[980px] mx-auto px-6 pt-24 pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-[#34C759] animate-pulse"></span>
        <span class="text-[12.5px] font-medium text-[#005CE8] tracking-[0.01em]">Web · iOS · Android</span>
      </div>

      <h1 class="text-[48px] sm:text-[56px] font-semibold tracking-tight leading-[1.07] text-[#1d1d1f]">
        Pełen system dla busów<br/>
        <span class="text-[#6e6e73]">2,5–3,5 t w transporcie międzynarodowym.</span>
      </h1>
      <p class="mt-6 text-[19px] sm:text-[21px] leading-relaxed text-[#6e6e73] max-w-2xl mx-auto">
        Od GPS i paragonów w sześciu językach po dokumenty kierowcy, AETR, tachograf G2V2 i eksport do księgowej. Wszystko w jednej aplikacji — wszystko zgodne z prawem polskim i pakietem mobilności UE.
      </p>

      <div class="mt-8 inline-flex flex-wrap items-center justify-center gap-2 text-[12.5px] text-[#6E6E73]">
        <span class="px-2.5 py-1 rounded-full bg-[#005CE8]/[0.08] text-[#005CE8] font-semibold">MVP — gotowe lub w wdrożeniu</span>
        <span class="px-2.5 py-1 rounded-full bg-[#FF9500]/[0.08] text-[#FF9500] font-semibold">Po MVP — funkcje wkrótce</span>
        <span>Funkcje bez tagu są stale dostępne.</span>
      </div>
    </div>
  </section>

  <!-- FEATURE GROUPS -->
  {featureGroups.map((group, groupIndex) => (
    <section class={groupIndex % 2 === 0 ? 'bg-[#F5F5F7]' : 'bg-white'}>
      <div class="max-w-[980px] mx-auto px-6 py-20">
        <div class:list={[
          'reveal-on-scroll rounded-[20px] p-7 sm:p-9 shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.1)] transition-shadow duration-300',
          (group as any).featured ? 'bg-[#1D1D1F] text-white' : 'bg-white',
        ]}>
          <div class="flex items-start gap-3.5 mb-2">
            <div
              class:list={[
                'w-11 h-11 rounded-[14px] flex items-center justify-center flex-shrink-0',
                (group as any).featured ? 'bg-white/15' : '',
              ]}
              style={!(group as any).featured ? `background-color: ${group.color};` : undefined}
              set:html={group.icon}
            />
            <div>
              <h2 class:list={[
                'text-[22px] font-semibold tracking-tight',
                (group as any).featured ? 'text-white' : 'text-[#1d1d1f]',
              ]}>
                {group.title}
              </h2>
              <p class:list={[
                'text-[14px] mt-1 leading-relaxed',
                (group as any).featured ? 'text-white/70' : 'text-[#86868B]',
              ]}>{group.subtitle}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mt-6">
            {group.features.map((feature) => {
              const isObj = typeof feature === 'object' && feature !== null;
              const name = isObj ? (feature as any).name : feature;
              const tag = isObj ? (feature as any).tag : null;
              const isFeatured = (group as any).featured;
              return (
                <div class="flex items-start gap-2.5 py-1">
                  <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                    <path d="M2 8l4 4 8-8" stroke={isFeatured ? 'white' : '#34C759'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class:list={[
                    'text-[14.5px] leading-snug flex-1',
                    isFeatured ? 'text-white/90' : 'text-[#1d1d1f]',
                  ]}>
                    {name}
                  </span>
                  {tag && (
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-bold whitespace-nowrap flex-shrink-0 mt-0.5 ${
                      tag === 'MVP'
                        ? (isFeatured ? 'bg-white/20 text-white' : 'bg-[#005CE8]/[0.10] text-[#005CE8]')
                        : (isFeatured ? 'bg-white/10 text-white/70' : 'bg-[#FF9500]/[0.12] text-[#FF9500]')
                    }`}>
                      {tag}
                    </span>
                  )}
                </div>
              );
            })}
          </div>

          {(group as any).featured && (
            <div class="mt-6 pt-5 border-t border-white/15">
              <a href="/cennik" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-[#1D1D1F] text-[14px] font-bold hover:bg-white/90 transition-all">
                Dołącz do pilotażu
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="bg-[#1d1d1f]">
    <div class="max-w-[980px] mx-auto px-6 py-24 text-center">
      <h2 class="text-[40px] sm:text-[48px] font-semibold tracking-tight leading-tight text-white">
        Pilotaż dożywotnio gratis<br/>dla biur rachunkowych.
      </h2>
      <p class="mt-5 text-[19px] text-[#a1a1a6] max-w-xl mx-auto leading-relaxed">
        Pełny dostęp do panelu multi-klient. Bez karty kredytowej.
        Wszystkie firmy klientów biura korzystają również gratis &mdash; dopóki biuro pozostaje w pilotażu.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/cennik#trial-br"
          class="inline-flex items-center gap-2 bg-[#005CE8] hover:bg-[#0040B0] text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          Zacznij bezpłatny trial
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href="/cennik"
          class="inline-flex items-center gap-2 bg-transparent border border-[#424245] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          Zobacz cennik
        </a>
      </div>
    </div>
  </section>

  <!-- Reveal animation script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('.reveal-on-scroll');

      elements.forEach((el) => {
        const htmlEl = el as HTMLElement;
        htmlEl.style.opacity = '0';
        htmlEl.style.transform = 'translateY(30px)';
        htmlEl.style.transition = 'opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const htmlEl = entry.target as HTMLElement;
              htmlEl.style.opacity = '1';
              htmlEl.style.transform = 'translateY(0)';
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );

      elements.forEach((el) => observer.observe(el));
    });
  </script>

</MarketingLayout>
