---

<MarketingLayout title="Funkcje" description="Kompletny przegląd funkcji BusiKM — GPS tracking, raporty MF, eksport FK, panel flotowy, tryb offline.">

  <!-- HERO -->
  <section class="bg-white">
    <div class="max-w-[980px] mx-auto px-6 pt-24 pb-20 text-center">
      <h1 class="text-[48px] sm:text-[56px] font-semibold tracking-tight leading-[1.07] text-[#1d1d1f]">
        Wszystko czego potrzebujesz.<br/>
        <span class="text-[#6e6e73]">W jednym miejscu.</span>
      </h1>
      <p class="mt-6 text-[19px] sm:text-[21px] leading-relaxed text-[#6e6e73] max-w-2xl mx-auto">
        10 grup funkcjonalności, ponad 50 funkcji, 4 role użytkowników.
        Od GPS trackingu po eksport do systemów FK — BusiKM obsługuje
        cały proces ewidencji przebiegu.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <div class="flex items-center gap-2">
          <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-[#005CE8]/10 text-[#005CE8]">MVP</span>
          <span class="text-[13px] text-[#6e6e73]">Sprint 0-5 (kwiecień-lipiec 2026)</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-[#FF9500]/10 text-[#FF9500]">POST-MVP</span>
          <span class="text-[13px] text-[#6e6e73]">Post-MVP (Q3 2026)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE GROUPS -->
  {featureGroups.map((group, groupIndex) => (
    <section class={groupIndex % 2 === 0 ? 'bg-[#F5F5F7]' : 'bg-white'}>
      <div class="max-w-[980px] mx-auto px-6 py-20">
        <div class="reveal-on-scroll bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.1)] transition-shadow duration-300">
          <div class="flex items-center gap-3.5 mb-6">
            <div
              class="w-11 h-11 rounded-[14px] flex items-center justify-center flex-shrink-0"
              style={`background-color: ${group.color};`}
              set:html={group.icon}
            />
            <h2 class="text-[22px] font-semibold tracking-tight text-[#1d1d1f]">
              {group.title}
            </h2>
          </div>
          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
            {group.features.map((feature) => (
              <div class="flex items-center gap-2.5 py-1">
                <span
                  class={`px-2 py-0.5 rounded-full text-[11px] font-semibold whitespace-nowrap flex-shrink-0 ${
                    feature.tag === 'MVP'
                      ? 'bg-[#005CE8]/10 text-[#005CE8]'
                      : 'bg-[#FF9500]/10 text-[#FF9500]'
                  }`}
                >
                  {feature.tag}
                </span>
                <span class="text-[15px] text-[#1d1d1f] leading-snug">
                  {feature.name}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="bg-[#1d1d1f]">
    <div class="max-w-[980px] mx-auto px-6 py-24 text-center">
      <h2 class="text-[40px] sm:text-[48px] font-semibold tracking-tight leading-tight text-white">
        Gotowy na porządek<br/>w ewidencji przebiegu?
      </h2>
      <p class="mt-5 text-[19px] text-[#a1a1a6] max-w-xl mx-auto leading-relaxed">
        Wybierz plan dopasowany do Twojej firmy i zacznij automatyzować
        ewidencję od pierwszego dnia.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/cennik"
          class="inline-flex items-center gap-2 bg-[#005CE8] hover:bg-[#0040B0] text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          Zobacz cennik
        </a>
        <a
          href="mailto:kontakt@busikm.pl"
          class="inline-flex items-center gap-2 bg-transparent border border-[#424245] hover:border-[#6e6e73] text-[#a1a1a6] hover:text-white font-semibold px-7 py-3.5 rounded-full text-[17px] transition-all duration-200"
        >
          kontakt@busikm.pl
        </a>
      </div>
    </div>
  </section>

  <!-- Reveal animation script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('.reveal-on-scroll');

      elements.forEach((el) => {
        const htmlEl = el as HTMLElement;
        htmlEl.style.opacity = '0';
        htmlEl.style.transform = 'translateY(30px)';
        htmlEl.style.transition = 'opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const htmlEl = entry.target as HTMLElement;
              htmlEl.style.opacity = '1';
              htmlEl.style.transform = 'translateY(0)';
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );

      elements.forEach((el) => observer.observe(el));
    });
  </script>

</MarketingLayout>
