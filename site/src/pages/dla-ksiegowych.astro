---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Dla księgowych w firmach transportowych — BusiKM"
  description="Faktury z DE/IT/FR/ES czytane automatycznie. Kursy NBP, diety zagraniczne, VAT-REFUND, rentowność per zlecenie i eksport do biura rachunkowego — bez Excela."
>

<!-- ============ HERO ============ -->
<section class="relative overflow-hidden bg-white px-5 py-24 sm:py-32">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[#FF9500]/[0.04] blur-[120px]"></div>
  </div>
  <div class="relative max-w-[1120px] mx-auto">
    <div class="max-w-[760px]">
      <div class="hero-seq-1 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#FF9500]/15 bg-[#FF9500]/[0.04] mb-6">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF9500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <span class="text-[12.5px] font-medium text-[#FF9500]">Dla księgowych w firmach transportowych</span>
      </div>

      <h1 class="hero-seq-2 font-display text-[clamp(2.2rem,5vw,3.5rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
        Koniec z reklamówką paragonów<br/>z całej Europy.
      </h1>

      <p class="hero-seq-3 text-[clamp(1rem,2vw,1.15rem)] leading-relaxed text-[#6E6E73] max-w-[620px] mb-9">
        BusiKM przyjmuje faktury kosztowe z DE/IT/FR/ES/NL przez OCR, przelicza walutę po kursie NBP, liczy diety per kraj na podstawie GPS i przygotowuje paczkę VAT-REFUND. Twoje biuro rachunkowe dostaje gotowy import do Insert GT, Comarch albo Symfonia.
      </p>

      <div class="hero-seq-4 flex flex-wrap gap-3 mb-12">
        <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#FF9500] text-white text-[15px] font-semibold hover:bg-[#E08600] transition-colors shadow-[0_1px_3px_rgba(255,149,0,0.4)]">
          Zobacz funkcje
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#F5F5F7] transition-colors">
          Cennik (gratis dla pilotów)
        </a>
      </div>

      <div class="hero-seq-5 grid grid-cols-2 sm:flex sm:flex-wrap gap-x-6 gap-y-7 sm:gap-8 md:gap-12 text-center sm:text-left">
        {[
          { num: '6', label: 'języków OCR\u00A0(PL/EN/DE/IT/FR/ES)' },
          { num: 'NBP', label: 'kursy auto z dnia poprzedniego' },
          { num: 'VAT-REF', label: 'paczka zwrotu z UE' },
          { num: '−60h/mies.', label: 'mniej ręcznej roboty' },
        ].map(s => (
          <div class="flex flex-col items-center sm:items-start">
            <div class="font-display text-[1.5rem] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-none">{s.num}</div>
            <div class="text-[12.5px] text-[#86868B] mt-2 max-w-[160px] leading-snug min-h-[2.4rem] flex items-start">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ============ MOCKUP — KOSZTY UE ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF9500] mb-4">Twój pierwszy ekran</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Skrzynka kosztowa UE.<br/>Wszystko już przeliczone.
      </h2>
      <p class="text-[15px] leading-relaxed text-[#6E6E73] mt-4">
        Każda faktura ma walutę oryginalną, kurs NBP, kwotę PLN, status (do zatwierdzenia / zaksięgowana / VAT-REF), pojazd i zlecenie. Filtrujesz, eksportujesz, gotowe.
      </p>
    </div>

    <div class="reveal rounded-[20px] bg-[#F8F7F2] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
      <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <div class="ml-4 flex-1 max-w-[340px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B] font-mono">app.busikm.pl/ksiegowosc/koszty-ue</div>
      </div>

      <div class="p-5 sm:p-7">
        <!-- Filter bar -->
        <div class="flex flex-wrap gap-2 mb-5">
          {[
            { label: 'Wszystkie', count: 47, active: true },
            { label: 'Paliwo', count: 18 },
            { label: 'Opłaty drogowe', count: 12 },
            { label: 'Hotele', count: 6 },
            { label: 'Serwis', count: 3 },
            { label: 'Do VAT-REF', count: 24 },
            { label: 'Maj 2026', count: 47 },
          ].map(f => (
            <span class:list={['px-3 py-1.5 rounded-xl text-[11.5px] font-semibold transition-colors',
              f.active ? 'bg-[#1D1D1F] text-white' : 'bg-white text-[#6E6E73] hover:bg-[#FF9500]/10']}>{f.label} <span class="opacity-60">({f.count})</span></span>
          ))}
        </div>

        <!-- Table — desktop / Cards — mobile -->
        <div class="bg-white rounded-2xl shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="hidden sm:grid grid-cols-12 gap-3 px-4 py-3 bg-[#FAFAFA] border-b border-black/[0.04] text-[10px] uppercase tracking-[0.06em] text-[#86868B] font-semibold">
            <div class="col-span-3">Faktura · Sprzedawca</div>
            <div class="col-span-2">Kategoria · Pojazd</div>
            <div class="col-span-2">Kwota oryg.</div>
            <div class="col-span-1">Kurs NBP</div>
            <div class="col-span-2">Kwota PLN</div>
            <div class="col-span-2">Status</div>
          </div>

          <div class="divide-y divide-black/[0.04]">
            {[
              { num: 'RE-2026-0473', vendor: 'Aral Tankstelle Hamburg', date: '12.05.2026', cat: 'Paliwo · Sprinter DK 12345', orig: '147,32 €', rate: '4,2731', pln: '629,57 zł', status: 'Do VAT-REF', statusColor: '#34C759', flag: 'DE' },
              { num: 'FT-987654', vendor: 'Telepass S.p.A.', date: '14.05.2026', cat: 'Maut · Crafter KR 67890', orig: '38,40 €', rate: '4,2698', pln: '163,96 zł', status: 'Zaksięgowana', statusColor: '#005CE8', flag: 'IT' },
              { num: 'F-2026/0892', vendor: 'Ibis Lyon Part-Dieu', date: '15.05.2026', cat: 'Hotel · Daily WA 11223', orig: '78,00 €', rate: '4,2710', pln: '333,14 zł', status: 'Do zatwierdzenia', statusColor: '#FF9500', flag: 'FR' },
              { num: 'FA-892371', vendor: 'OMV Tankstelle Wien', date: '16.05.2026', cat: 'Paliwo · Sprinter DK 12345', orig: '128,90 €', rate: '4,2754', pln: '551,11 zł', status: 'Do VAT-REF', statusColor: '#34C759', flag: 'AT' },
              { num: 'F-2026-1102', vendor: 'Garage Hendriks Apeldoorn', date: '17.05.2026', cat: 'Serwis · Transit GD 33445', orig: '420,50 €', rate: '4,2720', pln: '1\u00A0796,17 zł', status: 'Do zatwierdzenia', statusColor: '#FF9500', flag: 'NL' },
              { num: 'FT-2026/1471', vendor: 'Eni Carburanti', date: '17.05.2026', cat: 'Paliwo · Crafter KR 67890', orig: '163,80 €', rate: '4,2720', pln: '699,75 zł', status: 'Do VAT-REF', statusColor: '#34C759', flag: 'IT' },
            ].map(r => (
              <div class="px-4 py-3 hover:bg-[#FAFAFA] transition-colors">
                {/* Mobile card */}
                <div class="sm:hidden space-y-1.5">
                  <div class="flex items-start justify-between gap-2">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-1.5 mb-0.5">
                        <span class="font-mono text-[10px] text-[#86868B]">{r.num}</span>
                        <span class="text-[9px] font-mono font-semibold text-[#86868B] bg-black/[0.04] px-1.5 py-0.5 rounded">{r.flag}</span>
                      </div>
                      <p class="text-[13px] font-semibold text-[#1D1D1F] leading-tight">{r.vendor}</p>
                    </div>
                    <span class="inline-block px-2 py-0.5 rounded-md text-[10px] font-semibold whitespace-nowrap shrink-0" style={`background: ${r.statusColor}15; color: ${r.statusColor}`}>{r.status}</span>
                  </div>
                  <p class="text-[11px] text-[#86868B] leading-snug">{r.cat} · {r.date}</p>
                  <div class="flex items-baseline gap-1.5 text-[12px] font-mono pt-1.5 border-t border-black/[0.04]">
                    <span class="text-[#86868B]">{r.orig}</span>
                    <span class="text-[#86868B] text-[10px]">×</span>
                    <span class="text-[#86868B]">{r.rate}</span>
                    <span class="text-[#86868B] text-[10px]">=</span>
                    <span class="font-bold text-[#1D1D1F] ml-auto">{r.pln}</span>
                  </div>
                </div>

                {/* Desktop row */}
                <div class="hidden sm:grid grid-cols-12 gap-3 items-center text-[11.5px]">
                  <div class="col-span-3 min-w-0">
                    <p class="font-mono text-[10.5px] text-[#86868B]">{r.num}</p>
                    <p class="font-medium text-[#1D1D1F] truncate">{r.vendor}</p>
                    <p class="text-[10px] text-[#86868B]">{r.date}</p>
                  </div>
                  <div class="col-span-2 min-w-0">
                    <p class="text-[#1D1D1F] truncate">{r.cat}</p>
                  </div>
                  <div class="col-span-2 font-mono">
                    <span class="inline-block w-6 text-[9px] text-[#86868B] mr-1">{r.flag}</span>
                    <span class="font-semibold text-[#1D1D1F]">{r.orig}</span>
                  </div>
                  <div class="col-span-1 font-mono text-[#86868B]">{r.rate}</div>
                  <div class="col-span-2 font-mono font-semibold text-[#1D1D1F]">{r.pln}</div>
                  <div class="col-span-2">
                    <span class="inline-block px-2 py-0.5 rounded-md text-[10px] font-semibold" style={`background: ${r.statusColor}15; color: ${r.statusColor}`}>{r.status}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="px-4 py-3 bg-[#FAFAFA] border-t border-black/[0.04] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 text-[11px]">
            <span class="text-[#86868B]">Pokazano 6 z 47 dokumentów · maj 2026</span>
            <span class="text-[#1D1D1F] font-semibold">Suma PLN: 47 380,12 zł · VAT-REF: 24 dok. (3 920 €)</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FUNKCJE GŁÓWNE ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal max-w-[620px] mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF9500] mb-4">Funkcje dla księgowej</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Sześć rzeczy, które robisz miesięcznie<br/>— teraz dzieją się same.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-5">
      {[
        {
          title: 'OCR multi-języczny (PL/EN/DE/IT/FR/ES)',
          desc: 'Każdy dokument który kierowca sfotografuje — polskie KSeF-y, niemieckie Rechnungi, włoskie Fattury, francuskie Factures, hiszpańskie Facturas, angielskie Invoices — trafia do panelu z wyciągniętymi: numerem, datą, kwotą netto, VAT-em i sprzedawcą. Wszystko z polskimi etykietami.',
          color: '#FF9500',
          bullets: ['Auto-rozpoznanie waluty z dokumentu', 'Walidacja kwoty netto + VAT = brutto', 'Załącznik PDF/JPG zachowany jako dowód przez 5 lat', 'Tryb „do potwierdzenia" gdy OCR ma wątpliwości'],
        },
        {
          title: 'Kursy NBP tabela A — automatycznie',
          desc: 'Każda faktura w obcej walucie automatycznie pobiera kurs NBP tabela A z dnia poprzedzającego datę wystawienia (zgodnie z art. 11a UPDOP / art. 24c UPDOF). Brak kursu w weekend? System cofa się do ostatniego roboczego dnia. Pełen audit trail.',
          color: '#005CE8',
          bullets: ['Automatyczny pull z api.nbp.pl', 'Historia kursów z timestampami', 'Cache 24h dla performansu', 'Zgodność z UPDOP/UPDOF — bez ryzyka korekty'],
        },
        {
          title: 'Diety zagraniczne z GPS',
          desc: 'BusiKM wie po sekundach kiedy kierowca przekroczył granicę DE→FR i kiedy wyjechał z Włoch. Dieta zagraniczna liczona zgodnie z rozporządzeniem MRPiPS — różne stawki per kraj (49 € DE, 50 € FR, 48 € IT). Plus ryczałt noclegowy gdy brak rachunku.',
          color: '#34C759',
          bullets: ['Auto-detekcja granic z GPS', 'Stawki per kraj wg aktualnego rozporządzenia', 'Ryczałt 25% diety gdy brak rachunku noclegowego', 'Korekta godzin (powyżej 12h pełna dieta, poniżej 50% lub 33%)'],
        },
        {
          title: 'VAT-REFUND z 8 dyrektywy',
          desc: 'Faktury z paliwa, autostrad i niektórych innych kategorii kwalifikują się do zwrotu VAT z kraju zakupu (dyrektywa 2008/9/WE). BusiKM identyfikuje kwalifikujące się dokumenty per kraj i generuje paczkę gotową do złożenia wniosku przez polski US do administracji DE/FR/IT/NL/AT.',
          color: '#FF3B30',
          bullets: ['Filtr per kraj zwrotu (DE, FR, IT, NL, AT, BE, ES…)', 'Termin: do 30 września roku następnego', 'Minimalna kwota wniosku per kraj (50 EUR rocznie)', 'Eksport paczki z załącznikami w formacie XML/PDF'],
        },
        {
          title: 'Rentowność per zlecenie — live',
          desc: 'Każde zlecenie ma kartę z przychodem (z umowy), kosztami (paliwo, opłaty, hotele, diety, amortyzacja), marżą i ROI. Aktualizacja po każdym dodanym paragonie. Zero Excela, zero ręcznych formuł.',
          color: '#8B5CF6',
          bullets: ['Karta zlecenia z osią czasu kosztów', 'Marża netto, brutto, ROI', 'Porównanie do średniej w firmie i poprzednich tras', 'Eksport raportu PDF dla CFO'],
        },
        {
          title: 'Eksport do biura rachunkowego',
          desc: 'Twoje BR dostaje gotowy plik do importu w swoim systemie — Insert GT (EDI++ .epp), Comarch ERP Optima (XML), Symfonia FK (TXT/AMS), CSV uniwersalny. Bez wpisywania, bez korekt, bez „Pani Joanno, brakuje pojazdu w fakturze nr 12".',
          color: '#0A84FF',
          bullets: ['Insert GT EDI++ .epp', 'Comarch ERP Optima XML', 'Symfonia FK TXT/AMS', 'CSV uniwersalny + JPK_V7 ready'],
        },
      ].map(f => (
        <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 group">
          <div class="w-11 h-11 rounded-[14px] mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style={`background: ${f.color}12;`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={f.color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{f.title}</h3>
          <p class="text-[14px] leading-relaxed text-[#6E6E73] mb-4">{f.desc}</p>
          <ul class="flex flex-col gap-2">
            {f.bullets.map(b => (
              <li class="flex items-start gap-2.5 text-[12.5px] text-[#6E6E73]">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="shrink-0 mt-0.5"><path d="M2 8l4 4 8-8" stroke={f.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ DIETY ZAGRANICZNE TABELA ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center mb-10 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#34C759] mb-4">Diety zagraniczne</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        BusiKM zna stawki dla wszystkich krajów,<br/>do których jadą Twoje busy.
      </h2>
      <p class="text-[14px] leading-relaxed text-[#6E6E73] mt-4">
        Stawki wg rozporządzenia MRPiPS w sprawie należności z tytułu podróży służbowych. Aktualizowane przy każdej zmianie. Ryczałt noclegowy = 25% diety gdy brak rachunku.
      </p>
    </div>

    <div class="reveal rounded-[20px] bg-[#F5F5F7] p-6 sm:p-8">
      <div class="overflow-x-auto">
        <table class="w-full text-[13.5px]">
          <thead>
            <tr class="border-b border-black/[0.08] text-[11px] uppercase tracking-[0.06em] text-[#86868B]">
              <th class="text-left py-3 pr-4 font-semibold">Kraj</th>
              <th class="text-right py-3 pl-4 font-semibold">Dieta dzienna</th>
              <th class="text-right py-3 pl-4 font-semibold">Limit hotelu</th>
              <th class="text-right py-3 pl-4 font-semibold">Ryczałt noclegowy</th>
              <th class="text-right py-3 pl-4 font-semibold">Ryczałt komunikacyjny</th>
            </tr>
          </thead>
          <tbody>
            {[
              { country: 'Niemcy', diet: '49 €', hotel: '170 €', stay: '12,25 €', comm: '4,90 €' },
              { country: 'Francja', diet: '50 €', hotel: '180 €', stay: '12,50 €', comm: '5,00 €' },
              { country: 'Włochy', diet: '48 €', hotel: '174 €', stay: '12,00 €', comm: '4,80 €' },
              { country: 'Hiszpania', diet: '50 €', hotel: '160 €', stay: '12,50 €', comm: '5,00 €' },
              { country: 'Holandia', diet: '50 €', hotel: '130 €', stay: '12,50 €', comm: '5,00 €' },
              { country: 'Belgia', diet: '48 €', hotel: '160 €', stay: '12,00 €', comm: '4,80 €' },
              { country: 'Austria', diet: '52 €', hotel: '130 €', stay: '13,00 €', comm: '5,20 €' },
              { country: 'Czechy', diet: '41 €', hotel: '120 €', stay: '10,25 €', comm: '4,10 €' },
            ].map(d => (
              <tr class="border-b border-black/[0.04]">
                <td class="py-2.5 pr-4 font-semibold text-[#1D1D1F]">{d.country}</td>
                <td class="text-right py-2.5 pl-4 font-mono text-[#34C759] font-semibold">{d.diet}</td>
                <td class="text-right py-2.5 pl-4 font-mono text-[#6E6E73]">{d.hotel}</td>
                <td class="text-right py-2.5 pl-4 font-mono text-[#6E6E73]">{d.stay}</td>
                <td class="text-right py-2.5 pl-4 font-mono text-[#6E6E73]">{d.comm}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[11.5px] text-[#86868B] mt-4 italic">
        BusiKM dobiera stawkę obowiązującą w dniu wyjazdu i przelicza pełną dietę / 50% / 33% w zależności od liczby godzin w danym kraju (>12h, 8–12h, 0–8h). Aktualizacje przy każdej zmianie rozporządzenia.
      </p>
    </div>
  </div>
</section>

<!-- ============ EKSPORT DO BR ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#0A84FF] mb-4">Eksport do biura rachunkowego</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Twoje BR dostaje plik gotowy do importu.<br/>Nie listę PDF-ów do przepisania.
      </h2>
    </div>

    <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-5">
      {[
