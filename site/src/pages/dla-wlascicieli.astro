---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const iconDashboard = `<path d="M3 5h8v8H3zM13 5h8v4h-8zM13 13h8v6h-8zM3 17h8v2H3z" stroke="#34C759" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`;
const iconMap = `<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="#34C759" stroke-width="1.8" fill="none"/><circle cx="12" cy="9" r="2.5" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconVehicle = `<rect x="2" y="8" width="20" height="10" rx="2" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M6 8V6a2 2 0 012-2h8a2 2 0 012 2v2" stroke="#34C759" stroke-width="1.8" fill="none"/><circle cx="7" cy="18" r="2" stroke="#34C759" stroke-width="1.8" fill="none"/><circle cx="17" cy="18" r="2" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconDrivers = `<path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="#34C759" stroke-width="1.8" fill="none"/><circle cx="9" cy="7" r="4" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconReport = `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M14 2v6h6M8 13h8M8 17h8M8 9h2" stroke="#34C759" stroke-width="1.8" stroke-linecap="round" fill="none"/>`;
const iconAlert = `<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M13.73 21a2 2 0 01-3.46 0" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconCompliance = `<path d="M9 11l3 3L22 4" stroke="#34C759" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconRBAC = `<path d="M12 2a5 5 0 015 5v3H7V7a5 5 0 015-5z" stroke="#34C759" stroke-width="1.8" fill="none"/><rect x="3" y="10" width="18" height="12" rx="2" stroke="#34C759" stroke-width="1.8" fill="none"/><circle cx="12" cy="16" r="1.5" stroke="#34C759" stroke-width="1.8" fill="none"/>`;
const iconExport = `<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M7 10l5 5 5-5M12 15V3" stroke="#34C759" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`;
const iconWebApp = `<rect x="2" y="3" width="20" height="14" rx="2" stroke="#34C759" stroke-width="1.8" fill="none"/><path d="M8 21h8M12 17v4" stroke="#34C759" stroke-width="1.8" stroke-linecap="round" fill="none"/>`;

const features = [
  {
    icon: iconDashboard,
    title: 'Dashboard floty',
    desc: 'Podsumowanie floty w czasie rzeczywistym: łączna liczba pojazdów, aktywni kierowcy, trasy w bieżącym miesiącu i szacunkowe koszty przebiegu.',
    color: '#34C759',
  },
  {
    icon: iconMap,
    title: 'Mapa pojazdów na żywo',
    desc: 'Pozycje kierowców na mapie Mapbox GL z WebSocket. Markery z kierunkiem jazdy, statusy (w ruchu / zatrzymany) i klasteryzacja.',
    color: '#0A84FF',
  },
  {
    icon: iconVehicle,
    title: 'Zarządzanie pojazdami',
    desc: 'Dodawaj i edytuj pojazdy, przypisuj dokumenty: OC, przegląd techniczny, legalizacja tachografu. Wszystko w jednym miejscu.',
    color: '#FF9F0A',
  },
  {
    icon: iconDrivers,
    title: 'Zarządzanie kierowcami',
    desc: 'Zaproszenia e-mail, przypisywanie pojazdów, ewidencja prawa jazdy i kwalifikacji zawodowych. Automatyczne alerty o statusie dokumentów.',
    color: '#BF5AF2',
  },
  {
    icon: iconReport,
    title: 'Raporty zgodne z MF',
    desc: 'Kilometrówka PDF zgodna ze wzorem Ministerstwa Finansów. Raporty kosztów floty i raporty delegacji w formatach PDF i CSV.',
    color: '#FF375F',
  },
  {
    icon: iconAlert,
    title: 'Alerty dokumentów',
    desc: 'Automatyczne powiadomienia 30, 14 i 7 dni przed wygaśnięciem OC, przeglądu, tachografu i prawa jazdy. Nigdy nie przegapisz terminu.',
    color: '#FF9F0A',
  },
];

const moreFeatures = [
  {
    icon: iconCompliance,
    title: 'Compliance dashboard',
    desc: 'Wskaźniki kompletności tras, brakujące klasyfikacje, kolorowe statusy dokumentów (zielony / żółty / czerwony).',
    color: '#34C759',
  },
  {
    icon: iconRBAC,
    title: 'RBAC — 4 role w systemie',
    desc: 'Kierowca, właściciel, księgowy, biuro rachunkowe. Każda rola widzi dokładnie to, czego potrzebuje — nic więcej.',
    color: '#0A84FF',
  },
  {
    icon: iconExport,
    title: 'Eksport Insert GT EDI++',
    desc: 'Eksport kilometrówek do systemu FK Insert GT w formacie EDI++. Jeden klik — dane gotowe dla księgowego.',
    color: '#FF375F',
  },
  {
    icon: iconWebApp,
    title: 'Panel webowy Next.js',
    desc: 'Nowoczesny dashboard zbudowany na Next.js 16 + Tailwind + SWR + Recharts + Mapbox. Szybki, responsywny i bezpieczny.',
    color: '#BF5AF2',
  },
];

const faqs = [
  {
    q: 'Czy kilometrówka chroni mnie tylko w kwestii VAT?',
    a: 'Nie — BusiKM zabezpiecza trzy obszary: 100% odliczenia VAT (art. 86a), 100% kosztów pojazdu w PIT/CIT (art. 23 ust. 7) oraz zwroty km dla pracowników na prywatnych autach (art. 21 ust. 1 pkt 23b). Jeden system, trzy tarcze podatkowe.',
  },
  {
    q: 'Czy muszę zgłosić pojazd do urzędu skarbowego?',
    a: 'Tak — aby odliczać 100% VAT, musisz złożyć druk VAT-26 elektronicznie przez e-Urząd Skarbowy przed pierwszym odliczeniem. BusiKM przypomni Ci o tym przy dodawaniu pojazdu.',
  },
  {
    q: 'Ile pojazdów mogę dodać?',
    a: 'BusiKM jest na etapie pilotażu MVP — pierwsze firmy biorą udział dożywotnio gratis. Cennik komercyjny ogłosimy po analizie informacji od użytkowników pilotażowych. Limity pojazdów na poszczególnych planach: Free (1), Starter (do 10), Professional (do 50). Powyżej 50 — napisz do nas na kontakt@busikm.pl.',
  },
  {
    q: 'Czy mogę śledzić pojazdy na mapie w czasie rzeczywistym?',
    a: 'Tak. Dashboard właściciela zawiera interaktywną mapę z pozycjami kierowców aktualizowanymi na żywo. Widzisz kierunek jazdy, status (w ruchu / zatrzymany) i możesz filtrować po pojazdach.',
  },
  {
    q: 'Jakie dokumenty monitoruje system alertów?',
    a: 'Polisę OC, przegląd techniczny, legalizację tachografu i prawo jazdy kierowcy. Alerty push i e-mail 30, 14 i 7 dni przed wygaśnięciem.',
  },
  {
    q: 'Czy mogę zaprosić księgowego lub biuro rachunkowe?',
    a: 'Tak. System obsługuje 4 role: kierowca, właściciel, księgowy (read-only) i biuro rachunkowe (multi-klient). Każda rola ma dedykowane uprawnienia.',
  },
  {
    q: 'Mam leasing z limitem km — czy BusiKM pilnuje limit?',
    a: 'Tak. System monitoruje przebieg i alertuje gdy zbliżasz się do limitu leasingowego — unikasz kar za nadprzebieg.',
  },
  {
    q: 'Moi pracownicy jeżdżą prywatnymi autami służbowo. Mogę im zwracać koszty?',
    a: 'Tak — zwrot km × stawka jest zwolniony z PIT pracownika (art. 21 ust. 1 pkt 23b), ale wymaga ewidencji przebiegu. BusiKM prowadzi ją automatycznie z GPS.',
  },
];
---

<MarketingLayout title="Dla właścicieli firm — BusiKM" description="Pełna kontrola nad flotą pojazdów firmowych. Dashboard, mapa na żywo, alerty dokumentów, zarządzanie kierowcami i raporty zgodne z MF.">

  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden bg-white">
    <!-- subtle blue glow -->
    <div class="absolute top-[-120px] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[#34C759]/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-24 pb-20 sm:pt-32 sm:pb-28 text-center">
      <div class="reveal">
        <!-- pill badge -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#34C759]/15 bg-[#34C759]/[0.04] mb-6">
          <svg class="w-4 h-4 text-[#34C759]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7"/></svg>
          <span class="text-[13px] font-semibold text-[#1D1D1F]/70">Panel webowy + aplikacja mobilna</span>
        </div>

        <!-- headline -->
        <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.035em] text-[#1D1D1F] max-w-3xl mx-auto mb-5">
          Pełna kontrola <br class="hidden sm:block"/>nad Twoją flotą
        </h1>

        <!-- subtitle -->
        <p class="text-[15px] sm:text-[17px] leading-relaxed text-[#6E6E73] max-w-2xl mx-auto mb-10">
          Dashboard z mapą pojazdów na żywo, automatyczne alerty o wygasających dokumentach, kilometrówki zgodne z MF i eksport do systemów FK&nbsp;&mdash;&nbsp;wszystko z jednego panelu.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap justify-center gap-3.5 mb-16">
          <a href="/cennik" class="px-7 py-3.5 rounded-full bg-[#34C759] text-white text-[15px] font-semibold hover:bg-[#2DA44E] transition-colors duration-200">
            Wypróbuj za darmo
          </a>
          <a href="/funkcje" class="px-7 py-3.5 rounded-full bg-[#F5F5F7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#E8E8ED] transition-colors duration-200">
            Poznaj funkcje
          </a>
        </div>

        <!-- stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-2xl mx-auto">
          <div>
            <div class="text-[clamp(1.6rem,3vw,2rem)] font-bold tracking-[-0.03em] text-[#1D1D1F]">100%</div>
            <div class="text-[13px] text-[#6E6E73] mt-1">kontroli floty</div>
          </div>
          <div>
            <div class="text-[clamp(1.6rem,3vw,2rem)] font-bold tracking-[-0.03em] text-[#1D1D1F]">4 poziomy</div>
            <div class="text-[13px] text-[#6E6E73] mt-1">alertów dokumentów</div>
          </div>
          <div>
            <div class="text-[clamp(1.6rem,3vw,2rem)] font-bold tracking-[-0.03em] text-[#1D1D1F]">1 klik</div>
            <div class="text-[13px] text-[#6E6E73] mt-1">generowanie raportów</div>
          </div>
          <div>
            <div class="text-[clamp(1.6rem,3vw,2rem)] font-bold tracking-[-0.03em] text-[#1D1D1F]">100%</div>
            <div class="text-[13px] text-[#6E6E73] mt-1">compliance MF</div>
          </div>
        </div>
      </div>

      <!-- Live fleet — desktop: map, mobile: vehicle list -->
      <div class="reveal mt-12 max-w-[900px] mx-auto">
        <!-- MOBILE: vehicle status cards -->
        <div class="sm:hidden rounded-[20px] bg-white border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)] p-5">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-2.5 h-2.5 rounded-full bg-[#34C759] animate-pulse"></span>
            <span class="text-[13px] font-semibold text-[#1D1D1F]">5 pojazdów w trasie</span>
          </div>
          <div class="space-y-3">
            {[
              { plate: 'WA 12345', model: 'Sprinter', status: 'W trasie', detail: 'Warszawa → Kraków · 82 km/h', driver: 'Jan Kowalski', color: '#005CE8' },
              { plate: 'GD 54321', model: 'Crafter', status: 'W trasie', detail: 'Warszawa → Gdańsk · 95 km/h', driver: 'Piotr Nowak', color: '#34C759' },
              { plate: 'KR 98765', model: 'Ducato', status: 'W trasie', detail: 'Łódź → Wrocław · 67 km/h', driver: 'Adam Wiśniewski', color: '#FF9500' },
              { plate: 'PO 11223', model: 'Transit', status: 'W trasie', detail: 'Wrocław → Poznań · 88 km/h', driver: 'Marek Zieliński', color: '#8B5CF6' },
              { plate: 'GD 44556', model: 'Boxer', status: 'W trasie', detail: 'Gdańsk → Łódź · 72 km/h', driver: 'Tomek Lewandowski', color: '#FF3B30' },
            ].map(v => (
              <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F5F5F7]">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style={`background:${v.color}12`}>
                  <div class="w-3 h-3 rounded-full" style={`background:${v.color}`}></div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-[13px] font-bold text-[#1D1D1F]">{v.plate}</span>
                    <span class="text-[11px] text-[#86868B]">{v.model}</span>
                  </div>
                  <div class="text-[12px] font-medium truncate" style={`color:${v.color}`}>{v.detail}</div>
                  <div class="text-[11px] text-[#86868B]">{v.driver}</div>
                </div>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0"><path d="M6 4l4 4-4 4" stroke="#86868B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            ))}
          </div>
        </div>

        <!-- DESKTOP: animated Poland map -->
        <div class="hidden sm:block rounded-[20px] bg-[#F5F5F7] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
          <!-- Browser chrome -->
          <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
            <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
            <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
            <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
            <div class="ml-4 flex-1 max-w-[260px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B]">app.busikm.pl/dashboard/mapa</div>
            <div class="flex items-center gap-1.5 ml-auto">
              <span class="w-2 h-2 rounded-full bg-[#34C759] animate-pulse"></span>
              <span class="text-[11px] text-[#34C759] font-semibold">5 pojazdów w trasie</span>
            </div>
          </div>

          <!-- Map SVG — Poland with realistic geography -->
          <svg viewBox="0 0 900 420" width="100%" height="100%" preserveAspectRatio="xMidYMid slice" class="block">
            <defs>
              <filter id="tBlur"><feGaussianBlur stdDeviation="20"/></filter>
            </defs>

            <!-- Background — land color across entire map -->
            <rect width="900" height="420" fill="#E8ECE5"/>

            <!-- Terrain — subtle green patches -->
            <ellipse cx="350" cy="250" rx="100" ry="60" fill="#D5E8D0" opacity="0.25" filter="url(#tBlur)"/>
            <ellipse cx="600" cy="200" rx="80" ry="50" fill="#D5E8D0" opacity="0.2" filter="url(#tBlur)"/>
            <ellipse cx="500" cy="360" rx="80" ry="30" fill="#C8D5C0" opacity="0.3" filter="url(#tBlur)"/>

            <!-- Wisła river — Kraków→Warszawa→Gdańsk -->
            <path d="M 516 335 C 540 320 570 305 590 280 C 605 255 608 230 606 210 C 604 200 605 193 606 188 C 590 178 550 168 505 163 C 460 150 420 140 404 135 C 408 100 408 70 408 44" stroke="#A8C8E0" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.5"/>
            <path d="M 516 335 C 540 320 570 305 590 280 C 605 255 608 230 606 210 C 604 200 605 193 606 188 C 590 178 550 168 505 163 C 460 150 420 140 404 135 C 408 100 408 70 408 44" stroke="#C8DDF0" stroke-width="10" fill="none" stroke-linecap="round" opacity="0.15"/>

            <!-- Odra river -->
            <path d="M 202 315 C 210 300 230 280 260 264 C 250 240 240 210 235 190 C 225 160 200 130 170 110" stroke="#A8C8E0" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.35"/>

            <!-- Highways — dashed, connecting cities -->
            <path d="M 606 188 L 477 220" stroke="#CDCDCD" stroke-width="1.5" fill="none" stroke-dasharray="5 3" opacity="0.6"/>
            <path d="M 606 188 C 570 250 540 300 516 335" stroke="#CDCDCD" stroke-width="1.5" fill="none" stroke-dasharray="5 3" opacity="0.6"/>
            <path d="M 606 188 C 540 150 470 100 408 44" stroke="#CDCDCD" stroke-width="1.5" fill="none" stroke-dasharray="5 3" opacity="0.6"/>
            <path d="M 477 220 C 400 240 340 260 272 264" stroke="#CDCDCD" stroke-width="1.2" fill="none" stroke-dasharray="4 3" opacity="0.5"/>
            <path d="M 272 264 C 268 230 265 200 263 175" stroke="#CDCDCD" stroke-width="1.2" fill="none" stroke-dasharray="4 3" opacity="0.5"/>
            <path d="M 408 44 C 440 120 460 170 477 220" stroke="#CDCDCD" stroke-width="1.2" fill="none" stroke-dasharray="4 3" opacity="0.5"/>

            <!-- Cities at real positions -->
            <!-- Warszawa (606, 188) — main hub, largest marker -->
            <circle cx="606" cy="188" r="16" fill="#005CE8" opacity="0.06"><animate attributeName="r" values="16;24;16" dur="3s" repeatCount="indefinite"/></circle>
            <circle cx="606" cy="188" r="8" fill="white" stroke="#005CE8" stroke-width="2.5"/><circle cx="606" cy="188" r="3.5" fill="#005CE8"/>
            <rect x="573" y="200" width="66" height="17" rx="5" fill="#005CE8"/><text x="606" y="212" text-anchor="middle" fill="white" font-size="8.5" font-family="system-ui" font-weight="600">Warszawa</text>

            <!-- Kraków (516, 335) -->
            <circle cx="516" cy="335" r="6" fill="white" stroke="#34C759" stroke-width="2"/><circle cx="516" cy="335" r="2.5" fill="#34C759"/>
            <text x="516" y="352" text-anchor="middle" fill="#6E6E73" font-size="8.5" font-family="system-ui" font-weight="500">Kraków</text>

            <!-- Łódź (477, 220) -->
            <circle cx="477" cy="220" r="6" fill="white" stroke="#FF9500" stroke-width="2"/><circle cx="477" cy="220" r="2.5" fill="#FF9500"/>
            <text x="477" y="237" text-anchor="middle" fill="#6E6E73" font-size="8.5" font-family="system-ui" font-weight="500">Łódź</text>

            <!-- Wrocław (272, 264) -->
            <circle cx="272" cy="264" r="6" fill="white" stroke="#8B5CF6" stroke-width="2"/><circle cx="272" cy="264" r="2.5" fill="#8B5CF6"/>
            <text x="272" y="281" text-anchor="middle" fill="#6E6E73" font-size="8.5" font-family="system-ui" font-weight="500">Wrocław</text>

            <!-- Gdańsk (408, 44) -->
            <circle cx="408" cy="44" r="6" fill="white" stroke="#FF3B30" stroke-width="2"/><circle cx="408" cy="44" r="2.5" fill="#FF3B30"/>
            <text x="408" y="37" text-anchor="middle" fill="#6E6E73" font-size="8.5" font-family="system-ui" font-weight="500">Gdańsk</text>

            <!-- Poznań (263, 175) -->
            <circle cx="263" cy="175" r="5" fill="white" stroke="#86868B" stroke-width="1.5"/><circle cx="263" cy="175" r="2" fill="#86868B"/>
            <text x="263" y="168" text-anchor="middle" fill="#AEAEB2" font-size="8" font-family="system-ui">Poznań</text>

            <!-- Katowice (439, 321) — small marker -->
            <circle cx="439" cy="321" r="4" fill="white" stroke="#86868B" stroke-width="1.2"/><circle cx="439" cy="321" r="1.5" fill="#86868B"/>
            <text x="439" y="337" text-anchor="middle" fill="#AEAEB2" font-size="7.5" font-family="system-ui">Katowice</text>

            <!-- Bydgoszcz (353, 127) — small marker -->
            <circle cx="353" cy="127" r="4" fill="white" stroke="#86868B" stroke-width="1.2"/><circle cx="353" cy="127" r="1.5" fill="#86868B"/>
            <text x="353" y="120" text-anchor="middle" fill="#AEAEB2" font-size="7.5" font-family="system-ui">Bydgoszcz</text>

            <!-- Routes — curves following real highways between correct city positions -->
            <!-- R1: Warszawa(606,188)→Kraków(516,335) via E77/S7 through Radom -->
            <path id="oR1" d="M 606 188 C 600 210 585 245 570 270 C 555 295 540 315 530 328 C 525 332 520 334 516 335" stroke="#005CE8" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-dasharray="300" stroke-dashoffset="300"><animate attributeName="stroke-dashoffset" from="300" to="0" dur="2s" fill="freeze"/></path>
            <path d="M 606 188 C 600 210 585 245 570 270 C 555 295 540 315 530 328 C 525 332 520 334 516 335" stroke="#005CE8" stroke-width="10" fill="none" opacity="0.04" stroke-dasharray="300" stroke-dashoffset="300"><animate attributeName="stroke-dashoffset" from="300" to="0" dur="2s" fill="freeze"/></path>

            <!-- R2: Warszawa(606,188)→Gdańsk(408,44) via A1/S7 through Toruń -->
            <path id="oR2" d="M 606 188 C 580 170 540 145 500 120 C 470 100 440 75 420 55 C 414 48 410 45 408 44" stroke="#34C759" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-dasharray="350" stroke-dashoffset="350"><animate attributeName="stroke-dashoffset" from="350" to="0" dur="1.8s" begin="0.3s" fill="freeze"/></path>

