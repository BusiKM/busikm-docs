---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Dla właścicieli firm transportowych — BusiKM"
  description="Pełna kontrola nad flotą busów w transporcie międzynarodowym. Mapa floty na żywo, rentowność per zlecenie, koszty z całej UE w jednym miejscu, alerty G2V2 i pakiet mobilności."
>

<!-- ============ HERO ============ -->
<section class="relative overflow-hidden bg-white">
  <div class="absolute top-[-120px] left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-[#005CE8]/[0.04] blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-[1120px] mx-auto px-4 sm:px-6 pt-24 pb-16 sm:pt-32 sm:pb-20">
    <div class="max-w-[760px] reveal">
      <!-- pill badge -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#005CE8]/15 bg-[#005CE8]/[0.04] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#005CE8] animate-pulse"></span>
        <span class="text-[12.5px] font-medium text-[#005CE8] tracking-[0.01em]">Dla właścicieli firm transportowych · Transport międzynarodowy busami</span>
      </div>

      <!-- headline -->
      <h1 class="font-display text-[clamp(2.2rem,5vw,3.6rem)] font-bold leading-[1.08] tracking-[-0.035em] text-[#1D1D1F] mb-6">
        Wiesz, gdzie jest każdy bus.<br/>
        I ile naprawdę zarobiłeś na zleceniu.
      </h1>

      <!-- subtitle -->
      <p class="text-[clamp(1rem,2vw,1.15rem)] leading-relaxed text-[#6E6E73] max-w-[620px] mb-10">
        BusiKM łączy mapę floty na żywo, ewidencję czasu pracy AETR, rentowność każdego zlecenia w EUR i alerty dokumentów w jednym panelu. Faktury z paliwa z DE, opłaty Maut, hotele we Włoszech — wszystko w jednym widoku, bo KSeF tych dokumentów nie obsłuży.
      </p>

      <!-- CTA -->
      <div class="flex flex-wrap gap-3 mb-12">
        <a href="/cennik" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#005CE8] text-white text-[15px] font-semibold hover:bg-[#003FAD] transition-colors shadow-[0_1px_3px_rgba(0,92,232,0.4)]">
          Dołącz do pilotażu (gratis dożywotnio)
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/funkcje" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#D2D2D7] text-[#1D1D1F] text-[15px] font-semibold hover:bg-[#F5F5F7] transition-colors">
          Zobacz funkcje
        </a>
      </div>

      <!-- stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        {[
          { num: '~90%', label: 'rynku TSL\u00A0w PL\u00A0to transport międzynarodowy' },
          { num: '2 lip 2026', label: 'obowiązek tachografu G2V2' },
          { num: '30 000 €', label: 'kara za naruszenie pakietu mobilności' },
          { num: '6\u20138%', label: 'typowa marża netto\u00A0\u2014\u00A0każde zł błędu boli' },
        ].map(s => (
          <div>
            <div class="font-display text-[clamp(1.4rem,2.6vw,1.75rem)] font-bold tracking-[-0.03em] text-[#1D1D1F]">{s.num}</div>
            <div class="text-[12.5px] text-[#86868B] mt-1 leading-snug">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ============ DASHBOARD MOCKUP — RENTOWNOŚĆ ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-12 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Pierwszy ekran po zalogowaniu</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Każde aktywne zlecenie. Z rentownością na żywo.
      </h2>
      <p class="text-[15px] leading-relaxed text-[#6E6E73] mt-4">
        Przychód i koszty aktualizują się od razu po dodaniu paragonu z aplikacji kierowcy. Nie musisz czekać do końca miesiąca, żeby sprawdzić, ile wyniosła marża.
      </p>
    </div>

    <div class="reveal rounded-[20px] bg-[#F8F7F2] border border-black/[0.06] overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.10)]">
      <!-- Browser chrome -->
      <div class="flex items-center gap-2 px-5 py-3 bg-[#EBEBED] border-b border-black/[0.06]">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <div class="ml-4 flex-1 max-w-[320px] rounded-md bg-white/70 px-3 py-1 text-[11px] text-[#86868B] font-mono">app.busikm.pl/zlecenia/aktywne</div>
        <div class="hidden sm:flex items-center gap-1.5 ml-auto">
          <span class="w-2 h-2 rounded-full bg-[#34C759] animate-pulse"></span>
          <span class="text-[11px] text-[#34C759] font-semibold">odświeżane na żywo</span>
        </div>
      </div>

      <!-- Body -->
      <div class="p-5 sm:p-7">
        <!-- Top stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
          {[
            { label: 'Aktywne zlecenia', value: '7', sub: '4 PL → UE · 3 powrotne', color: '#005CE8' },
            { label: 'Przychód miesiąca', value: '186 420 zł', sub: '+12% vs poprzedni mies.', color: '#34C759' },
            { label: 'Koszty z UE (do księgowej)', value: '47 doku\u00ADmentów', sub: 'OCR · 6 walut · gotowe', color: '#FF9500' },
            { label: 'Marża netto', value: '7,8%', sub: 'cel: 8% · pilnujemy', color: '#8B5CF6' },
          ].map(s => (
            <div class="bg-white rounded-2xl p-4 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
              <p class="text-[10.5px] text-[#86868B] mb-1.5 uppercase tracking-[0.04em]">{s.label}</p>
              <p class="font-display text-[clamp(1.05rem,2vw,1.4rem)] font-bold tracking-[-0.02em] text-[#1D1D1F] leading-tight">{s.value}</p>
              <p class="text-[11px] mt-1 leading-tight" style={`color: ${s.color};`}>{s.sub}</p>
            </div>
          ))}
        </div>

        <!-- Order rows -->
        <div class="bg-white rounded-2xl shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="px-4 py-3 bg-[#FAFAFA] border-b border-black/[0.04] flex items-center justify-between">
            <span class="text-[11px] font-semibold uppercase tracking-[0.06em] text-[#86868B]">Aktywne zlecenia · rentowność na żywo</span>
            <span class="text-[11px] text-[#86868B]">stan na 14:23</span>
          </div>
          <div class="divide-y divide-black/[0.04]">
            {[
              {
                id: 'BKM-2841',
                vehicle: 'Sprinter DK 12345',
                driver: 'Jan Kowalski',
                route: 'Warszawa → Berlin',
                progress: 62,
                revenue: '1 850 €',
                costs: '1 140 €',
                margin: '+38,4%',
                marginColor: '#34C759',
                status: 'W ruchu · 412/670 km',
                statusColor: '#005CE8',
              },
              {
                id: 'BKM-2842',
                vehicle: 'Crafter KR 67890',
                driver: 'Marek Nowak',
                route: 'Kraków → Mediolan',
                progress: 28,
                revenue: '2 350 €',
                costs: '1 290 €',
                margin: '+45,1%',
                marginColor: '#34C759',
                status: 'W ruchu · 308/1100 km',
                statusColor: '#34C759',
              },
              {
                id: 'BKM-2843',
                vehicle: 'Daily WA 11223',
                driver: 'Piotr Wiśniewski',
                route: 'Wrocław → Paryż',
                progress: 45,
                revenue: '1 980 €',
                costs: '1 540 €',
                margin: '+22,2%',
                marginColor: '#FF9500',
                status: 'Postój 45/45 min',
                statusColor: '#FF9500',
              },
              {
                id: 'BKM-2844',
                vehicle: 'Transit GD 33445',
                driver: 'Adam Lewandowski',
                route: 'Gdańsk → Amsterdam',
                progress: 88,
                revenue: '1 720 €',
                costs: '1 850 €',
                margin: '−7,5%',
                marginColor: '#FF3B30',
                status: 'Awaria · serwis Apeldoorn',
                statusColor: '#FF3B30',
              },
            ].map(o => (
              <div class="grid grid-cols-12 gap-3 items-center px-4 py-3.5 hover:bg-[#FAFAFA] transition-colors">
                <div class="col-span-12 sm:col-span-3">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-[10px] font-mono text-[#86868B]">{o.id}</span>
                  </div>
                  <p class="text-[12.5px] font-semibold text-[#1D1D1F] tracking-[-0.005em] leading-tight">{o.vehicle}</p>
                  <p class="text-[11px] text-[#86868B] leading-tight">{o.driver}</p>
                </div>
                <div class="col-span-12 sm:col-span-4">
                  <p class="text-[12px] text-[#1D1D1F] mb-1.5 font-medium">{o.route}</p>
                  <div class="h-1.5 rounded-full bg-black/[0.06] overflow-hidden">
                    <div class="h-full rounded-full" style={`width:${o.progress}%; background: ${o.statusColor}`}></div>
                  </div>
                  <p class="text-[10.5px] mt-1" style={`color: ${o.statusColor}`}>{o.status}</p>
                </div>
                <div class="col-span-4 sm:col-span-2">
                  <p class="text-[10px] text-[#86868B] uppercase tracking-[0.04em]">Przychód</p>
                  <p class="text-[12.5px] font-mono font-semibold text-[#1D1D1F]">{o.revenue}</p>
                </div>
                <div class="col-span-4 sm:col-span-2">
                  <p class="text-[10px] text-[#86868B] uppercase tracking-[0.04em]">Koszty UE</p>
                  <p class="text-[12.5px] font-mono font-semibold text-[#6E6E73]">{o.costs}</p>
                </div>
                <div class="col-span-4 sm:col-span-1 text-right">
                  <p class="text-[10px] text-[#86868B] uppercase tracking-[0.04em]">Marża</p>
                  <p class="text-[13px] font-mono font-bold" style={`color: ${o.marginColor}`}>{o.margin}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <p class="text-[11px] text-[#86868B] mt-4 italic">
          Ujemna marża zlecenia BKM-2844: awaria w Apeldoorn doliczyła 320 € do kosztów. Krzysztof wie o tym w chwili dodania faktury serwisowej, nie po zamknięciu miesiąca.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============ 6 FILARÓW WARTOŚCI ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center mb-14 max-w-[680px] mx-auto">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#005CE8] mb-4">Co dostaje właściciel</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        Sześć rzeczy które zmieniają sposób, w jaki zarządzasz flotą.
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {
          title: 'Mapa floty na żywo',
          desc: 'Mapbox + WebSocket. Każdy bus aktualizuje pozycję co kilkanaście sekund. Klikasz markera — widzisz: zlecenie, kierowca, ETA, czas pracy AETR, najbliższa stacja paliw.',
          tech: 'Mapbox GL · GPS w tle · Daphne ASGI',
          icon: `<path d="M9 4l-7 3v13l7-3 6 3 7-3V4l-7 3-6-3z" stroke-width="1.6"/><path d="M9 4v13M15 7v13" stroke-width="1.6"/>`,
          color: '#005CE8',
        },
        {
          title: 'Rentowność per zlecenie — na żywo',
          desc: 'Każde aktywne zlecenie ma w karcie: przychód (z umowy), koszty paliwa (PL+UE), opłaty drogowe (Maut, Telepass, Viatoll, ASFINAG), hotele, diety zagraniczne, amortyzację. Marża aktualizuje się od razu po dodaniu paragonu.',
          tech: 'Kalkulacja per zlecenie · NBP tabela A · 6 walut',
          icon: `<path d="M3 3v18h18" stroke-width="1.6"/><path d="M7 14l4-4 4 4 5-5" stroke-width="1.6"/>`,
          color: '#34C759',
        },
        {
          title: 'Faktury z UE → jedno miejsce',
          desc: 'KSeF nie obsługuje zagranicznych faktur kosztowych — ale Twoje 60% kosztów to właśnie one. BusiKM przyjmuje paragon ze zdjęcia, OCR czyta DE/IT/FR/ES/EN, przelicza walutę po kursie NBP z dnia poprzedzającego, przypisuje do zlecenia i pojazdu.',
          tech: 'OCR multi-język · NBP tabela A · auto-przypisanie',
          icon: `<rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.6"/><path d="M7 8h10M7 12h10M7 16h6" stroke-width="1.6"/>`,
          color: '#FF9500',
        },
        {
          title: 'Compliance pakietu mobilności',
          desc: 'Czas pracy AETR (4,5h jazdy + 45 min przerwy, 9h/11h dziennego odpoczynku, 45h tygodniowego), powrót do bazy co 4 tygodnie, rotacja co 8 tygodni, kabotaż 3 operacje w 7 dni. Alerty zanim kierowcę zatrzyma BAG, ITD, Gendarmerie czy Polizia Stradale.',
          tech: 'AETR · Pakiet Mobilności UE · ITD/BAG-ready',
          icon: `<circle cx="12" cy="12" r="9" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke-width="1.6"/>`,
          color: '#8B5CF6',
        },
        {
          title: 'Tachograf G2V2 i dokumenty',
          desc: 'Od 2 lipca 2026 obowiązek wymiany na G2V2 dla pojazdów >2,5 t w transporcie międzynarodowym. BusiKM pokazuje które pojazdy wymagają wymiany, kiedy, i alertuje 90/30/14/7 dni przed wszystkimi terminami: OC, AC, przegląd, legalizacja tachografu, licencja transportowa, ADR, świadectwa kierowców.',
          tech: 'Alerty 90/30/14/7 dni · push + e-mail',
          icon: `<path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke-width="1.6"/><polyline points="22 4 12 14.01 9 11.01" stroke-width="1.6"/>`,
          color: '#FF3B30',
        },
        {
          title: 'Eksport dla księgowej i biura',
          desc: 'Twoja księgowa dostaje gotowe rejestry VAT, koszty per zlecenie, paczkę VAT-REF na zwrot z DE/FR/IT, ewidencję przebiegu. Biuro rachunkowe importuje gotowe dane do Insert GT (EDI++ .epp), Comarch ERP Optima (XML) lub Symfonia FK (TXT/AMS).',
          tech: 'EDI++ · XML · TXT/AMS · CSV',
          icon: `<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke-width="1.6"/><polyline points="7 10 12 15 17 10" stroke-width="1.6"/><line x1="12" y1="15" x2="12" y2="3" stroke-width="1.6"/>`,
          color: '#0A84FF',
        },
      ].map(f => (
        <div class="bg-white rounded-[20px] p-7 shadow-[0_1px_4px_rgba(0,0,0,0.06)] border border-transparent hover:border-black/[0.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.10)] transition-all duration-300 group">
          <div class="w-11 h-11 rounded-[14px] mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110" style={`background: ${f.color}12;`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={f.color} stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}/>
          </div>
          <h3 class="font-display font-semibold text-[1.05rem] text-[#1D1D1F] mb-2 tracking-[-0.01em]">{f.title}</h3>
          <p class="text-[13.5px] leading-relaxed text-[#6E6E73] mb-3">{f.desc}</p>
          <p class="text-[11px] font-mono text-[#86868B]">{f.tech}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ TACHOGRAF G2V2 — DEEP DIVE ============ -->
<section class="py-20 sm:py-28 bg-white px-5">
  <div class="max-w-[1000px] mx-auto">
    <div class="reveal grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-5">
        <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#FF3B30] mb-4">Termin krytyczny</p>
        <h2 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.12] mb-5">
          Tachograf G2V2.<br/>2 lipca 2026.<br/>Bez planu — stoisz.
        </h2>
        <p class="text-[14.5px] leading-relaxed text-[#6E6E73] mb-5">
          Od 2 lipca 2026 wszystkie pojazdy o DMC powyżej 2,5 t w transporcie międzynarodowym muszą mieć tachograf cyfrowy drugiej generacji wersja 2. Bez tego: kara ITD do 10 000 zł, zatrzymanie pojazdu na granicy i straty ze stojącego zlecenia.
        </p>
        <p class="text-[14.5px] leading-relaxed text-[#6E6E73]">
          BusiKM pokazuje które pojazdy w Twojej flocie muszą zostać wymienione, jakie są terminy ostatecznych wymian (na podstawie daty pierwszej rejestracji) i kiedy zacząć rezerwować wizyty w serwisach.
        </p>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-[20px] bg-[#F5F5F7] p-6 sm:p-7">
          <p class="text-[11px] font-semibold uppercase tracking-[0.06em] text-[#86868B] mb-4">Plan wymiany G2V2 — Twoja flota</p>
          <div class="space-y-2.5">
            {[
              { plate: 'DK 12345', model: 'MB Sprinter 316', current: 'G1 (2018)', deadline: '2 lip 2026', status: 'WYMAGA WYMIANY', statusColor: '#FF3B30', daysLeft: '60 dni' },
              { plate: 'KR 67890', model: 'VW Crafter 35', current: 'G2V1 (2021)', deadline: '21 sie 2026', status: 'WYMAGA WYMIANY', statusColor: '#FF9500', daysLeft: '111 dni' },
              { plate: 'WA 11223', model: 'Iveco Daily 35S', current: 'G2V2 (2024)', deadline: '—', status: 'ZGODNY', statusColor: '#34C759', daysLeft: '—' },
              { plate: 'GD 33445', model: 'Ford Transit', current: 'G2V2 (2024)', deadline: '—', status: 'ZGODNY', statusColor: '#34C759', daysLeft: '—' },
              { plate: 'PO 55667', model: 'Fiat Ducato', current: 'G1 (2017)', deadline: '2 lip 2026', status: 'WYMAGA WYMIANY', statusColor: '#FF3B30', daysLeft: '60 dni' },
            ].map(v => (
              <div class="bg-white rounded-2xl p-4 flex items-center gap-3 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-[12.5px] font-mono font-bold text-[#1D1D1F]">{v.plate}</span>
                    <span class="text-[11px] text-[#86868B]">· {v.model}</span>
                    <span class="text-[10px] text-[#86868B] hidden sm:inline">· obecnie {v.current}</span>
                  </div>
                  <p class="text-[10.5px] text-[#86868B] mt-0.5 sm:hidden">obecnie {v.current}</p>
                  <p class="text-[10.5px] mt-0.5" style={`color: ${v.statusColor}`}>{v.status} · termin {v.deadline}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-[10px] text-[#86868B] uppercase tracking-[0.04em]">Pozostało</p>
                  <p class="text-[12px] font-mono font-bold" style={`color: ${v.statusColor}`}>{v.daysLeft}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-5 pt-4 border-t border-black/[0.06] flex items-center justify-between text-[12px]">
            <span class="text-[#86868B]">3 z 5 pojazdów wymagają wymiany</span>
            <span class="font-semibold text-[#FF3B30]">Najbliższy termin: 60 dni</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ ROZLICZENIA — KSEF + UE ============ -->
<section class="py-20 sm:py-28 bg-[#F5F5F7] px-5">
  <div class="max-w-[1120px] mx-auto">
    <div class="reveal text-center max-w-[720px] mx-auto mb-14">
      <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-[#34C759] mb-4">Rentowność prawdziwa, nie księgowa</p>
      <h2 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-bold tracking-[-0.03em] text-[#1D1D1F] leading-[1.15]">
        KSeF nie powie Ci, ile zarobiłeś.<br/>BusiKM — tak.
      </h2>
      <p class="text-[15px] leading-relaxed text-[#6E6E73] mt-4">
        Krajowy System e-Faktur to świetne narzędzie do polskiego VAT-u. Ale zlecenie z Warszawy do Mediolanu generuje 60% kosztów poza Polską — w EUR, na obcojęzycznych dokumentach, których KSeF nigdy nie zobaczy.
      </p>
    </div>

